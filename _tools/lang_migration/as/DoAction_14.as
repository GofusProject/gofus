D.q[7915] = "Quelle victoire écrasante ! Splendide ! \n \nVous avez bien mérité cette médaille et ces 1250 jetons ! N\'hésitez pas à revenir vous mesurer au Gladiatrool si vous voulez remettre ça ! \n";
D.q[7916] = "Salutations guerrier et bienvenue au Gladiatrool !  \n \nJe vois que tu es impatient de retourner dans l\'arène, mais il faut être patient. Afin de laisser les autres aventuriers passer, il faut attendre 10 minutes avant d\'entrer à nouveau.";
D.q[7918] = "Vous plaisantez ? Mes sets de cartes sont les plus puissants. Allez agrémenter votre collection de cartes remarquables et on en reparlera.";
D.q[7919] = "Vous pouvez en obtenir en vainquant les créatures des différents continents. Mais également en troquant avec d\'autres aventuriers. \n \nAllez rendre visite à Lainu Prof, à la Foire du Trool, il vous en dira davantage.";
D.q[7920] = "Aaah ! Enfin un adversaire digne de ce nom, notre bataille sera légendaire. \n \nEn garde !";
D.q[9601] = "Tu veux déjà sortir ? Mais tu n\'as pas encore combattu... le jeton ne te sera pas remboursé si tu sors !";
D.q[9612] = "Bonjour, je suis Gladiatroc ! \n \nViens échanger tes jetons du Gladiatrool contre des paquets de cartes et d\'autres articles, je te fais un prix d\'ami.";
D.q[9613] = "Oh eh ! Ohhh, dis tu vas aller dans le Gladiatrool ? Ouaaah eh trop bien, j\'suis fan ! \n \nDis, dis, tu voudrais bien gagner avec l\'arme que je te dis d\'utiliser ? Si tu le fais je te donne ces Gladiatons que j\'ai récupéré dans les gradins !";
D.q[9614] = "Ouaiiis ! Alors j\'aimerais que tu participes avec cette arme ! *il la note sur votre journal de quêtes* \n \nSi tu réussis ce défi, ces jetons sont à toi.";
D.q[9627] = "Alors alors, tu t\'en sors ? \n \nTu sais, les gens me disent que j\'ai l\'humeur changeante, peut-être que demain j\'aurai envie de te voir manier une autre arme !";
D.q[9628] = "Ouah ! Tu es vraiment super balèze dis-donc !  \n \nDis, dis, tu reviendras demain pour essayer avec une autre arme ?  \nFaut que je retourne ramasser des jetons !";
D.q[9630] = "Il est noté : \n \n" + "\"" + "Salut ! \nDésolé mais le Gladiatrool est temporairement fermé. J\'ai dû aller me réapprovisionner en créatures, alors repassez plus tard !" + "\"" + " \n \nC\'est signé Notend Less";
D.q[9631] = "Il est noté : \n \n" + "\"" + "Bonjour, \nNavré mais j\'ai dû m\'absenter pour analyser une découverte scientifique majeure. Merci de repasser plus tard." + "\"" + " \n \nC\'est signé Lainu Prof";
D.q[9632] = "Il est noté : \n \n" + "\"" + "Bonjour, j\'ai dû m\'absenter temporairement. Merci de revenir plus tard !" + "\"" + " \n \nOn dirait que le gardien du donjon n\'est pas là pour le moment... C\'est sûrement pour une bonne raison.";
D.q[9638] = "Je ne vois aucune carte en votre possession, il vous faudra de puissants sets si vous espérez pouvoir m\'affronter. Commencez déjà par partir à la recherche de cartes.";
D.q[9639] = "Vous êtes un redoutable adversaire, laissez moi le temps de perfectionner mon jeu et je prendrai ma revanche...";
D.q[9640] = "Je lance un kama qui décidera de qui commence... Pile ! C\'est donc à mon tour de jouer. Je pioche et j\'invoque le " + "\"" + "DragOeuf Doré Immature" + "\"" + ". Je termine en posant une carte face cachée. A toi, essaies donc de me vaincre.";
D.q[9641] = "*Vous piochez la carte " + "\"" + "L\'Appel de Cania" + "\"" + ". Que décidez vous de faire ?*";
D.q[9642] = "*Vous piochez la carte du " + "\"" + "Tofu malade" + "\"" + ". Que décidez vous de faire ?*";
D.q[9644] = "À moi de piocher... Par Ecaflip ! On dirait que la chance est de mon côté. Je commence par jouer la carte " + "\"" + "Fouet d\'Osamodas" + "\"" + " qui me permet de faire partir la créature de mon choix du terrain et je détruis ta carte.  \n \nEnsuite je sacrifie mon " + "\"" + "DragOeuf Doré Immature" + "\"" + " pour invoquer ma toute puissante " + "\"" + "Dragoune dorée aux yeux noirs" + "\"" + " ! \n \nÀ l\'aide de la carte " + "\"" + "Roulette Avantageuse" + "\"" + ", je te fais passer un tour et j\'attaque avec ma Dragoune. Comme je le pensais, tu n\'étais pas à la hauteur...";
D.q[9645] = "*La chance vous sourit, vous piochez  " + "\"" + "Eratz le Revendicateur" + "\"" + ", " + "\"" + "Edasse le Trouble Fête" + "\"" + " et " + "\"" + "Nomekop le Crapoteur" + "\"" + ".  \nComme indiqué sur la carte " + "\"" + "L\'Appel de Cania" + "\"" + ", vous pouvez immédiatement les placer en jeu.*";
D.q[9646] = "*L\'effet de ces cartes vous permet de piocher une carte de type " + "\"" + "Dofus" + "\"" + " de votre deck si les trois sont sur le terrain.*";
D.q[9647] = "*Jouer la carte " + "\"" + "Dofus Ocre" + "\"" + " permet à toutes les cartes sur le terrain d\'attaquer même si elles viennent d\'être invoqué ou qu\'elles ont déjà attaqué durant ce tour.*";
D.q[9649] = "Eh bien, pour commencer il faudrait déjà que tu te places en face de moi, tu ne vas pas jouer par terre, non ?";
D.q[9648] = "Comment est-ce possible ?! Cela faisait bien longtemps que je n\'avais pas eu autant de mal dans un duel. Il va me falloir trouver de nouveaux sets et perfectionner mes stratégies...  \n \nEn attendant je dois reconnaître que vous m\'avez vaincu, prenez donc cette tenue de duelliste en récompense, elle vous siéra parfaitement.";
D.q[2746] = "Oui, une lumeul. Le Wa a affilmé qu\'il détenait le Dofus d\'une Cawotte Dlaconesque : le Dofus Cawotte. Et je plécise bien lumeul, cal nul ne pouvait décemment confilmer ou infilmer la chose. Petit à petit celtains aventuliers sont levenus d\'un intletien avec le Wa en ayant vu un oeuf magique, ce qui a contlibué à lendle clédible la lumeul...poultant, il ne faut jamais êtle sûl de soi, et c\'est là la molale de mon histoile.";
D.q[2562] = "Palmi les Dofus se cachent des faux... Les authentiques Dofus sont pondus pal des dlagons. Il faut vlaiment êtle naïf pour penser qu\'une Cawotle pond des oeufs ! Le Dofus Cawotte est une Cawotte enchantée par le Wa en pelsonne, ce qui lui confèle tout de même des pouvoils puissants...";
