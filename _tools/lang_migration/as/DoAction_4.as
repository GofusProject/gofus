D.q[1022] = "Jolie ! Elle est aiguisée comme au premier jour. Le forgeron a fait un travail remarquable.";
D.q[1966] = "Ah de l\'argent, merci beaucoup ahah. C\'est moi le chef, qu\'est ce que tu veux ?";
D.q[3056] = "J\'ai un petit creux.";
D.q[4137] = "Tu es digne de franchir ce pont.";
D.q[4323] = "On m\'a rapporté que tu flânais dans les rues. Qu\'as-tu à répondre à ça ?";
D.q[1272] = "Je suis le chef cuistot de la milice, alors " + "\"" + "bas les pâtes" + "\"" + " de ma cuisine.";
D.q[4025] = "Je n\'en attendais pas moins de toi !";
D.q[108] = "Quel lieu cherchez vous ?";
D.q[5459] = "Quel rang souhaites-tu avoir au sein de la milice ?";
D.q[4342] = "Salut. Qu\'est-ce qui t\'amène par ici ?";
D.q[2816] = "C\'est pour une offrande à la déesse ?";
D.q[6405] = "Non, pourquoi me demandes-tu ça ?";
D.q[3561] = "Chef pas parler avec gringalet !";
D.q[1479] = "Qu\'est ce que tu veux que ça me fasse ?! Va prendre un autre bâton et trouve-moi un Bontarien qui empeste la mort !";
D.q[6147] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[6145] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[6124] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[6123] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[3383] = "Ca c\'est bien ! Tiens, v\'la la clef pour la suite. Vas-y vite.";
D.q[2938] = "Félicitations, vous avez réussi à me vaincre, mes sbires et moi. Acceptez ce cadeau en guise de reconnaissance.";
D.q[4572] = "Répéter je vais. Ne pas insister vous devriez. Révéler l\'emplacement jamais je ne ferai.";
D.q[7514] = "Quelle caractéristique doit modifier ce parchemin ?";
D.q[3029] = "Nous avons encore battu Bonta la dernière fois, les braves s\'engagent tous chez Brâkmar !";
D.q[6444] = "Bienvenue à la Taverne de la Bagrutte. Ici c\'est moi qui donne les ordres au client, compris ?";
D.q[3890] = "texte2";
D.q[2327] = "zzZZZ... hummmM ket la ?";
D.q[4062] = "Quel sort veux-tu oublier ?";
D.q[3763] = "Quand j\'aurai récupéré assez de bric à brac ici, j\'irai à Astrub pour tout revendre.";
D.q[5642] = "C\'est qui pour toi les plus belles ? Les sramettes, les sadidettes, les craettes, les bworkettes, les cacahuètes ?";
D.q[6345] = "Tu te prends pour qui ? Hors de ma vue avant que je ne te fasse fouetter à coups de Baguette Euh\'Laille\'Fe\'.";
D.q[3576] = "Oh mais oui tu seras payée, ne t\'en fais pas pour ça. Enfin, ça dépend de ce que tu accompliras.";
D.q[5652] = "Je ne vois pas de quoi tu parles. Et puis ce ne sont pas des manières de s\'adresser à une personne âgée. Nous n\'avons pas élevé les bouftons ensemble à ce que je sache.";
D.q[3072] = "Hors de ma vue galopin ! Goujat ! Malotru !";
D.q[6427] = "Des Ecaflips ? Pas vu d\'Ecaflips, jamais. C\'est quoi au juste un Ecaflip ?";
D.q[2697] = "Ouais, enfin un faux Dofus... mais sculpté dans du minerai précieux, par une Enutrofette habile de ses mains, j\'te le dis !";
D.q[6452] = "Tu peux poser une question à condition qu\'elle ne soit pas idiote, sinon tu tâteras de mon fouet.";
D.q[1355] = "*Feuille* \nPas de chance tu as perdu...";
D.q[3304] = "Pnj(802) et Message(3302)";
D.q[1307] = "Encore un nouvel impôt ? Prenez donc ce chèque.";
D.q[1805] = "Si tu veux affronter un Dopeul, il faudra faire une donation de sang de scorbute au temple...";
D.q[1802] = "Si tu veux affronter un Dopeul, il faudra faire une donation de Liquide Vampiresque au temple...";
D.q[2333] = "Qu\'est ce que tu veux toi ? Si tu tiens à ta vie, dégage ! Et tu n\'as rien vu...sinon...";
D.q[7598] = "C\'était vraiment un beau combat, tu as bien mérité ta récompense. \nRepasse me voir à l\'occasion, peut-être que je serai enclin à te laisser combattre un autre de mes trophées de chasse.";
D.q[2525] = "" + "\"" + "C\'est à Boire à boire à boireuuuhhh, c\'est à boire qu\'il me faut WoOooooh" + "\"" + ". Que veux-tu ? Je prie. Et quand je prie, j\'ai soif...";
D.q[1779] = "Je t\'apprendrai différentes choses au fil de tes missions.";
D.q[4091] = "Maintenant il faudrait aller chercher la robe de la mariée à Bonta. Peux-tu t\'en charger ?";
D.q[3955] = "Ah, ce cher Uba... Tiens, prend ce recueil et insères-y ce que tu apprendras, je pense que ça t\'aidera.";
D.q[2094] = "Pnj(498) et Message(2093)";
D.q[477] = "Wobot matwicule 53, 2ème classe au 11ème wégiment de wobot de la gawde du Wa. \nHalte-là !";
D.q[6234] = "Merci à vous. Tenez, prenez ces pains. C\'est pas grand chose mais ça vous remplira l\'estomac pendant votre voyage. \nMaintenant montrez-moi votre carte, je vais vous indiquer là où j\'ai vu le Sram.";
D.q[240] = "Mais qui êtes-vous ? Allez-vous-en ! Haaa... Je vois ! vous essayez de voler mon trésor ! Mais il est à moi ! à moi ! De toute façon, je ne vous dirai pas où il est ! pas un mot ! Rien !";
D.q[1604] = "Equiper un objet, c\'est le sortir de son inventaire pour le porter sur soi. \nDe cette manière, on peut profiter de ses effets magiques.";
D.q[4126] = "Enfin, je commençais à m\'impatienter ! Je vais charger les munitions dans mon bateau et prendre mon petit déjeuner, tu pourras revenir me voir quand tu te sentiras prêt pour voyager vers cette île.";
D.q[2714] = "Notre mission est de bouter la vermine aventurière hors de notre île bien-aimée. Pour cela, tous les moyens sont bons : saboter les ponts, voler toutes les chaussures gauches, empoisonner les... traîtres. Bien ! Si tu veux être des nôtres, tu connais certainement la réponse à cette énigme : \nTout le monde connait le son produit par deux chopes qui trinquent, mais quel est le son d\'une seule chope ? \n";
D.q[1783] = "Si tu veux affronter un Dopeul, il faudra faire une donation de Laine de Bouftou au temple...";
D.q[818] = "Un écureuil a volé la clé de la salle du Prisme de Brâkmar, ne me demande pas pourquoi ni comment, mais plusieurs soldats l\'ont vu. \nSi on ne la retrouve pas, tu risques la pendaison, tu vois où je veux en venir.... ? \nJ\'ai déjà des gardes qui surveillent le pont, l\'écureuil ne peut pas s\'échapper !";
D.q[4545] = "L\'assaut n\'a pas été un succès complet, mais au moins vous avez vaincu quelques-uns de leurs guerriers. Malheureusement, j\'ai aussi de bien mauvaises nouvelles à t\'apprendre. Les Brâkmariens sont venus à bout des pièges de Nara et comme il a refusé de travailler pour eux, ils se sont débarrassés de lui. Il s\'est vaillamment défendu et a emporté de nombreux Brâkmariens avec lui dans la tombe. Reste à savoir ce que les Brâkmariens comptent faire à présent.";
D.q[3760] = "Vu ta force, tu risques de détruire un épouvantail d\'un seul coup ! Essaie de ne pas trop les abîmer, parce que c\'est moi qui les rempaille après !";
D.q[2906] = "Bien joué, mercenaire !";
D.q[4615] = "Beuh... T\'as pas le droit de répondre par une autre question, c\'est de la triche. Tu cherches aussi la Corne Edfrit ? \nMais !? T\'es un idiot de Bontarien. Meurs, charogne !";
D.q[1801] = "Si tu veux affronter un Dopeul, il faudra faire une donation de poison cinglant au temple...";
D.q[580] = "Pour remeeercier l\'aventuurier *hic* voici mon trésor incooongru *hic* ce pot qui m\'a fait déébuter *hic* ma carrière de peeintre-poête disparu *hoc*";
D.q[6577] = "Des tacticiens viennent parfois ici car notre bibliothèque compte plusieurs ouvrages de référence. Il y a un tacticien en particulier qui a passé ces trente dernières années à étudier la tactique, un Enutrof du nom de Dréna Nassema. Malheureusement il s\'était récemment mis en tête de se rendre au Donjon des Squelettes pour mettre son apprentissage en pratique. Je dis malheureusement car son retour était prévu il y a plus d\'une semaine et nous sommes toujours sans nouvelles de lui. Je suppose que quelque chose a mal tourné.";
D.q[4440] = "Shhh ! Tu es là pour nous apporter du poison ?";
D.q[2836] = "Salutations #1, je ne t\'ai pas vu arriver, je vois que tu as amélioré ta discrétion depuis notre dernière rencontre ! \nQue puis-je faire pour toi ?";
D.q[6165] = "Durant nos nombreuses recherches archéologiques sur cette île, nous avons trouvé beaucoup d\'indices troublants. Cette ancienne civilisation disparue semble être liée de près aux Dofus. Nous n\'avons pas encore trouvé de quelle façon, il nous reste tant de choses à découvrir et à comprendre.";
D.q[2293] = "Huuum ? Je réfléchis... Laisse-moi s\'il te plaît...";
D.q[3224] = "Je pourrais te raconter ce que je sais à propos du peuple Porco Rusto et du Dragon Cochon, j\'aime instruire les touristes un peu niais dans ton genre. Commençons par la légende, la vraie...\nGoultard était le nom de l\'épée légendaire de Garathgoul le célèbre Ecaflip. Garathgoul partit en quête du Dragon Cochon, car il savait que le Dragon Cochon recelait dans son antre le fameux Dofus Turquoise. Il trouva le Dragon Cochon et le combattit à l\'aide de sa magie et de son épée ! Garathgoul ferrailla pour sauver sa peau et son épée Goultard fut aspergée du sang odorant de Dragon Cochon. Ensuite, une étincelle jaillit lorsque l\'Ecaflip lança son sort fétiche. L\'étincelle tomba dans une flaque de boue, et on dit qu\'elle fit naître le peuple des Porcos Rustos. Voilà je t\'ai raconté tout ce que je savais à propos de cette légende.";
D.q[2110] = "Grand merci, tu nous rends un fier service !";
D.q[6174] = "Ah oui ? Ca change tout alors. Les Bontariens sont plus nombreux que nous et toute nouvelle chair à canon... je veux dire toute nouvelle recrue est la bienvenue. Tu veux rejoindre nos rangs ?";
D.q[4503] = "Où en sont tes recherches ? As-tu trouvé un forgeron susceptible de nous fournir un meilleur équipement ?";
D.q[6244] = "Je vois, monsieur a des goûts de luxe. Qu\'à cela ne tienne, j\'ai justement ce qu\'il te faut. Il s\'agit de la couronne du Roi des Borins. C\'est une oeuvre unique qui a nécessité l\'exploitation jusqu\'à épuisement de trois mines de diamants, l\'assèchement d\'un océan et la fonte de mille tonnes de métaux précieux. Tu veux la voir ?";
D.q[6268] = "Oublie ce que je viens de dire, j\'ai du travail pour toi. J\'espère que tu as toujours les cinq lingots d\'or, la nacre et la bave du Bouftou Royal avec toi sinon il faudra t\'en procurer à nouveau. \nEcoute-moi bien attentivement, je n\'ai aucune envie de me répéter et en plus j\'ai horreur de ça. Dans l\'atelier des alchimistes de Brâkmar, il y a un passage secret caché derrière le tronc central. Tu vas t\'y rendre pour enchanter le cristal de Kain Dharyn. Tu ne pourras pas le faire seul, il faudra qu\'un maître joaillomage, un maître alchimiste et un maître mineur t\'accompagnent. Il te faudra en plus posséder une Harmonie, une Potion de Rafale et une Kobalite que tu mélangeras à la Bave du Bouftou Royal.";
D.q[4329] = "Parfait. La dernière partie du plan va pouvoir débuter.";
D.q[7556] = "Je n\'aime pas trop discuter en public.";
D.q[3928] = "Des choses étranges au château ? Non, à part la visite d\'Allisteria. D\'habitude, elle ne quitte jamais ses bouftous.";
D.q[3927] = "Des choses étranges au château ? Non, à part la visite d\'Allisteria. D\'habitude, elle ne quitte jamais ses bouftous. Ah oui, et l\'intendant San Lavalss a strictement interdit de cuisiner du wabbit au château.";
D.q[2074] = "Ouch ! Du bois d\'Arash, rien qu\'ça !? Tu sais d\'ouk ça pousse au moins ? Ben moi non plus, c\'est des marchands qui passent parfois dans l\'coin qui nous en rapportent. D\'après eux, c\'est rare, t\'as pas idée ! Enorme, hein ?";
D.q[7558] = "Le contenu de cette caisse ne te regarde pas. Contente-toi de la livrer à bon port et tu seras récompensé pour tes efforts.";
D.q[4249] = "Pnj(961) et Message(4247)";
D.q[1447] = "OK, c\'est du bon boulot, j\'espère que je n\'entendrais plus parler de ces crapules... \nJe vais donner cet acte de propriété à Danathor pour qu\'il fasse le nécessaire.";
D.q[1327] = "Je vois, vous n\'êtes peut-être guère différent. Faites comme bon vous semble.";
D.q[2389] = "Tiens, v\'là le retour des renforts ! Alors tu t\'en es tiré à ce que je vois ! Et les frères Pyrite aussi... mais ils sont dans un drôle d\'état les pauvres ! Bah... le bon air de Pandala les remettra d\'aplomb ! Tu devrais aller y faire un tour, tu m\'as l\'air pâlot toi aussi... Va voir Surivitna, il est le Shaman de Pandala !";
D.q[1454] = "Huff ça va mieux. C\'est bon, je te pardonne. C\'est vrai qu\'il était infernal...comme son papa. Enfin bref. On n\'a plus de bois pour se chauffer...et c\'est toi qui vas t\'y coller. Ramène-nous 10 écorces d\'abraknydes. Tiens un pense-bête...ce serait idiot que tu oublies les ordres encore une fois n\'est-ce pas ?";
D.q[4360] = "Du nouveau ? Les taverniers savent-ils quelque chose ?";
D.q[1722] = "Les disciples Enutrofs savent utiliser n\'importe quelle arme, mais sont meilleurs avec les pelles et les marteaux.";
D.q[6593] = "Et comment pourrais-tu m\'aider ? Comment pourrais-tu conjurer une malédiction lancée par les dieux eux-mêmes ? Même mon grimoire ne m\'apporte que peu de réconfort face à cette situation. Chaque jour est pire que le précédent, j\'ignore combien de temps je pourrai tenir encore. J\'ai bien essayé de me boucher le nez, mais il ne me reste alors qu\'une seule main pour tenir mon grimoire et jeter mes sortilèges. Crois-moi, ce n\'est pas pratique du tout sans compter les crampes que ça provoque. \nMais toi, tu peux sortir d\'ici et interroger les érudits. J\'ai entendu dire que ceux de ton peuple ont accès à de vastes bibliothèques, peut-être que la solution se trouve dans l\'un de ces ouvrages.";
D.q[4338] = "J\'accepte vos conditions. Ne restez pas ici, on pourrait nous surprendre !";
D.q[585] = "Ca pas aller, moi besoin 4 carapaces différentes. Reviens quand toi avoir ça.";
D.q[4286] = "Ah ! Nos efforts ont porté leurs fruits. La taverne du Pandawa Ivre, hein ? On va pouvoir le contacter, maintenant. \nTiens, prends ces quelques bières pour te rafraîchir le gosier.";
D.q[1097] = "Voilà pour toi, reviens me voir quand il t\'en faudra davantage.";
D.q[1247] = "Enchanté, que puis-je faire pour vous ? Si vous cherchez quelconques pains ou brioches vous avez frappé à la bonne porte.";
D.q[759] = "Bon #1, un petit test de connaissance sur l\'art de la tactique, voir si tu mérite mon estime. \nSi tu échoue tu seras de nouveau de corvée de patate haha !";
D.q[3221] = "Bienvenue dans la salle des dalles ! Place-toi sur une de ces dalles et tu seras directement transporté dans une des salles de ce surprenant labyrinthe rempli de gros Porkass. Si je me fie à ton odeur, tu ne devrais pas t\'y sentir trop dépaysé ! ";
D.q[2159] = "Ca y est, j\'ai fini l\'analyse du sang... Euh va voir Saketsu, il t\'expliquera...";
D.q[6417] = "D\'accord pour 1000 Kamas mais vous faites une affaire. Et si ça ne marche pas inutile de venir vous plaindre.";
D.q[5589] = "Tu as l\'air fatigué. As-tu ressuscité Terra Tibya ?";
D.q[666] = "Je concède à enseigner les bases de la création d\'équipements magiques uniquement si deux conditions sont remplies: \n-il faut tout d\'abord maîtriser la fabrication des équipements normaux. \n-il faut ensuite me prouver que l\'on mérite mon enseignement.";
D.q[5632] = "Je pense que le dieu Xélor accorde trop de pouvoirs à ses disciples et que les Fécas sont la risée de tout Amakna, même si personne n\'ose leur dire en face.";
D.q[6531] = "Je hais ces bandits, ils nuisent au commerce et pire, à MON commerce. Cette fois ils ont eu une bonne leçon. Merci pour votre aide si... désintéressée. Montrez cette broche à Amayiro pour lui signifier ma reconnaissance. Elle n\'a pas de valeur, il me la rendra plus tard.";
D.q[4373] = "J\'ai fait une réunion avec le conseil et malgré quelques réticences, j\'ai réussi à obtenir son aval pour tendre un piège aux bandits. Un bijou d\'une grande valeur sera transporté jusqu\'à Astrub, mais j\'ajouterai quelques miliciens d\'élite aux gardes.";
D.q[4066] = "J\'ai découvert cette île il y a plusieurs années, un peu par hasard je dois bien l\'avouer. Je cherchais une sorte de nouvel éden, une île vierge de toutes les perversions que nous pouvons trouver sur le continent... \nJ\'ai trouvé cette île par erreur, j\'en cherchais une autre et mon bateau s\'est échoué ici. J\'aurais pu avoir beaucoup moins de chance, cette île est tout simplement magnifique.";
D.q[4045] = "Que faites vous encore ici, vous devriez vraiment partir maintenant.";
D.q[3379] = "J\'ai vu tant de choses, que vous, ne pourriez croire... De grands navires en feu, surgissant de l\'épaule d\'Orion. J\'ai vu des rayons fabuleux, briller dans l\'ombre de la porte de Tanhauser. Tous ces moments se perdront dans l\'oubli, comme les larmes, dans la pluie... Il est temps de partir...";
D.q[1772] = "J\'ai entraîné des Dopeuls pour qu\'ils apprennent les techniques de combat Ecaflip. Ainsi ils font d\'excellents adversaires pour s\'entraîner, et ce quel que soit son niveau.";
D.q[737] = "J\'ai parlé de toi à Danathor, l\'intendant de Bonta il y a quelque temps, et il désire te rencontrer. J\'ignore pourquoi, je suppose qu\'il a un service à te demander ou quelque chose à t\'offrir...";
D.q[3329] = "Merci, jeune aventurier.";
D.q[6386] = "Tu as besoin d\'un grattoir spécial ? Non, non, je ne veux pas savoir ce que tu comptes en faire. Commence par me rapporter mes clefs, Fidji Merline a encore oublié de me les rendre.";
D.q[970] = "Capitaine Arlok pour vous servir ! Que puis-je pour vous ?";
D.q[568] = "Vous êtes sur l\'île de Moon. Votre résidence pour les 50 prochaines années ahahah. Heureusement pour vous, l\'île s\'anime un peu ces temps-ci. Vous n\'allez pas vous ennuyer...la première semaine Ahahah!";
D.q[2792] = "Toi, tu as envie de dresser les monstres de la forêt maudite !";
D.q[3657] = "Voilà une recette que vous devez porter à ma cliente Pipelette. Elle vous paiera à la réception.";
D.q[1415] = "Les champos ? Ce sont les maîtres bolet qui les portent, tu en trouveras dans les champs au Sud de Bonta. \nInutile de prendre un champo destiné au combat, le premier venu fera l\'affaire.";
D.q[7145] = "Tu as réussi à te débarrasser d\'eux, bravo ! D\'après leur ordre de mission, ils devaient remettre des documents à un garde au pied de la Tour de Brâkmar, peut-être devrais-tu t\'y rendre à leur place et donner de faux documents ? Nous ferons ainsi d\'une pierre deux coups.";
D.q[83] = "En fait je n\'ai jamais trouvé comment faire.";
D.q[5766] = "Tu commences à savoir te débrouiller et on a déjà entendu parler de toi dans certaines tavernes, c\'est pouquoi redevenir Neutre te coûtera 2000 Kamas. \nPar contre, si tu souhaites rejoindre un alignement minoritaire, n\'oublie pas que je peux te faire changer d\'allégeance gratuitement.";
D.q[4529] = "Tu vas rendre une petite visite à Larry Poller, à la Tour des Ordres de Bonta, et voir avec lui comment améliorer notre arsenal magique. Je me moque éperdument des moyens employés pour y parvenir du moment que tu obtiens des résultats concrets.";
D.q[6280] = "Tu as vaincu les cambrioleurs et fais en sorte qu\'ils ne soient plus une menace ? Très bonne initiative même si j\'aurai préféré qu\'ils viennent grossir les rangs de mes sbires. D\'un autre côté, quelques incompétents de plus ou de moins, quelle différence ?";
D.q[1249] = "*hic* du jus de gloutovore ! *hic* \nSi tu m\'en *hic* ramèène au moins 4 je te ferais du v*hic* !";
D.q[2785] = "Psttt...maintenant que ce gros balourd est parti, on a une chance de se tirer...";
D.q[935] = "Bonjour, je suis la propriétaire de la bijouterie Bagdoré, que puis-je faire pour vous ?";
D.q[5630] = "Suit mon conseil : trouve-toi une panoplie du bouftou et ne la quitte plus.";
D.q[1092] = "Tiens je te le prête, mais faudra penser à me le rendre... Burrrp. Oh ! je ne me sens pas bien. Une bière devrait m\'aider à passer ce cap difficile. Reviens me voir quand tu veux l\'ami... Yhooo !";
D.q[887] = "77";
D.q[37] = "Bonjour, je suis Abely Bobeule, Sculpteur sur Bois renommé, j\'exerce avec talent, les professions de Sculpteur de Baguettes, Sculpteur d\'Arcs, et Sculpteurs de Bâtons.";
D.q[5636] = "J\'ai appris plein de choses en écoutant les gens discuter au zaap. Ils narrent leurs exploits, comment ils ont vaincu des créatures mythiques ou découverts d\'immenses richesses. Ils défilent avec leur super équipement, se défient, agressent des gens parfois mais tout ça dans la joie et la bonne humeur. Le plus impressionnant, c\'est leur respect d\'autrui. Je t\'ai déjà parlé de leur respect d\'autrui ? Non ? Alors il faut que j\'arrange ça.";
D.q[1206] = "Laissez-moi avec mon malheur... Il est parti, vous entendez ? Parti !";
D.q[2066] = "Tu comprends, je ne peux pas laisser ma petite toute seule pendant ce temps. Et elle ne peut pas venir avec moi non plus, tu comprends...c\'est impossible. Elle courrait partout et dérangerait tout le monde, moi le premier ! J\'ai une faveur à te demander, peux tu la garder quelques minutes. Ca ne sera pas long...";
D.q[2305] = "Keuf ! Kof ! Keuf ! *éructe bizarrement*";
D.q[2095] = "Bien bien... Sacrée petite on voit vraiment de qui elle tient. J\'ai une dernière faveur à vous demander. Avec tout ce remue-ménage, quelques-uns de nos bouftous se sont échappés, certains se sont égarés du côté des souterrains.";
D.q[6311] = "*hips* Je ne suis pas à vendre ! Ah tiens, la bouteille est vide.";
D.q[4099] = "J\'ai trouvé un nouveau maître, je vais le rejoindre tout de suite.";
D.q[3114] = "Le pauvre garçon, il ne veut pas quitter sa prison. Le roi Allister l\'a amnistié pourtant. Il avait volé tout un convoi de pommes de tewe en provenance de l\'île des Wabbits.";
D.q[3897] = "Bonjour, Loyal sujet ! J\'ai besoin de ton aide, peux-tu me rendre quelques services ? Tu seras récompensé de tes efforts.";
D.q[2497] = "Pas de taxe sur la Pandarista, pas de Pandala !";
D.q[1406] = "OUI J\'AIME LE BLEU CIEL ! ET ALORS ?! JE SUIS QUAND MEME UN HABITANT DE BRAKMAR !";
D.q[1516] = "Le problème, jeune impatient, vient de l\'émergence d\'adorateurs de Djaul. De plus en plus de brâkmariens adoptent le culte du démon sans honneur. De plus en plus de personnes ne veulent plus simplement rendre coup pour coup, mais veulent la mort de toutes choses, et pas seulement de Bonta. L\'équilibre sombre est menacé, la tête représentant le culte de Djaul menace de guerre civile. Tous les brâkmariens ont cette passion commune pour les ténèbres, mais désormais ils se séparent par la façon de les honorer.";
D.q[4065] = "Je suis désolé, mais tu ne t\'es pas encore montré assez vaillant pour que je puisse t\'offrir un oubli de sort. Affronte d\'autres créatures mythiques de cette île et reviens me voir ensuite.";
D.q[4525] = "Ah, te revoilà. Danathor voulait à nouveau te voir. Tu commences à te faire connaître par ici, tout le monde veut t\'engager !";
D.q[4021] = "L\'attentat avec le tofu a échoué. Laisse-moi réfléchir à un nouveau plan.";
D.q[5562] = "Ah ben c\'est trop tard. Un milicien vient de partir avec la potion et la formule. Pour une fois que j\'avais réussi du premier coup... Mais si vous vous dépêchez vous pourrez le rattraper. Montrez-moi votre carte, je vais vous indiquer où je l\'ai envoyé.";
D.q[940] = "Bonjour !\nSavez-vous que la ville de Bonta a un mur d\'enceinte qui compte pas moins de 128.369 pierres de craqueleur ?\nSavez-vous qu\'il a fallu 250 ouvriers pour bâtir ce mur et qu\'un 32ème d\'entre eux sont morts dans d\'atroces souffrances durant les travaux ?\nNon vous ne le saviez pas ! J\'en étais sûr.\n\nMais vous pouvez concevoir que le budget de la ville qui s\'élève à #1 kamas devra en partie être utilisé pour payer la pension de leurs veuves ? \n\nNon, bien sûr. C\'est bien ce que je disais. Maintenant, laissez-moi, j\'ai à faire.";
D.q[1248] = "Hmm, il veux que je le remplace à la porte Nord ? Bon, j\'irais après ma pause au Chabrulé. \nPfff, je te remercie pas.";
D.q[6491] = "huhuhuhéhéhé HIARHIARHIARHAHAHA !  \nJ\'avais changé d\'avis et je voulais te donner l\'information gratuitement mais puisque tu insistes, je prends le saphir. \nhuhuhuhéhéhé HIARHIARHIARHAHAHA !  \nLes réserves de poison se trouvent à un endroit auquel tu n\'as pas accès, à côté de l\'hôtel de ventes des sculpteurs. Seuls les gens naturellement doués pour l\'espionnage peuvent y pénétrer en déjouant les mécanismes cachés qui en bloquent l\'accès. En plus, l\'endroit est piégé et il faut être au moins deux pour ouvrir les grilles mais comme tu n\'as pas d\'amis, tu n\'y arriveras jamais. \nhuhuhuhéhéhé HIARHIARHIARHAHAHA !";
D.q[788] = "78";
D.q[888] = "78";
D.q[1330] = "HYYAAAAH Par Jiva, les pauvres Wabbits ! VOUS ÊTES UN MONSTRE, ALLEZ-VOUS-EN !";
D.q[3864] = "Ah, je vois que tu viens t\'assurer que tout va bien au Château... Ne t\'inquiète pas, je veille sur le trône!";
D.q[2841] = "Un membre de l\'Ordre de l\'Oeil Attentif nous a rapporté les dépouilles de trois renégats bontariens. Nous avons besoin de les interroger mais les méthodes classiques de résurrection ne fonctionnent pas. \nTu vas aller me chercher un ouvrage intitulé " + "\"" + "La bénédiction d\'Erazal" + "\"" + " à la bibliothèque.";
D.q[3917] = "Hum, je ne sais pas ce que manigance mon oncle, mais ma nourrice m\'a fait venir au château et a pris mes mesures pour une robe. C\'est bizarre quand même, je porte la même chose depuis des lustres et tout d\'un coup on veut me faire une nouvelle robe !";
D.q[3410] = "Ce n\'est pas en voyant le sommet que tu pourras te vanter d\'avoir gravi la montagne.";
D.q[4210] = "Hum, d\'après ta constitution, je peux déterminer qu\'il me faudra une relique du Corailleur Magistral, et une relique de Gourlo le Terrible pour préparer ta potion. Une fois réduites en poudre, je pourrais en retirer toute la puissance magique dont j\'ai besoin.";
D.q[4178] = "C\'est moi Crocodaille Dandi, celui qui coud des sous-vêtements coquins en écailles de Crocodaille, celui qui hypnotise les sangliers des plaines avec les doigts, celui qui a toujours voulu transformer cette île en un parc d\'attraction ! \nJe suis persuadé que les aventuriers en quête de nouvelles expériences aimeraient visiter cette île au milieu de toutes ces créatures dangereuses, les aventuriers modernes aiment avoir peur, mais pas prendre des risques. \nMalheureusement, depuis que les créatures se sont totalement échappées de leurs cages et évoluent librement, s\'en est fini de mon idée de parc d\'attraction, je dois proposer d\'autres divertissements aujourd\'hui.";
D.q[2690] = "Je suis le meilleur fabricant de bouclier pandawaïen au monde ! Et je mets mes apprentis au défi de me surpasser, c\'est comme ça que l\'on progresse le plus vite, autant eux, que moi, retenez bien cela.";
D.q[426] = "Les Eniripsas affectionnent particulièrement les baguettes. Ces dernières demandent souvent beaucoup d\'intelligence et un peu de sagesse pour pouvoir être utilisées. Les baguettes font rarement d\'importants dommages, mais confèrent souvent d\'importants pouvoirs magiques à leurs porteurs. \nLes sculpteurs de Baguettes utilisent comme outil, une Tailladeuse de Baguettes. \n";
D.q[4413] = "Formidable. Nous avons enfin capturé ce vaurien et son correspondant Brâkmarien. Ton aide et ta détermination ont été très précieuses. J\'ai demandé au boulanger de me fournir ses meilleurs pains pour fêter ça, prends-en quelques-uns ! Quant aux deux prisonniers, ils vont subir un interrogatoire et je vais faire en sorte que les richesses de Xephirès soit redistribuées à la population.";
D.q[1192] = "Il me semble que tu n\'es pas encore prêt à rejoindre nos rangs.  \nIl te faut déjà suivre une formation. Va voir Amayiro, à la caserne de la milice. Il t\'expliquera la marche à suivre.";
D.q[6216] = "Toute petite déjà je m\'intéressais à l\'horlogerie et c\'est pour ça que j\'ai choisi d\'adorer le dieu Xélor. Maintenant que je suis plus forte l\'horlogerie n\'est plus qu\'un passe-temps entre deux chasses au Bworker. A l\'occasion il faudra que tu viennes assister à l\'un de mes spectacles en arène, je te montrerai comment je mets une raclée au Bworker. D\'ailleurs là je suis en train de voir avec Moub Reicifitra pour mettre en scène un spectacle pyrotechnique.";
D.q[4037] = "Maintenant il faudrait aller chercher la robe de la mariée à Bonta. Peux-tu t\'en charger?";
D.q[3314] = "Je veux chaaaaaaaaaaaaaaarger ! Ramène-moi vite ces Dragodindes.";
D.q[1202] = "Tu as donc tous les éléments pour rejoindre l\'Ordre de l\'Esprit Salvateur. \nEs-tu toujours sûr de ton choix ?";
D.q[2696] = "Tiens, tu lui remettras cette sublime réplique de Dofus de la part des Enutrofs d\'Astrub. Nous autres, on est coincés en quarantaine.";
D.q[3731] = "Bonjour, jeune âme, que veux-tu ?";
D.q[3132] = "Voilà, tu sais désormais comment hypnotiser une Dragodinde, il ne te reste plus qu\'à acheter mon célèbre ouvrage sur l\'élevage des Dragodindes pour en savoir plus. \nBon tu es bien gentil, mais maintenant que je suis en forme, je n\'ai plus besoin de toi, et le peuple a besoin de mes connaissances, alors laisse-moi tranquille.";
D.q[3131] = "Avant d\'essayer d\'élever une Dragodinde, il faut que tu réussisses à la capturer, et pour cela, il faut tenter de détourner son attention, de l\'hypnotiser et ensuite, il suffit d\'utiliser un filet de capture. Tu dois t\'en douter, la seule façon d\'hypnotiser une Dragodinde, c\'est de lui lancer un sortilège. Et je suis le seul à pouvoir t\'apprendre ce sortilège. Je te dois bien cela, même si je parie que tu ne seras jamais un aussi bon éleveur de Dragodindes que moi.";
D.q[2457] = "Voilà une ombre à l\'ombre pour bien longtemps.";
D.q[3830] = "On dirait que tu t\'en es sorti. Bien. Félicitations. Tu as bien mérité la récompense que je remets à ceux qui ont réussi.";
D.q[1396] = "Ah vous n\'avez pas accès aux quartiers d\'interrogations ? Je vois, je vais vous donner un laisser-passer temporaire...Votre nom ? #1 ? Ah mais je me souviens, Oto m\'a parlé de vous aux dernières réunions. Du bon boulot ! Je vous en fait un définitif du coup. Tenez.";
D.q[2960] = "Ouuuulalalala ! Vous avez l\'air bien fatigué. Continuez comme ça et mon père ne fera qu\'une bouchée de vous. \nLe contraire m\'arrangerait plus en fait car j\'ai toujours rêvé de devenir Bworker à la place de Bworkie. \nPrenez ces poils et vous pourrez reprendre votre chemin ici, quand vous aurez repris des forces.";
D.q[1721] = "Les disciples Fécas peuvent utiliser n\'importe quelle arme, mais sont meilleurs avec les bâtons et les baguettes.";
D.q[2478] = "Sur Pandala, y paraîtrait qu\'ils font fermenter des larves bleues dans de la bave de Bouftou, et que c\'est goûteux ! La première chose que je ferai en allant sur cette île, c\'est lamper c\'t\'alcool, foi d\'Enutrof ! Mais tout ça nous dit pas où est passé Toyo Dzink. S\'il revient pas avec l\'ambre, on va jamais le colmater, ce pont !";
D.q[6260] = "Oto Mustam a ordonné le renforcement de la garde et les Bontariens ont été maîtrisés. Ils ont été confiés à Bout d\'chair pour en faire des conserves. Il veut également que vous renvoyiez un message au Captain Starky en le prévenant que sa nièce risque de subir le même sort s\'il ne se montre pas coopératif.";
D.q[6785] = "Ledrob Terceséc ? Il ne vient plus ici depuis sa réaction allergique au mélange de poils de chacha et d\'arakne. C\'est dommage, c\'était un bon client.";
D.q[262] = "En tant que Crâ, vous pouvez accéder à l\'étage, mais il est actuellement occupé par mon entraineur de dopeul.";
D.q[1558] = "Moo oom holp m\'om plos\'om moo oom.";
D.q[2144] = "Ohhh c\'est pas cool ça... Allez steuplé fais un effort quoi... Ramène moi l\'extrait de fleur de Dizbi comme ça je pourrais en renifler tranquillement tout en contemplant la nature au coin de mon chataignier fétiche.";
D.q[4551] = "Huuummm. Très bon ce plat est. Du vertgely ajouté vous avez ? Un grand chef cuisinier indubitablement vous êtes. Pourtant même avec ce plat, m\'amadouer vous ne parviendrez pas.";
D.q[2365] = "Par là-bas, c\'est Amakna. J\'va te dire, y commence à y\'avoir de drôles d\'histoires sur c\'qui s\'passe de s\'côté. Mais j\'vois bien à ta tête qu\'c\'est pas fait pour te déplaire, hein ?";
D.q[4014] = "Servir un prince, hein? Il doit être riche, s\'il est prince, non ? Alors, combien il paie ?";
D.q[4883] = "Tu peux dire à Amayiro qu\'il pourra compter sur mon aide et celle de mes hommes.";
D.q[3778] = "Veux-tu retourner à ta statue ?";
D.q[2329] = "Mon écureuil s\'est encore échappé ! *sniffff*  \nIl n\'arrête pas de se sauver... Et j\'en ai assez ! Cette fois-ci, j\'ai mis un avis de recherche pour qu\'on le retrouve... Va d\'abord le lire. Si tu le croises ensuite dans Astrub, et que tu essaies de l\'attraper, il va sûrement se défendre... Il est adorable - quoique les chachas du quartier en ont peur...";
D.q[1503] = "On surveille ce côté de près. La terre est à portée d\'une bonne corde ou d\'un bon téléport. Il faut donc faire attention.";
D.q[1198] = "Très bien, tu as donc déjà retenu ma première leçon : bien réfléchir aux différents choix avant de prendre une décision définitive. \nReviens dès que tu seras sûr de toi.";
D.q[4622] = "Oh, oh ! Du calme ! Je me disais qu\'un service en valait un autre, mais je suppose que les Brâkmariens voient la chose autrement... \nBon, alors c\'est simple : tout ce que je sais, c\'est que cette corne magique serait sur une île mais j\'ignore laquelle. \nJe n\'en sais pas plus, je ne suis pas une bibliothèque sur pattes comme Harry Stote.";
D.q[2583] = "Halte là ! On ne passe pas !";
D.q[1405] = "Qu\'as- tu fait des graines que je t\'avais données ? Bon si tu en veux d\'autres cela te coûtera 1000 kamas !";
D.q[2557] = "Inutile de mentir, vermine insolente ! Ces oeufs diaboliques sèment violence et désolation partout où ils se trouvent ! Comprends moi bien : un oeuf de dragon ne ferait pas de mal à un Moskito : c\'est toute la bande d" + "\"" + "aventuriers cupides – dont tu fais partie - qu\'il faut exterminer... n\'est-ce pas ?";
D.q[2798] = "L\'appel de la forêt, même maudite, t\'appelle me semble-t-il...";
D.q[6277] = "Ca marche ! Vous voyez les gars, moi je sais y faire avec les femmes. C\'est pour ça que c\'est moi le chef. \nBon alors parlons sérieusement, tu reviens me voir demain soir, je m\'arrangerai pour que les gars soient à la taverne et qu\'ils nous laissent tranquilles. Tu vas voir ma mignonne, le doigté des Srams n\'est pas une légende.";
D.q[2006] = "Perdu ta fleur de Dizbi ?! Du pur gâchis !... tiens, en voilà une autre, et prends en soin, c\'est assez précieux comme ça !";
D.q[2970] = "Oui, je t\'écoute.";
D.q[5703] = "Non ! Attends. Il y a une statuette cachée dans la mine du village d\'Amakna. Il faut une magie assez puissante pour la faire apparaître.";
D.q[2939] = "Donner la clé et rentrer.";
D.q[335] = "Voilà, vous disposez maintenant des bases nécessaires pour exercer ce métier, mais n\'oubliez pas qu\'il vous faut l\'outil adéquat pour exercer votre métier. Regardez les outils que je vends.";
D.q[2786] = "Je suis pas un bwak, je suis juste tombée dans une des sources maudites en essayant de fuir ces abrutis !";
D.q[484] = "Tenez, j\'ai noté sur ce parchemin la liste des missions inachevées, n\'hésitez pas à me demander des renseignements.";
D.q[2512] = "Tiens, tu lui remettras cette sublime réplique de Dofus de la part des Enutrofs d\'Astrub.";
D.q[2223] = "N\'oublie pas d\'aller dire à ton maître que j\'moccupe d\'ses Tofus !";
D.q[6600] = "Bonjour noble serviteur de Bonta. La mission que je t\'ai confiée pour la plus grande gloire de Bonta avance-t-elle ?";
D.q[3137] = "Parfait, c\'est incroyable, mon rêve se réalise, je peux enfin avoir autant de prestance que le Koulosse ! \nTu as bien mérité la clef que je viens de te donner, mais rappelle-toi, Skeunk est un maître Eniripsa, il est très dangereux, personne à ma connaissance n\'a encore réussi à le battre ! \nPour arriver jusqu\'à Skeunk, il faudra que tu traverses une vallée aride peuplée de dangereux Koalaks, et que tu présentes cette clef au gardien du repère de Skeunk... \n";
D.q[1142] = "Hmm j\'y pense, tu n\'as pas l\'âge légal pour boire du vin de Gloutovore. \nQuel dommage, je ne vais pas pouvoir le partager avec toi. \nPar contre il parait que tu devais me donner une lettre... Merci. Mais quel incompétence quand même. La prochaine fois c\'est le cachot compris ?!";
D.q[2765] = "Parfait ! Tu maîtrises les bases du Pandawushu. Les choses sérieuses vont maintenant commencer : à partir de maintenant je t\'accorderai un entrainement particulier chaque jour ! Tu t\'entraîneras pour obtenir les grades supérieurs, les Danwas...";
D.q[5557] = "Maintenant il faut que je trouve où j\'ai rangé la formule...\nAlors c\'est très simple : vous mettez une goutte de cette potion sur chaque graine, vous les planter et lorsque vous avez terminé, vous lisez à voix haute le texte écrit sur ce parchemin. Vous savez lire, n\'est-ce pas ?\nCe sort ne fonctionne que sur l\'avoine donc il faut trouver un champ où l\'utiliser. Il est important de bien faire les choses c\'est pourquoi l\'aide de plusieurs paysans et alchimistes est nécessaire. J\'ai envoyé quelqu\'un préparer un champ pour vous, je vais indiquer où sur votre carte pour que vous ne perdiez pas de temps à le chercher.";
D.q[2462] = "Salut ! Comme moi, tu aimes la douceur du bois ? Va voir Oli Venders, c\'est le meilleur bûcheron d\'Astrub. Si tu te débrouilles bien, il pourra même prendre le temps de t\'apprendre les bases de son métier. Je t\'ai indiqué le chemin. Tu n\'as qu\'à suivre ta boussole.";
D.q[2150] = "Dépêche toi d\'aller chez le forgeron. Il fondra ces kamas pour t\'en faire une lame digne de ton bras. Je t\'ai indiqué le chemin. Tu n\'as qu\'à suivre ta boussole. Reviens me voir après.";
D.q[5592] = "Va donc faire un tour à Bonta et demande à Finche Aticus s\'il y a du nouveau.";
D.q[6249] = "Bonjour, que faites-vous chez moi ? Si vous voulez cambrioler ma maison, je vous préviens : mon oncle Starky est capitaine de la milice de Bonta et il vous le fera payer cher.";
D.q[600] = "Je vois que vous êtes déterminé...Je ne vous stopperai pas. Voici une corde, attachez la comme un collier et vous êtes prêt ! Bon voyage et envoyez nous une carte postale!";
D.q[1841] = "Une Eriaxis Rigida Acrimonieuse, haha, je tiens là un joli spécimen. Voyez par vous-même, tendez l\'oreille à cette orchidée, et vous serez de mauvaise humeur toute la journée ! \nOh, je n\'ai pas fait attention à l\'heure, il faut que je nourrisse ma plante Audrey, une Brâkmaris Acerbe d\'une extrême rareté... pouvez-vous me donner un coup de main et aller l\'arroser ? ";
D.q[2661] = "L\'Horloge Divine vit sa propre vie, et elle se stabilise d\'elle-même malgré les interférences magiques du Monde et de l\'Univers. Lorsqu\'elles deviennent importantes, il arrive que les portes du temps s\'entrouvent... suffisamment pour que des démons redoutables s\'infiltrent dans notre Monde : " + "\"" + "Les démons des heures" + "\"" + ". \nDepuis quelque temps, l\'agitation qui se crée autour des Dofus, provoque des fluctuations temporelles de plus en plus importantes, je te laisse donc deviner la suite...";
D.q[304] = "A l\'instant critique quand tout le monde craque...";
D.q[636] = "Si vous désirez des recettes je vous conseille de faire un tour à la bibliothèque. Un alchimiste a créé une encyclopédie en plus de 12 tomes sur les recettes rares.";
D.q[404] = "Le métier de Mineur est un métier difficile, il faut aimer l\'obscurité, et ne pas avoir peur d\'affronter un Craqueleur avec une pioche. \nCe métier est cependant assez gratifiant, vous pouvez, sans trop de difficultés, devenir riche à condition de travailler dans les meilleures mines. \nL\'outil par excellence du mineur est la pioche, prenez soin de la vôtre et ne la laissez pas rouiller.";
D.q[3791] = "Salut, tu voyages seul ? Sur Incarnam tu n\'auras pas de problèmes mais en Amakna, il est souvent sage de voyager à plusieurs. Moi j\'aime pouvoir compter sur mes amis. Pour les contacter, je tiens un agenda à jour. Tu devrais le faire toi aussi. Ainsi, tu pourras contacter les personnes disponibles plus facilement.";
D.q[548] = "Hola moussaillon *hic* l\'heeure est graave *hic*! Bientôt plus de boâsson *hic* pour remplir ces cââles *hic*.  \nMais si ce n\'était que çaa *hic* Ma muûse a disparu *hic* mon graand squelette de bois *hic* mon moodèle aux heures perdues *hic*.";
D.q[3879] = "Ah, très bien, vous avez trouvé un moyen de rentrer ! Bravo ! Bon, maintenant, allez trouver Vil. Surtout pas de combat ! Je veux juste lui parler !";
D.q[4484] = "J\'ai une nouvelle mission pour toi. D\'après un récent courrier de Xephirès, décidément nous avons bien fait de le corrompre, le navire bontarien La Descemer aurait ses soutes pleines à craquer d\'objets magiques. Il fait actuellement route vers le Port de Madrestam pour être déchargé et tu dois dérober son contenu avant qu\'il ne se retrouve sous bonne escorte. Commence par interroger le capitaine Lily pour savoir si le navire est déjà arrivé. Autant te prévenir que si tu échoues tu subiras le supplice de la tofoune.";
D.q[3203] = "Je sens que tu n\'as rien compris... Heureusement, tu as un plan pour te repérer, alors il faudra que tu l\'utilises, pour t\'organiser avec tes coéquipiers. Oui... J\'ai oublié de te prévenir, tu n\'as aucune chance, si tu y vas seul, plus vous serez nombreux, plus vous aurez de chance de progresser dans ce terrible labyrinthe. Une fois dans le labyrinthe, tu remarqueras que chaque porte et chaque levier dispose d\'un code de couleur. ";
D.q[6415] = "Par les douze dieux, comment est-ce possible ? Tu... tu es pauvre ! Avec ta dégaine de plouc j\'aurai dû m\'en douter. rassure-moi, ce n\'est pas contagieux, si ? Tiens, prends cette recette et va-t-en, je ne voudrai pas être contaminé.";
D.q[6356] = "Je sais que des contrebandiers oeuvrent dans ce port, j\'en mettrais ta main à couper ! Depuis la découverte des îles de Wabbit et Moon et la mise en place de circuits touristiques par l\'Agence Touriste la contrebande est florissante. D\'ailleurs tu m\'as l\'air louche, tu n\'essaierais pas de me distraire par hasard ?";
D.q[393] = "Vous avez de la chance, on dirait que je l\'ai sous la main. Il me manque 90 Pattes d\'Arakne et 65 Trèfles à Cinq Feuilles.";
D.q[1466] = "Jik itrik inik nikiril ibindinnik, imirik binik ritrivirik mik miminik misik jik cririk qik illik ik itik ciptirik...";
D.q[3467] = "Toâ kraser trool. Toâ brav !";
D.q[1512] = "Il y a peu, Brâkmar et Bonta ont soudainement refait surface, caprice des dieux ou des gardiens, personne ne le sait encore. Les Amakneens versés dans les cultes sombres migrèrent en petite partie à Brakmar et, à l\'inverse, ceux de la lumière à Bonta. Les nouveaux habitants de Brâkmar élurent 3 représentants, un par culte sombre majeur : Djaul, Hécate, Brumaire pour gouverner au mieux la cité. Je suis celui de Brumaire.";
D.q[1570] = "Tout de suite ? Pour défendre les remparts ? Grmph je n\'en ai plus en stock. Quoique...L\'occasion est bonne pour tester ma nouvelle création. Elle est fragile, mais tire très loin...L\'inconvénient c\'est qu\'elle est trop puissante et on ne peut pas tirer à courte portée.";
D.q[1505] = "Bien, chope la corde ! Voilà. Possèdes-tu une attaque très longue portée ? parce que tu vas en avoir besoin là.";
D.q[2858] = "Pour sortir d\'ici, tu as le choix entre payer 2000 kamas de caution, ou attendre 20 minutes avant de pouvoir sortir. \nLa prison est trop petite pour que nous gardions des êtres aussi misérable que toi indéfiniment...";
D.q[3342] = "Salut! Bienvenue sur le serveur de test. \n \nVoici une liste de quelques unes des nouveautés apportées par cette version 1.17.0 BETA 1 : \n \n - Le donjon des Abraknydes et celui du Chêne Mou; \n - Le système de forgemagie revu; \n - Les emotes avec la commande /me; \n - La correction du problèmes des cases bloquantes; \n - Un nouveau système de choix de serveur automatique; \n - Une liste plus complète des caracteristiques de son personnage. \n \nCette liste n\'est pas complète, tu peux en trouver une plus exaustive sur le forum, dans la section Serveur de test. \n \nEn haut à droite de ton écran, à coté du menu des options, se trouve maintenant un petit bouton qui te permet de soumettre au support un problème que tu aurais constaté. Tu peux également en discuter sur le forum. \n \nVoilà voilà, alors, qu\'est-ce que je peux faire pour toi?";
D.q[5935] = "Salut petit Bouloute, je suis là pour échanger les friandises qui ne sont plus comestibles. Ne me demande pas pourquoi j\'offre de très bonnes friandises contre d\'autres friandises non comestibles, c\'est une histoire à dormir debout. Et tu n\'as pas envie de dormir debout.";
D.q[1245] = "Bonjouuur, je suis le grand Paro Cabanne, généreux créateur, incroyable styliste et génial prophète. Que puis-je faire pour votre petite personne ?";
D.q[398] = "Bonjour, je suis Eowïne Fiole. Je suis la grande spécialiste des potions. C\'est votre jour de chance, j\'ai besoin d\'ingrédients. Aidez-moi à en trouver et vous serez récompensé.";
D.q[5591] = "Que m\'as-tu fait ? Je sens des picotements dans tout mon corps et ça fait mal. Vile petite canaille, je suis sûre que c\'est à cause de ton urine. D\'ailleurs tu devrais arrêter d\'en boire, ça déteint sur ton haleine.";
D.q[1621] = "Salut, quel bon vent t\'amène dans la cité des nuages ? \nAvec un ami nous fabriquons des potions pour se déplacer plus vite qu\'une rafale ! N\'en parle pas à Girle Pylote, elle ne jure que par les engins mécaniques...";
D.q[6475] = "Je vous comprend, ça doit être terrible. Plus aucune soirée passée à la belle étoile dans les plaines de Cania, plus personne pour vous réconforter la nuit, plus personne pour vous lécher le matin. \nLa perte d\'un familier est toujours un moment difficile et éprouvant mais j\'ai entendu dire qu\'il était possible de ramener à la vie un fantôme de familier. Pour ça vous devez trouver un sanctuaire dans les marécages et passer toutes ses épreuves.";
D.q[1584] = "Sik tik vixik prifitirik dik pivirik miricilixik ilik tik fidrik inik binnik risinik itik mik dinnik ink glindik...";
D.q[2434] = "Il vous faudra faire un petit détour, il se trouve sur la presqu\'île au centre du lac.";
D.q[5668] = "Je ne m\'attendais pas à ce que tu réussisses aussi facilement mais ce n\'est pas plus mal. Puisque tu as été capable d\'en capturer une, tu intègres les rangs des Chasseurs d\'Âmes.";
D.q[3704] = "Je protège le dernier orme d\'Incarnam. Nul ne peut le couper. Celui qui le ferait, se ferait attaquer par un protecteur de la Nature ou Sadida lui-même !";
D.q[4508] = "J\'ai déjà eu affaire à eux... \nS\'ils gagnent le conflit, ils me chasseront de ma mine et me forceront sûrement à travailler pour eux. Tout sauf ça ! \nNéanmoins, je ne vous fais pas confiance pour autant. La confiance se mérite, vous allez donc me prouver que je peux avoir un minimum confiance en vous.";
D.q[1762] = "Si tu veux affronter un Dopeul, je te conseille de te préparer. Alors ? prêt ?";
D.q[1892] = "J\'ai toujours rêvé d\'avoir un apprenti comme toi, tu sais le genre qu\'on envoie faire des commissions à l\'autre bout du pays et qui revient toujours avec le sourire... Enfin bref, si tu veux aller un peu sur le terrain, je voudrais que tu sillonnes les alentours et que tu répertories trois endroits dans les champs où poussent le plus souvent des fleurs, j\'aimerais faire un recoupement topographique des espèces les plus courantes !";
D.q[1974] = "Ouais za va hein ! J\'ai bien zentit que j\'avais comme une marque de pelle zur la face, mais le broblème n\'est bas là ! J\'ai des infos zuper imbortantes, mais l\'Enutrof gui m\'a surbris a maintenant mon rabbort en sa bossession, et s\'il z\'en zert, z\'en est fini de moi ! Tu combrends ?!";
D.q[457] = "Bonjour, voilà plusieurs semaines que j\'essaye sans succès d\'apprivoiser ces dragodindes pour les chevaucher. J\'aurais tant aimé en faire un commerce...";
D.q[6749] = "Les autres sont arrivés à Astrub sans encombre. Aucune trace de bandits, je crois que nous avons fait chou blanc.";
D.q[3675] = "Au delà de ce pont, il y a le ballon vers Astrub ou Pandala. Que d\'aventures pour ceux qui osent s\'y rendre, seul ou à plusieurs !";
D.q[3380] = "Arrrh sur que j\'peux te trouver un truc \'faire, j\'ben un coin ou deux à d\'ratiser s\'tu vois s\'qu\'je pense. Si l\'maître te d\'mande ça, doit avoir ses raisons. Tiens, commence donc par ça.";
D.q[6813] = "Si tu poses la question c\'est parce que tu as déjà rendu visite à Sabine dans sa cellule, n\'est-ce pas ?\nComment ça, non ? Tu te moques de moi ? Vas-y au galop avant que je te botte les fesses à coups de rangers cloutées";
D.q[1882] = "Grand Dieu merci ! Je suis tellement absorbé par mon travail, que j\'en oublierais presque où j\'habite, haha ! Puisque je vois que tu aimes rendre service, ne voudrais-tu pas me ramener une fleur de pissenlit diabolique, j\'en croise souvent en allant dans les champs au Nord-Est du village... \nJ\'aimerais comparer la composition de leurs graines avec de l\'Epyss Sauvage que j\'ai ramassée hier !";
D.q[1962] = "Des explications ? Te crois tu en position de force pour demander des explications ?!";
D.q[3158] = "Quelle malchance, la dernière tempête a malheureusement abîmé la coque de mon magnifique bateau. Si tu me ramènes 15698758² planches en bois de Frêne et 100 kamas, je pourrais cependant le réparer et t\'y emmener gratuitement, je suis quelqu\'un de généreux... \nArrête de rêver, je plaisantais, je n\'ai pas envie d\'emmener un plouc comme toi sur mon bateau !";
D.q[3231] = "J\'ai regardé comment tu te bats, et franchement, je suis impressionné.\nJe ne plaisante pas, tu ne ressembles à rien, tu t\'habilles mal, tu as un horrible accent... Tu me fais penser à ces ploucs qui viennent du sud ! Heureusement, tu sais te battre, ça compense beaucoup de choses...\nBon je suppose que tu veux que je te sorte d\'ici ?";
D.q[397] = "C\'est gentil à vous. En fait, il me faudrait 60 Peaux de Larve Bleue, 50 Peaux de Larve Orange, 50 Peaux de Larve Verte, 40 Ailes de Tofu Maléfique et 30 unités de Sang de Vampire. \nSi vous pouvez me ramener tout ça, je vous donnerai un parchemin très puissant.";
D.q[1643] = "La multygely ? C\'est un croisement maudit de bonbon gely. Plus personne n\'en vend car elle a provoqué la disparition de nombreux enfants. Il parait qu\'elle envoie la personne qui la mange dans ses pires cauchemars.";
D.q[4105] = "La première potion permet d\'oublier totalement tes caractéristiques, elles seront identiques à celles que tu avais lorsque tu es arrivé sur le monde des douze. Tout ce que tu auras appris grâce à des parchemins sera perdu. Tu pourras grâce à cette potion, changer complètement ta façon de combattre et d\'utiliser tes sorts, en changeant tes éléments de prédilection.";
D.q[4461] = "Bien. Un allié de Bonta en moins, c\'est un atout en plus pour nous. \nTu n\'as rien à faire ? Tant mieux, tu vas donc retourner à Bonta et trouver le secret du domptage des Crocs Glands. Si tu ne sais pas où chercher, pourquoi ne pas commencer par la bibliothèque ?";
D.q[3296] = "Il est vrai que je n\'y croyais plus moi-même. Nous avons enfin un bâtiment dédié au savoir, à la culture, à l\'intelligence, à la mémoire, à la commémoration de la grandeur de Bonta.";
D.q[2789] = "Bien joué, sortons d\'ici, on se sépare pour brouiller les pistes maintenant, bonne chance !";
D.q[2218] = "Par là-bas, c\'est Amakna. J\'va te dire, y commence à y\'avoir de drôles d\'histoires sur c\'qui s\'passe de s\'côté. Mais j\'vois bien à ta tête qu\'c\'est pas fait pour te déplaire, hein ?";
D.q[327] = "Parmi ceux qui iront, certains n\'en reviendront pas. Et même ceux qui en reviendront, ils n\'en reviendront pas. Et si vous en revenez tous, alors c\'est moi qui n\'en reviendrai pas.";
D.q[2922] = "Que me vaut la visite d\'un de mes apprentis ?";
D.q[2340] = "Tu as trouvé d\'où venait la bête qui ravage mon troupeau ? Reviens me voir quand tu seras certain qu\'il soit neutralisé !";
D.q[1855] = "Merci beaucoup. Tenez voici un peu d\'argent de poche, vous l\'avez bien mérité. Je me demande quand même ce que ces sousouris viennent faire ici. Je suis sure que c\'est à cause de toute cette pagaille dans les souterrains. Ca fait remonter les sousouris ça... Kwikwi est d\'accord avec moi !";
D.q[1850] = "Meow !";
D.q[554] = "Les habitants de l\'île sont assez bourrus au premier abord. Mais ne croyez pas qu\'ils ont une dent contre vous ! Bien au contraire, ils adorent vraiment les touristes. Rien ne surpasse plus leur compagnie que leur chef lui-même. On dit de ce dernier qu\'il est l\'incarnation du Dieu de l\'île : Moon. Ne vous fiez pas à son apparence, il est vraiment très intelligent et drôle.";
D.q[4292] = "Alors ? Tu lui as parlé ?";
D.q[4380] = "Alors, as-tu le bijou ?";
D.q[415] = "La province d\'Amakna est paisible, mais parfois vous serez amené à combattre des monstres, à vous défendre d\'agresseurs, à châtier des agresseurs, ou à défier d\'autres personnes.";
D.q[1193] = "Pour trouver sa tombe, il te suffit d\'aller jusqu\'à cet endroit que je viens de marquer sur ta carte. \nDevant sa tombe se trouvent des fleurs que j\'y ai déposées récemment, tu ne devrais pas la rater...";
D.q[170] = "Pour faire du pain, il faut de la Farine, de l\'Eau et parfois de la Levure de Boulanger. En général, les meilleurs pains sont ceux composés de multiples farines, mais ils sont également beaucoup plus complexes à cuire.";
D.q[2372] = "Tiens tiens, v\'la la terreur du rat d\'égoût ! Avec c\'que tu lui as mis, tu dois être connu de tous les rats d\'Astrub maint\'nant ! Qu\'est-ce qui t\'amène ?";
D.q[4041] = "Attention, le monstwe wevient!";
D.q[3230] = "Comment cela, tu veux continuer cette discussion ? Je t\'ai déjà consacré suffisamment de temps ! Et je t\'ai dit tout ce que je savais à propos des Porcos.";
D.q[6275] = "Tope-la. A partir de maintenant nous allons nous recycler dans le détournement de dragodindes. J\'ai justement un cousin qui recrute.";
D.q[5672] = "Encore toi ? T\'es du genre coriace à ce que je vois. Mais si tu crois que ça va suffire pour nous attraper, tu te trompes.";
D.q[1587] = "Souhaites-tu me rendre la bague ?";
D.q[1620] = "J\'aime beaucoup voyager, c\'est pourquoi j\'ai décidé de proposer un transport gratuit pour tous les amis et membres du village. \nIl te suffit de choisir une destination pour t\'y rendre !";
D.q[1448] = "MAIS JE T\'AVAIS DEMANDE DE PERDRE ! Tu vas comprendre ma colère !";
D.q[6323] = "Tu as de la chance sur ce coup. Continue à m\'apporter régulièrement des bonnes nouvelles et tout se passera bien, peut-être même que je te confierai des missions plus importantes. En attendant déguerpis, je n\'ai toujours pas digéré les autres nouvelles.";
D.q[6541] = "Mais c\'est pas vrai, c\'est un véritable cauchemar ! Comment ai-je pu enrôler une créature aussi, aussi... il n\'y a pas de mot pour qualifier ta stupidité. Tu oses me désobéir et prendre du bon temps avec la cible que je t\'avais désignée ? \nPour ta gouverne sache que Trape agissait sur service commandé et qu\'elle me sert à tester les andouilles dans ton genre. Je voulais savoir à quel point tu étais maléfique pour te confier des missions plus importantes mais je me suis fourvoyé. Tiens, voilà une liste de course, si tu me rapportes ces objets j\'éviterai peut-être de donner l\'ordre à mes meilleurs assassins de t\'éliminer membre par membre. \nUn dernier petit détail : ne t\'avise plus de t\'approcher de Trape, pour quelque raison que ce soit ! Me suis-je bien fait comprendre ? Ose l\'effleurer ou pire, penser à elle et je te fais avaler un bourbassingue vivant.";
D.q[7668] = "Salut ! \nTu es à la recherche de biens et de fortune ? Approche, j\'ai en ma possession une poignée d\'enclos de grande valeur ! À de très bons prix nets vendeurs ! Bien sûr, elles sont toutes aux normes, je n\'ai pas décelé le moindre " + "\"" + "ecache-misère" + "\"" + " si je puis m\'exprimer ainsi, miaha ! \n \nCependant, en tant qu\'aficionado de combats épiques, je ne les proposerais qu\'aux plus méritants, alors rassemble tes alliés et c\'est parti !";
D.q[642] = "Voilà je signe ce petit papier...Allez voir l\'Alchimiste Examinateur. Je ne sais hélas où il est. Je peux simplement vous dire qu\'il fait actuellement des recherches sur le calcium du cartilage intranasal post-mortem.";
D.q[2140] = "Que veux-tu ? Je n\'ai pas la patience de discuter de la pluie et du beau temps, laisse-moi tranquille...";
D.q[4287] = "Le but est de se faire passer pour des marchands, pas pour des mendiants. Tu aurais pu demander à Amayiro de te trouver une tenue décente. Enfin, de toute manière il est trop tard, nous devons y aller. D\'autres gardes sont cachés dans les véhicules, ils nous assisteront en cas d\'attaque. Allons-y !";
D.q[6435] = "Que les choses soient claires : j\'ai eu une aventure avec un Ecaflip jusqu\'au jour où je me suis aperçue que c\'était un raté. Soit disant il était le chef d\'un groupe de bandits alors j\'ai insisté pour qu\'il m\'amène à son repaire. J\'ai tellement insisté qu\'il a fini par accepter et c\'est une fois sur place que j\'ai compris qu\'il n\'était qu\'un sous-fifre. Il a voulu faire profiter ses copains de ma présence et depuis ce jour plusieurs d\'entre eux sont soit borgnes, soit manchots, soit cul-de-jatte, soit les trois à la fois.";
D.q[6778] = "Pose ça à côté de la table, ça va être rapide. \nJ\'espère que tu n\'as pas attiré l\'attention au moins ? Bah, au pire je trouverai bien un prétexte, ce ne sont pas les fausses excuses qui manquent à Brâkmar. \nAu fait, as-tu vu ma soeur récemment ? Je n\'ai pas eu de nouvelles de sa part depuis longtemps mais j\'ai entendu dire que les affaires marchaient plutôt bien pour elles. Je ne me plains pas, au contraire. Bien que je ne croule pas sous les commandes j\'ai suffisamment de clients pour gagner ma vie. \nVoilà, c\'est terminé ! J\'ai trafiqué les mangeoires pour qu\'elles nourrissent les dragodindes avec des aubergines sans attirer l\'attention. Va les mettre dans l\'enclos public, le résultat sera explosif.";
D.q[3866] = "Savez vous comment les roublards ont aidé le démon Uk\'Not\'Allag à s\'évader ?";
D.q[1734] = "Disciple, tu dois avoir encore beaucoup de choses à apprendre, que veux-tu savoir ?";
D.q[5468] = "Mais enfin tu ne comprends pas que tout le comique de la situation est intrinsèquement contenu dans l\'incongruité des circonstances qui amènent un ours, plantigrade dénué de parole, à demander une bière dans une taverne... à moins, qu\'effectivement, ce ne soit le fait de ne pas s\'en étonner.";
D.q[1596] = "Que beux-tu bumain ? Bomment ose tu me béranger bendant bette bartie ?";
D.q[1191] = "Voyons voir... Oui, tu sembles avoir commencé la formation de ce brave Amayiro. \nIl est peut-être temps pour toi de choisir un ordre et de te spécialiser au mieux pour servir les intérêts de Bonta ! \n \nJe suis moi-même le maître de l\'ordre du Coeur Vaillant, pour te renseigner sur un autre ordre, je te conseille de visiter les autres étages de la tour...";
D.q[1845] = "*peut être a-t-il faim maintenant* \n *il faudrait se renseigner sur l\'alimentation d\'un chacha et lui donner à manger*";
D.q[3315] = "Pour charger les Brâkmariens avec ma cavalerie, j\'ai besoin de Dragodindes véloces et résistantes !";
D.q[259] = "Oh merci ! Si vous parvenez à me débarrasser de ces satanées bestioles, je saurai vous récompenser. Hum... Perdez cet air pervers, je vous paierai en biens matériels !";
D.q[341] = "Les sculpteurs travaillent différentes essences de bois suivant leurs besoins, mais il leur faut parfois d\'autres éléments rares comme des pierres précieuses ou des métaux rares. \nPlus vous progressez dans votre métier de Sculpteur, plus vous pouvez sculpter des objets puissants. \nJe peux vous apprendre des métiers de sculpture, mais attention, l\'apprentissage d\'un métier est très long, et il faudra pour progresser, vous exercer de nombreuses fois. ";
D.q[2903] = "Félicitation, tu es désormais un disciple Pandawushu du grade Gokwa!";
D.q[6367] = "Bwak bwak bwaaAAAK ! \n(apparemment il vous faut utiliser la corde depuis un autre endroit).";
D.q[2579] = "Si tu refuses, tu m\'offenses. Si tu m\'offenses, tu offenses tous les Pandawas, sans parler de notre déesse... Ne compte pas après ça obtenir le moindre renseignement sur le Dofus de Pandala... C\'est pour ça que tu es ici, non ?";
D.q[6287] = "Le Conseiller Boyowa ne vous a pas fait jeter en prison ? Je veux dire, tout s\'est bien passé avec le Conseiller Boyowa, vous lui avez bien livré la caisse de marchandises ?";
D.q[4394] = "Voyons...X... Xiron, Xylophone, Xéna la cordonnière, Xav... Tous ces noms ne me disent rien. \nXénondunepipe, X-or... ah, voilà, Xarthan ! C\'est un notable de Bonta et je pense que c\'est votre homme. Je ne vois aucun autre Bontarien sur ce registre.";
