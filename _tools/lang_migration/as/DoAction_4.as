D.q[7144] = "Tu reviens du temple ? J\'espère que tu en as profité pour le visiter de fond en comble, il y a tant à faire là-bas.";
D.q[1076] = "Rien à signaler monsieur !";
D.q[2529] = "C\'est pour une libation à la déesse ?";
D.q[4890] = "Alors, as-tu réussi à obtenir ce que je t\'ai demandé ?";
D.q[6155] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[5648] = "Salutations, le mal qui t\'accompagne est de plus en plus oppressant, je suis fier de toi ! \nQuelle est la raison de ta visite ?";
D.q[2963] = "<B> test </B> \n<I>test </I> \n<U>test </U>";
D.q[1953] = "Je suis le livreur de bière, aujourd\'hui j\'ai décidé de passer, alors je vais passer !";
D.q[3819] = "Pnj(884) et Message(3813)";
D.q[3437] = "Il faut que j\'aille faire un tour au marché. Les aventuriers vendent tellement de belles choses.";
D.q[3439] = "Tu joues avec moi ?";
D.q[1796] = "Si tu veux affronter un Dopeul, apporte moi une truite.";
D.q[5614] = "Salutations, la famille Terra a-t-elle accepté de nous aider ?";
D.q[6751] = "Tu n\'as rien à faire ici. Déguerpis tant qu\'il en est encore temps.";
D.q[6400] = "C\'est une recette de pain bwork ? J\'ignorais que les bworks savaient préparer du pain. Je suppose que le goût va avec le nom.";
D.q[4891] = "(Soudain, tout devient noir et vous tombez au sol. Attaquer Turorte n\'était peut-être pas une si bonne idée.)";
D.q[3863] = "vhjvb.";
D.q[2832] = "use later";
D.q[2097] = "Merci, je savais que je pouvais compter sur vous.";
D.q[2587] = "oOom Pandawa oOm - Chut ! Les paroles de la déesse ne vont pas tarder à affluer jusqu\'à mes tympans sacrés !";
D.q[2670] = "de rien. Que la déesse vous protège touri...aventurier !";
D.q[1165] = "Bon, voilà, tu l\'as, maintenant, ce satané papelard. \nJe peux retourner pioncer tranquille ?";
D.q[2162] = "Voila tu as reussi à remplir ta cruche c\'est bien ! Dégage maintenant !";
D.q[3713] = "Un jour je me lèverai du bon pied, et je partirai à l\'aventure.";
D.q[2910] = "OoOoMm Pandawa OoOoMm - (il prie)";
D.q[2672] = "OoOoMm Pandawa OoOoMm - (il prie)";
D.q[3633] = "Ici, tu n\'auras pas de kamas, mais je pourrai t\'apprendre quelques astuces qui te seront utiles plus tard.";
D.q[3825] = "Pnj(886) et Message(3823)";
D.q[2361] = "Holà, je t\'ai dit que ce n\'était pas un métier facile et tu veux quand même devenir chasseur ? Pour pouvoir manipuler les armes de chasseur il faut une certaine dextérité, prouve moi cette dextérité et j\'te nommerai chasseur.";
D.q[3754] = "Laisse-moi jeter un œil dans ce fatras.";
D.q[3108] = "Lors de sa dernière visite au port de Madrestam, le roi Allister a dit de moi que même les sirènes enviaient ma beauté.";
D.q[2646] = "Je pense que je vais vite devoir préparer un nouveau voyage initiatique.";
D.q[2326] = "HUmff ? gnark rhhhhr :";
D.q[1511] = "En es-tu sûr ? Refuser de parler avec moi signifie que tu te dresses contre l\'une des têtes de Brâkmar.";
D.q[2897] = "Je dois m\'occuper du passage de grade de nombreux adeptes, si tu veux retenter un passage, reviens me voir d\'ici deux heures au minimum !";
D.q[1148] = "Voilà, remet ceci à ton maître, il devrait être ravi. \nEt dis lui de surveiller ses arrières, certains de mes disciples ne le portent pas dans leur coeur, mouhaha !";
D.q[3082] = "Elle veut plus ? Ce n\'est pas une Enutrof pour rien. Voici encore 1000 Kamas. Reviens vite pour ta récompense.";
D.q[5710] = "Que je t\'explique la situation : je suis ton maître d\'ordre, par conséquent tu ne dois pas me déranger sans une bonne raison.";
D.q[2796] = "Hmm, je ressens chez toi l\'envie de fouler les terres maudites du labyrinthe, serais-tu assez fou pour envisager de soigner Dark Vlad ?";
D.q[3404] = "Krzzouiiittt ! scan... code non reconnu...";
D.q[2981] = "Entre la vieille outre à bière et l\'autre escroc qui cherchent des naïfs à plumer, pas facile d\'entendre le murmure de l\'avenir... Que veux-tu ? Laisse-moi deviner... Tu veux connaître ton destin !";
D.q[5606] = "Ce n\'est pas que je ne veux pas t\'aider, mais j\'approche de la retraite et une petite contrepartie en échange de l\'information serait la bienvenue.";
D.q[4171] = "C\'est parfait, grâce à ces objets améliorés je vais pouvoir voler beaucoup plus rapidement à dos de Scarafeuilles, sans les fatiguer inutilement avec le poids de mon équipement désuet.";
D.q[1093] = "Hmm, tu m\'as pas l\'air d\'être un bout en train toi. Tiens prends mon badge pour ton recensement.";
D.q[2600] = "Disciple, tu sembles avoir encore beaucoup de choses à apprendre sur les Pandawas. Que veux-tu savoir ?";
D.q[2860] = "Tu pourras sortir d\'ici 5 minutes, la prison est trop petite pour que nous gardions des êtres aussi misérable que toi indéfiniment...";
D.q[2727] = "On le dit. Ses chemins sont tortueux et les créatures qui la hantent sont peu amicales. Mais un certain Wally Elconom à réussi à en dresser la carte. Il serait utile que tu le rencontres. On le voit souvent du côté d\'Amakna.";
D.q[1096] = "Hmm, Tsog était un brillant soldat, il est mort en héros. Mais ce vieux fou a voulu être enterré dans le cimetière abandonné à l\'Est de Bonta...";
D.q[609] = "Regarde par exemple ce caleçon rose, il ne paye pas de mine. Pourtant, il s\'agit du caleçon magique du capitaine pirate, il porte chance en mer dit-on, je suis sûr de le revendre un bon prix.";
D.q[2801] = "... \nEmeraude est cette couleur...  \nRazeriane aime à contempler sa beauté dans la coquille si lisse du Dofus... \n...Pars maintenant...";
D.q[2622] = "Garouph \n<il coince un ballon sur son museau et commence à danser>";
D.q[2687] = "Par les pintes de la déesse ! Tu as besoin d\'un petit remontant ? J\'ai de quoi te contenter. Que souhaites-tu acheter ? \n";
D.q[5571] = "Salutations. La décomposition des dépouilles des renégats commencent à incommoder les geôliers. As-tu apporté les ingrédients nécessaires à leur résurrection ?";
D.q[2776] = "Ah je vois, si tu viens avec les recommandations d\'un maître de temple, je veux bien te laisser passer. \nMais uniquement cette fois ci !";
D.q[2778] = "HYAAAAAAAAAAAAAAAAK HAHAHA! Me rencontrer c\'est passer dans le royaume des ombres... hinhinhin... J\'écoute ta requête, ensuite je prendrai ton âme !";
D.q[5773] = "Te faire redevenir Neutre ne va pas être une mince affaire. Tout Amakna a entendu parler de toi, et c\'est peu dire. Il te faudra donc débourser 256000 Kamas si tu souhaites redevenir Neutre. \nPar contre, si tu souhaites rejoindre un alignement minoritaire, n\'oublie pas que je peux te faire changer d\'allégeance gratuitement.";
D.q[792] = "82";
D.q[801] = "91";
D.q[2523] = "Le Grandapan demande de porter ses prières à Pandawa, notre déesse bien-aimée ? C\'est une mission sacrée... Accompagne-moi !";
D.q[1518] = "Qu\'il en soit ainsi \nApporte cette lettre à Oto Mustam.";
D.q[1658] = "Je ressens une energie importante dans la salle du prisme, le territoire des Dopeuls est donc vulnérable aux attaques en ce moment.";
D.q[7592] = "Voyons, tu as dis que tu t\'appelais comment déjà ? Ah oui... Désolé, ton nom ne figure pas sur la liste des invités. En d\'autres termes, je n\'ai pas le droit de te laisser entrer. \n(l\'accès à ce lieu est réservé aux membres premium)";
D.q[5506] = "Burger Kimbo ! Riz Cola en sauce ! Joues d\'Ouginak ! Purée de cawottes ! \nHum hum... Vous voyez pas que je travaille ?";
D.q[355] = "C\'est dans les environs, j\'en suis sûr ! Je la retrouverai bien, cette satanée entrée de mine... C\'est pas loin, je le sens.";
D.q[901] = "91";
D.q[902] = "92";
D.q[561] = "Tout ça pour presque rien! Oui cher client, trois fois rien précisément. Le voyage ne coûte que 1000 kamas, cependant pour voyager dans les meilleures conditions nous vous demandons de vous munir d\'un casque et de vous équiper d\'une paire d\'ailes directrices. Revenez vite avec ces petits riens pour rapidement profiter de notre offre exceptionnelle, car elle ne sera pas éternelle...Et surtout, invitez vos amis, les vacances sont tellement plus drôles et plus passionnantes à plusieurs.";
D.q[2613] = "Toi être stupide, ça être pouvoir de sources Jus-Sang-Ki-Eau. Pouvoir transformer Poochan en chacha pour retrouver futur mari, mais poochan pas trouver. Toi vouloir aider moi ?";
D.q[4626] = "Eh bien, qu\'est-ce que tu attends ? Rends-toi sur l\'île de Moon et cherche des indices ! File !";
D.q[3784] = "Veux-tu retourner à ta statue ?";
D.q[5473] = "Môa venir de temps en temps, moâ aimer Parc. moâ aimer Parc et Pômmmes !... et blâgues aussi !";
D.q[2675] = "Que la mousse de la céleste chopine t\'étouffe, toi et tes descendants pour des siècles et des siècles ! On peut dire que tu commences bien dans la vie... En fait tu n\'as pas le choix !";
D.q[713] = "Tu vas peut-être pouvoir m\'aider à nouveau. Il paraît que Dame Cloude, la tenancière de la taverne de la Bagrutte, au nord-ouest de la ville, se fait harceler par un ivrogne ces temps-ci. Tu pourrais aller la voir et te renseigner sur ce qui s\'est passé ?";
D.q[2033] = "Tu vas peut-être pouvoir m\'aider... Quelque chose ne coule pas rond dans cette ville, mais si tu gardes ton sang froid, tout ira bien. Je sais qu\'il se passe de drôles de choses, dans les souterrains...";
D.q[2116] = "Alors, ca y est ? Tu crois que tu peux me toucher maintenant ? Alors vas-y FRAPPE MOI !";
D.q[6223] = "J\'ai travaillé pour Xephirès pendant trois ans avant de reprendre la bijouterie de ma mère. A l\'époque Xephirès débutait dans les affaires et ça n\'a pas toujours été évident ni pour lui ni pour moi.";
D.q[4180] = "Tu n\'as pas encore fini de chasser les créatures que je t\'ai demandées d\'anéantir, dépêche-toi si tu ne veux pas que je m\'enracine définitivement ici.";
D.q[2477] = "Tous ces bambous qui se fendillent, c\'est si triste... Sans ambre, on peut rien faire !";
D.q[1523] = "Qu\'il en soit ainsi... \nVa porter cette lettre à Oto Mustam. Et continue ton périple.";
D.q[584] = "Merci viande ! Toi pouvoir aller village, toi visiter et ensuite revenir ici pour être cuit ! Toi pas t\'éloigner trop !";
D.q[2121] = "Un complot ! La ville est menacée... population en danger... Hey ! Les roublards... fuyez !";
D.q[2242] = "*contemple une petite fleur de lin*  \nRegarde-moi cette beauté ! Ceci est un don de la nature, une pure merveille qu\'elle nous offre si délicatement. Prenons soin d\'elle et préservons-la.";
D.q[417] = "Si le coeur d\'Amakna est paisible, ses alentours le sont parfois nettement moins. \nLes créatures qui se promènent à la périphérie d\'Amakna ne sont pas agressives, il faut s\'en approcher de très près pour qu\'elles se mettent à vous attaquer. \nMais plus vous vous éloignez du centre d\'Amakna, plus les créatures sont agressives, et elles peuvent vous attaquer sans raison apparente. \nNe vous déplacez pas hors du village si vous n\'êtes pas accompagné d\'autres aventuriers, vous pourriez faire de mauvaises rencontres.";
D.q[6209] = "Si j\'étais toi j\'y réfléchirais à deux fois. De nombreux miliciens patrouillent ici et il me suffit de crier pour qu\'ils interviennent aussitôt. \nSi tu as envie de sensations fortes, pourquoi ne pas payer un coup à boire à l\'une de nos charmantes hôtesses ?";
D.q[1812] = "Si tu veux affronter un Dopeul, il faudra faire une donation d\'Orchidée Freyesque au temple...";
D.q[3532] = "Un disciple gobelin ? Pourquoi pas ! Je vais le former rapidement. De toute manière son cerveau ne devrait pas accepter beaucoup de sorts. ";
D.q[1800] = "Si tu veux affronter un Dopeul, je te conseille de te préparer. Alors ? prêt ?";
D.q[7553] = "Bonjour, je suis ravie de te voir. \nJ\'ai besoin de femmes débrouillardes dans ton genre pour m\'aider dans mes affaires. Je peux te proposer un travail simple et bien payé, mais tu devras te montrer discrète et ne pas poser de questions. \nQu\'en dis-tu ?";
D.q[2488] = "Te revoilà toi ? tu te souviens ? Il me faut cinq ambres !";
D.q[2484] = "Tu cherches de l\'Ambre par ici ? M\'est avis qu\'il te faut aller vers le Sud d\'Amakna pour en trouver, vers la forêt.";
D.q[6781] = "Je tape tellement vite que le frottement de mon poing avec l\'air génère de la chaleur et des flammes. C\'est physique, tu peux pas comprendre. Tu veux te battre ?";
D.q[4504] = "Tu penses qu\'une lettre de ma part pourrait convaincre ce Norb de nous aider ? Pas de problème, je te fais une lettre tout de suite. \nTiens, la voici.";
D.q[367] = "Salut ! Je m\'appelle Quincy Praïze. Je fabrique des oeufs-surprises avec mon père, Quin Praïze. On a besoin d\'ingrédients, donc si tu veux bien nous aider tu pourras avoir une belle récompense.";
D.q[624] = "Bonjour, comme vous le voyez je suis occupé. J\'étudie ces roches tachetées. Si vous pouviez donc ne pas trop faire de bruit cela gêne ma concentration.";
D.q[4544] = "Tu trouveras le commandant à l\'entrée du Cimetière des Torturés.";
D.q[623] = "Croyez-vous qu\'il suffit de parler pour pouvoir exercer ce métier ? C\'est que vous n\'avez pas bien compris l\'essence même du métier. Si vous souhaitez vraiment devenir alchimiste allez voir un confrère instructeur. Il doit être en train d\'étudier les pierres tachetées à trois lieues au Nord-Ouest du temple Kanojedo.";
D.q[2378] = "Etes vous sûr de vouloir débuter une carrière de sculpteur de Bâton ?";
D.q[3867] = "Pnj(893) et Message(3865)";
D.q[3135] = "Les Koalaks qui résistent à cet ensorcèlement, vivent reclus au fond de grottes, ou sont enfermés pour l\'éternité dans ce cimetière primitif, et seuls les êtres capables de se ressusciter peuvent s\'en échapper... \nMais passons, je suis enfermé à vie dans cet endroit lugubre, et ma dernière volonté, c\'est d\'avoir une apparence originale, je veux ressembler à mon idole, le Koulosse, et pour cela, il me faudrait sa panoplie et je pense que tu pourrais m\'aider si tu me ramenais sa panoplie complète.";
D.q[6150] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[5477] = "Quel rang souhaites-tu avoir au sein de la milice ?";
D.q[6476] = "Aïe, dur dur. C\'est Amayiro qui vous a confié cette mission suicide ?";
D.q[7541] = "Contre quels doplons souhaites-tu faire l\'échange ?";
D.q[859] = "49";
