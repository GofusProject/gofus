D.q[596] = "Le port du casque n\'est pas obligatoire dans les mines, cependant il est fortement conseillé. Il y a peu, j\'ai inventé un type de casque encore plus solide. Il faut juste 10 cuirs de Boufton Noir, 10 ficelles en Lin, et 5 laines de Bouftou, et bien sûr l\'aide d\'un bon tailleur.";
D.q[2921] = "J\'ai une mauvaise nouvelle : des Bontariens se sont ralliés à Brâkmar. Je n\'ai aucun chasseur de renégats sous la main donc si tu souhaites intégrer leurs rangs, ramène-moi la dépouille des renégats bontariens. J\'ignore où ils se trouvent exactement mais notre espion Bishom Pot en saura peut-être plus à leur sujet.";
D.q[3674] = "Vous pouvez dire à Disskray que tout va bien.";
D.q[2304] = "Kof ! Kof ! Kof ! *vieille toux maladive venant du fond du gosier*";
D.q[731] = "Une voyante m\'a révélé ce matin que le capitaine Tsog avait des informations de la plus haute importance à me révéler avant de mourir. \nTrouve un moyen de rentrer en communication avec lui au cimetière à l\'est de Bonta et ramène-moi ces derniers mots. \nDemande au Capitaine Alrok si tu veux plus d\'informations sur l\'emplacement de sa tombe.";
D.q[3583] = "Oui. Moâ vouloir devenir ange et voler pour Bonta.";
D.q[260] = "Oh ! merci mille fois ! Tenez, j\'ai trouvé ce parchemin magique au grenier lorsque j\'ai emménagé, je suis sûre qu\'il pourrait vous être utile.";
D.q[2298] = "Maow !";
D.q[985] = "Oh un visiteuw dans ma fowêt, tu es bien couwageux pour t\'aventuwer ici. \nJ\'ai un petit sewvice à te pwoposew, à mon âge il m\'est impossible de me wendwe sur l\'île des wabbits, mais j\'aimewais continuew mes wechewches sur cette wace. \n";
D.q[1677] = "VENEZ ÉVACUER VOTRE STRESS TOUT EN VOUS AMUSANT GRACE A NOS PETITES BÊTES JAUNES FAVORITES !  \nBonjour, je lis dans vos yeux que vous avez besoin de vous défouler, de relâcher la pression de la routine zaapo, crafto, dodo. Et bien n\'allez pas plus loin, je vous propose de le faire et en plus vous avez gros à gagner ! Seulement 20 Kamas pour tout ça !";
D.q[6544] = "Tu as le sens du jeu et le goût du risque, tu ne vis pas à Brâkmar pour rien.";
D.q[5464] = "Ah, Toâ pas connaître cousin moâ ? Lui être Ronan le Barbare. Lui se balader près de Brâkmar.";
D.q[6603] = "Tu es décidément pleine de talents, je comprends pourquoi Amayiro t\'estime autant. En attendant que l\'enchantement fasse effet, retourne auprès de lui. Tu reviendras me voir dès que la poupée sera prête. Tant que j\'y pense, prends cette bourse de Kamas, toute personne se mettant au service de l\'intendant de son plein gré est toujours récompensée. Si tu continues à bien me servir, il y a de fortes chances pour que ta progression au sein de la milice soit plus rapide, ne l\'oublie pas. Jiva apprécie les femmes dévouées corps et âme à sa cause.";
D.q[4162] = "Je parie que c\'est mon mari qui vous envoie me chercher ! \nC\'est un vaurien, un gentil vaurien, mais un vaurien ! \nIl accorde plus d\'importances à ses recherches sur les monstres qu\'à notre couple, il ne sait plus me séduire, ni partager ce qu\'un couple doit partager. \nEt pourtant je sais qu\'il m\'aime, j\'entends d\'ici son coeur battre la chamade, mais il ne sait pas communiquer sa passion avec des gestes ou même simplement des mots ou des regards.";
D.q[6612] = "C\'est la fillette bontarienne à qui nous avons donné la fessée, non ?";
D.q[4018] = "Voilà donc mes gens, malgwé leuw tête bizawwe, ils suffiwont. Hum, je vais encowe un peu me pwomener dans cette belle contwée avant d\'aller au château.";
D.q[2761] = "Je dois m\'occuper du passage de grade de nombreux adeptes, si tu veux retenter un passage, reviens me voir d\'ici une heure au minimum !";
D.q[6550] = "Félicitations, en défaisant les Brâkmariens nous avons déjoué leur plan. Ce qui m\'inquiète par contre c\'est la qualité de leur équipement. D\'après tes dires, leurs miliciens seraient mieux équipés que les nôtres ? C\'est inadmissible ! Ne sommes-nous pas la plus puissante cité du Monde des douze ? \nVoici 2000 Kamas pour ton exploit. Maintenant tu peux disposer, j\'en toucherai deux mots à Amayiro.";
D.q[1199] = "Bien, tu souhaites donc continuer sous ma tutelle, au sein de l\'Ordre du Coeur Vaillant. Choix judicieux que tu ne devrais pas regretter. \nToutefois, pour valider ton adhésion, il te faudra retrouver le greffier de l\'Ordre. Depuis que son chat de compagnie l\'a quitté, il écume les tavernes. Ramène-le ici et nous confirmerons ta demande.";
D.q[2312] = "Ugh! Tu n\'m\'as pas l\'air très costaud toi... T\'es sûr que tu manges assez ?! J\'te propose un p\'tit job, histoire de t\'remplir un peu les poches, et surtout l\'estomac héhé!...";
D.q[3011] = "Va voir Zeurg, dans le temple d\'Osamodas, il a des moeurs étranges... Mais il possède des parchemins de Sagesse, ce qui est plus étrange encore !";
D.q[2901] = "Je dois m\'occuper du passage de grade de nombreux adeptes, si tu veux retenter un passage, reviens me voir d\'ici six heures au minimum !";
D.q[3165] = "Qui me parle ? \nApproche, je ne te vois pas !";
D.q[2241] = "Mon vieux ! Regarde-moi ce minerai... \n*tend une pierre difforme ressemblant étrangement à du minerai de fer* \nÇa doit valoir une petite fortune, non ?";
D.q[6468] = "Cette fois je vous donnerai plus de fil à retordre.";
D.q[7602] = "Passe ton chemin, cloporte.";
D.q[4379] = "Ne restez pas ici. Retournez voir votre chef.";
D.q[3827] = "Je me souviens de toi, tu es déjà passé par là et tu as survécu n\'est-ce pas ? Je n\'ai plus rien pour toi, je garde ça pour les novices qui n\'ont pas encore fait leurs preuves.";
D.q[2713] = "... Et tous ces aventuriers qui infestent notre île seront bientôt malades de la Pandrista !... Mais ? Nous avons de la visite ?! Une nouvelle recrue Pandikaze on dirait ?";
D.q[2648] = "Pourquoi ma fille a ce caractère si spécial, je n\'arriverai jamais à la marier.";
D.q[2087] = "Ah ces Enutrofs ! Tu sais que nous les aidons dans leurs recherches ? Hé bien nous voilà embêtés : à force de traîner dans les souterrains, ils tombent malades, les Enutrofs. Et à qui ils refilent leurs germes ?! A nos Tofus pardi ! Et le rhume d\'Enutrof, je ne sais pas comment ça se soigne, moi... Mes pauvres Tofus... Heureusement qu\'il y a les Eniripsas...";
D.q[384] = "Bonjour. Je me nomme Heûl Leise, et voici mon fils adoptif Max. Je rêve d\'aventure et j\'ai voulu partir pour une longue odyssée, mais mon Max m\'a retenu lorsque j\'ai essayé de me mettre en route. " + "\"" + "Père ! Heûl Leise ! Reviens !" + "\"" + " Criait-il. \nTel est Max. Ca m\'a fendu le coeur, alors je suis resté. \nJe n\'ai donc plus besoin de mes Grands Parchemins de Force. \nJe les échange à qui en veut.";
D.q[6733] = "Que me voulez-vous encore, vous n\'en avez pas assez de me harceler ?";
D.q[7520] = "Contre quels doplons souhaites-tu faire l\'échange ?";
D.q[5631] = "Je prie la déesse Eniripsa pour qu\'elle m\'accorde ses grâces. Comme ça, je peux soigner mes amis et castagner mes ennemis. Je peux aussi faire l\'inverse, et c\'est ça qui est rigolo.";
D.q[738] = "Mon ami Rimaraf est décédé cette nuit dans des circonstances étranges, il a été empoisonné avec un Blopisier au scorbute. \nJ\'aimerais que tu enquêtes et que tu me trouves le coupable ! ";
D.q[7054] = "Très bien, maintenant quelle gemme désires-tu ?";
D.q[3719] = "Merci pour les nymphettes.";
D.q[6343] = "Ca c\'est déjà plus intelligent comme question. L\'incompétent de Latem Sa travaille pour Bonta mais je te l\'ai déjà dit. Peut-être que d\'autres forgerons ont parfois des commandes pour la cité, tu devrais te renseigner au village d\'Amakna.";
D.q[3341] = "Salut ! Bienvenue sur le serveur de test. \n \nQu\'est-ce que je peux faire pour toi?";
D.q[3264] = "Oui, avant j\'étais maîtresse... d\'école.  \nIl y a des habitudes qui restent... \nTu sais où est mon fils ?";
D.q[2079] = "Alors ça ! Nous aidons les Enutrofs dans leur recherches et tout ce que nous récoltons, ce sont des animaux malades. Et quelles maladies ! Genre qu\'on ne puisse soigner nous-même ! Heureusement, qu\'il y a les Eniripsas...";
D.q[4386] = "Pas d\'attaque ? Alors je n\'ai plus de doute. Quelqu\'un de haut placé ici renseigne les bandits. Nous avons quelqu\'un de corrompu dans nos rangs, c\'est certain. Il accepte probablement des pots-de-vin pour divulguer des renseignements secrets, et pour faire stopper nos enquêtes. Ça expliquerait également la réticence du conseil à mettre un terme aux agissements de ces bandits.";
D.q[4003] = "Moi, cuisiner pour un Wabbit ? Il ne mangent que des cawottes crues ! Aucun intérêt. Il va falloir me motiver plus que ça.";
D.q[2031] = "Vous êtes plutôt rapide, c\'est une bonne chose. Mais ce qui compte c\'est la force que vous mettrez dans vos attaques, et le courage d\'aller au bout de vos convictions. Et, par dessus tout, rester juste... Ce sont les maîtres mots de notre maison, ne l\'oubliez pas. Maintenant, donnez moi votre épée, pour que j\'y appose la marque qui scellera votre destin... *Rok utilise divers outils mais n\'a pas l\'air très habile de ses dix doigts si ce n\'est avec une epée*... Voilà, c\'est terminé !";
D.q[6583] = "Ah lui ? En fait c\'est la première fois que je le vois. Il voulait savoir si je travaillais pour Bonta mais je lui ai répondu que non. Par contre je lui ai dit que c\'était le cas de Nara, j\'ai bien fait ?";
D.q[3612] = "La belle Gobrose, esclave de Bworkcine. Peux-tu la libérer ?";
D.q[962] = "Les quartiers de Bonta sont découpés en fonction des activités exercées par les différents artisans. Vous pouvez reconnaître l\'activité principale d\'un quartier par les ornements sur les façades des maisons et aussi par les mats dont les armoiries correspondent au corps de métier.";
D.q[2099] = "Oula...toi tu commences mal ! *elle se met à crier* Papa, Papa ! ";
D.q[3021] = "Bien, si tu reviens me voir, c\'est que tu as trouvé le signe dont nous avons parlé.";
D.q[4229] = "Ce que vous voyez là, nous avons pu le faire grâce à nos expériences sur les éléments. Nous savons désormais comment fabriquer de la glace, et garder des microclimats nous permettant de faire évoluer la bactérie d\'Otomaï. Pour le meilleur. Et pour le pire.";
D.q[447] = "Pour cela, il y a les parchemins, je suppose que vous ne parliez pas d\'entraînement. Je peux vous échanger 100 Défenses de Sanglier contre un Petit Parchemin de Vitalité si vous le voulez.";
D.q[1842] = "Miaaaoow ! \n*ce chacha semble bien triste*";
D.q[6210] = "Si j\'étais toi j\'y réfléchirais à deux fois. De nombreux miliciens patrouillent ici et il me suffit de crier pour qu\'ils interviennent aussitôt. \nSi tu as envie de sensations fortes, pourquoi ne pas travailler ici ? Certains gaillards apprécient les femmes à forte personnalité dans ton genre.";
D.q[6227] = "Humph. Un tavernier, c\'est censé tout connaître sur tout. Quelle bande de minables... Heureusement pour toi tu as obtenu quelques informations intéressantes sur ce Xephirès, ça nous sera peut-être utile. \nJ\'ai une autre mission à te confier sur ce Xephirès. Figure-toi qu\'un de tes collègues a trouvé un Sram qui connaît personnellement Xephirès pour avoir été en affaire avec lui à plusieurs reprises. Mais comme cet idiot de milicien n\'a pas amené le Sram avec lui, je l\'ai fait châtier un peu trop fort et il ne peut plus se déplacer. C\'est donc toi qui va te charger de trouver ce Sram dans la forêt des Abraknydes et m\'apporter les informations qu\'il détient.";
D.q[6752] = "J\'aime pas les individus dans ton genre, ça m\'énerve. Et quand je suis énervé j\'ai envie de casser ce que j\'aime pas, tu piges ?";
D.q[2381] = "Holà, on ne devient pas un forgeron comme moi tout de suite. Tu dois choisir quelles armes tu décides de forger. Rien ne t\'empêche d\'en prendre plusieurs, mais cela va te prendre forcément une partie de ton temps.";
D.q[1907] = "Merci beaucoup, pourriez-vous me rendre un autre petit service dans la foulée ? J\'ai eu vent que mon livreur n\'était pas malade du tout... Il préfère courir les filles que de livrer mes commandes. J\'aimerais que vous puissiez le surveiller pour voir si cela est vrai...";
D.q[3634] = "Persévère, tu peux y arriver. Si tu veux une arme, va voir Anta Brok au sud d\'ici, elle a toujours un tas de chose à échanger.";
D.q[3386] = "D\'bien beaux combats, pour sur ! Moi j\'ai plus rien à t\'donner. Bon vent à toi.";
D.q[4494] = "Aïe. Je crains que cette défaite n\'incite les Brâkmariens à passer à l\'offensive. Il faut impérativement trouver une solution. Tu n\'as pas à t\'accabler de reproches, l\'équipement de nos ennemis a fait la différence.";
D.q[1227] = "Je n\'ai jamais vu un sang aussi génétiquement modifié. \nEn tout cas voici son analyse comme tu me l\'as demandé.";
D.q[1418] = "Parfait, je vais pouvoir reprendre la séance de torture avec Trof Hapyus.";
D.q[589] = "Si vous traînez trop, vous pourriez finir en civet. Une nourriture aussi habile que vous est certainement dure à mâcher et à digérer. Je ne veux pas imposer ça à mes adorateurs. Surtout que la viande plus tendre abonde en ce moment. Si vous le voulez, je peux vous aider à quitter ce village rapidement. Dans tous les cas, Adieu !";
D.q[4265] = "Alors ? As-tu trouvé quelque chose d\'intéressant ?";
D.q[2012] = "Ahlala ! J\'enrage ! Ces fichus Ecaflips ont encore gagné leur pari ! Mais je ne vais pas me laisser avoir une fois de plus par leur indécente chance au jeu. Et tu vas m\'aider, en échange de quoi je t\'enseignerai de puissants sortilèges !";
D.q[2911] = "Tu as déshonoré ta cité en manquant de loyauté durant tes combats. Ton compte bancaire restera donc bloqué jusqu\'à ce que tu rattrapes tes mauvaises actions.";
D.q[4642] = "Mettez-vous en slip, je veux être sûr que vous ne cachez pas d\'arme de destruction massive sous vos vêtements.";
D.q[2348] = "Croyez-vous qu\'il suffit de parler pour pouvoir exercer ce métier ? C\'est que vous n\'avez pas bien compris l\'essence même du métier. Si vous souhaitez vraiment devenir alchimiste, allez voir le chef des instructeurs en Amakna, je vous indique sa position sur votre carte si vous le désirez.";
D.q[4471] = "Au fond d\'une grotte au sud-ouest, dans le territoire Porcos. Je vous préviens, c\'est un particulier et il a une... légère... tendance à la paranoïa. Je ne sais pas s\'il acceptera de vous parler. \nMais au fait, qui êtes-vous ? Et pourquoi me demandez-vous cela ?";
D.q[2606] = "Très bien, reviens me voir si tu trouves quelque chose... Adieu, en somme!";
D.q[2080] = "Désolé mais je suis un Crâ très occupé. Je n\'ai pas le temps de faire connaissance.";
D.q[3663] = "Ne t\'inquiète pas pour ça, il t\'en faut juste un peu. Tu en trouveras sur les créatures que tu as battu. Plus tu vas loin, et plus il t\'en faut. Veux-tu connaître l\'histoire de l\'origine de ces portes magiques ?";
D.q[2421] = "Ce métier consiste à couper des arbres bien évidemment. Le bois ainsi récolté sert dans de nombreuses recettes de métiers d\'artisans, du sculpteur comme matière première à leurs bâtons, baguettes ou arcs, au forgeron comme matière secondaire pour ses manches d\'armes. Les applications sont diverses et la demande est grande. Les arbres sont cependant longs à couper et certains assez rares.";
D.q[5116] = "Bonjour, je suis très occupé pour l\'instant. Je suis en train de travailler sur une potion d\'invincibilité. Si on me dérange sans arrêt je ne pourrai jamais y arriver.";
D.q[4155] = "Alors avez-vous trouvé mon petit wabbit ? Comment va-t-il ?";
D.q[3089] = "Je n\'ai point besoin de cela pour plaire à mon roi. Pour le ravir, il me suffit de pointer mon beau minois. Trouve quelqu\'un d\'autre qui n\'a pas mon charisme félin.";
D.q[3695] = "Un bon récolteur fait attention à son inventaire. Il faut toujours avoir de la place pour entasser ses récoltes.";
D.q[6560] = "Mes armes sont destinées à pourfendre des monstres et mes armures à se protéger des mêmes monstres. Je ne fabrique pas d\'équipement pour que des hommes s\'étripent les uns les autres. J\'ai connu un forgeron qui avait moins de scrupules, mais il s\'est évanoui dans la nature il y a des années et nul ne l\'a revu depuis, sauf peut-être Norb. Tu ne connais pas Norb ? C\'est le forgeron qui a repris récemment la forge dans la Plaine des Scarafeuilles.";
D.q[3717] = "Lorsque tu partiras pour le grand monde, tu devras te nourrir pour te soigner. Les nymphes ne peuvent plus rien pour toi. Tu es trop puissant maintenant.";
D.q[4354] = "Des voyageurs Ecaflips ? Pas eu de ça dans ma taverne ces derniers temps, non.";
D.q[3515] = "Il manque une chose, c\'est un peu délicat, mais je crois que c\'est nécessaire, voire vital en fait !";
D.q[3204] = "Ah ! Je suis persuadé que tu veux rentrer dans ce labyrinthe et savoir quels trésors il renferme ! Je sais quelles créatures s\'y cachent, puisque je suis un des meilleurs archéologues de cette vaste île. Certains racontent que c\'est parce que je suis le seul, mais ce n\'est pas entièrement vrai ! Si je suis le seul, c\'est parce que les autres se sont perdus dans ce labyrinthe tellement ils étaient mauvais. Hahaha. Bon que veux-tu savoir ?";
D.q[2894] = "qu\'est ce que tu fais ici ? allez prend la clef et fuis vite fait";
D.q[915] = "Merci #1, toujours aussi serviable. Je vais pouvoir entraîner mes gars sérieusement.";
D.q[4499] = "On vous a parlé de lui ? Ecoutez, je n\'ai aucune envie d\'être mêlé à vos histoires ni d\'impliquer un ami là-dedans. Je sais que Bonta veut protéger le monde de l\'influence néfaste de Brâkmar, mais je ne suis pas convaincu pour autant qu\'il faille vous aider.";
D.q[3105] = "Il ne me manque plus que mon être cher. Un familier doux et ronronnant fera l\'affaire. Je veux un Chacha tout blanc comme moi. Trouve-m\'en six que je choisisse le plus blanc.";
D.q[3161] = "Approche, approche si tu n\'as pas peur ! Viens me voir en face, que je puisse lire la peur dans ton regard !";
D.q[4120] = "Quelle est la couleur de la Dragodinde blanche d\'Henry Kard ?";
D.q[3747] = "Qu\'est ce qui se passe, tu n\'arrives pas à fabriquer quelque chose ? Tu as besoin d\'aide ?";
D.q[4019] = "Ah, te wevoilà, gentil écuyer ! Je voulais te dem...";
D.q[2988] = "Pnj(729) et Message(2987)";
D.q[4523] = "Achetez ma bière, la seule qui transforme n\'importe quel pleutre en un vaillant chevalier ! \nEfficacité non garantie.";
D.q[4115] = "Quelle est ta couleur préférée ?";
D.q[7625] = "Soit vous n\'avez pas le courage de continuer, soit vos amis vous ont abandonné. Je peux vous faire sortir d\'ici si vous le souhaitez.";
D.q[6339] = "Quoi, que signifie... Je vois, tu te crois malin pas vrai ? Prends donc ce Croc Gland fraîchement dompté avec toi, nous verrons si la méthode d\'élevage canin est aussi efficace que le prétend Riyou Tchevlakouk. Je vais t\'indiquer où a eu lieu l\'embuscade, dépêche-toi d\'y aller et de revenir me faire un rapport.";
D.q[3887] = "Ouisshhh, vous désssirez parler à Vil Smissshe. Sssh\'est d\'accord. Ssshuivez-moi, ssshhh.";
D.q[1385] = "Tik nik triviris pis tijirs lik ripinsik dik tinik dictinnirik, riflichik ink pik ii lik fiçinik dik nirrik ink nikirik...";
D.q[816] = "Maintenant qu\'il a retrouvé des dents, Mak veut prendre sa revanche, il est toujours aussi têtu, enfin bref, avec ses nouvelles dents et son équipement flambant neuf il compte bien te mettre une dérouillée ! Accepte, je veux voir tes progrès depuis ton dernier combat.";
D.q[2710] = "YohOohHhOo Pandawa, bénis mes boucliers steuplait ! Mmmh ? Ah, je ne t\'avais pas vu ! Je peux t\'aider ?";
D.q[2597] = "Ta route a été longue, disciple, mais tu es sur la bonne voie : celle qui mène à la forêt maléfique... Avant de t\'y aventurer, tu devrais discuter avec notre dresseur de Dopeuls. Si tu le peux, fais toi la main sur l\'une de ses bestioles: rien de tel pour améliorer tes techniques de combat ! Tu risques d\'en avoir besoin une fois là-bas : on dit que cette forêt est oubliée des dieux...";
D.q[860] = "Ah ces corbacs frits! Vraiment infâme. Cette Sbab ne sait vraiment pas cuisinier. Tu vas lui donner une petite leçon tiens. Sbab adore les Wabbit, tu as dû le remarquer. Elle craque particulièrement pour les oreilles des Tiwabbits qu\'elle trouve " + "\"" + "adorables" + "\"" + ". Rapporte-lui en une dizaine de paires accompagné de cette petite lettre ça lui fera très plaisir hinhin !";
D.q[1588] = "Qu\'il en soit ainsi.";
D.q[1139] = "Rapide, efficace, silencieux, autant d\'adjectifs qui ne te correspondent pas.\n#1, tu as vu le temps que tu as mis pour me ramener de la bouillie ?\nEnfin de toute façon je viens d\'apprendre que son satané tabi était immunisé aux poisons communs. Seul un magique ferait l\'affaire.";
D.q[4161] = "La dernière fois que je l\'ai aperçue, elle s\'enfuyait vers ce village. J\'ai voulu la rattraper, mais elle était vraiment trop déterminée. \nJe pense que vous pourriez la retrouver pour moi, et m\'expliquer pourquoi elle est partie. \nMais attention, vous devrez sûrement affronter les créatures de ce village pour la retrouver.";
D.q[4357] = "Des Ecaflips récemment ? Oui, j\'en ai eu un. Il a passé la nuit à boire et à jouer, au petit matin il avait plus un rond et je crois que la garde l\'a embarqué pour je sais plus quelle raison. Ça peut vous aider ?";
D.q[1183] = "Hum, mais quelle est cette mauvaise odeur ? Ce n\'est pourtant pas mes poissons qui sentent comme ça...Ah, bonjour, que voulez-vous ?";
D.q[3589] = "Que sais-tu faire ? couper du bois ? C\'est bien ça. Bon j\'ai besoin de pas mal de planches pour réparer le toit de la grange ou renforcer les enclos. Va abattre quelques bons plans d\'arbres dans la forêt.";
D.q[3294] = "Snirk ! \nCouic snot snot gurlube couic ? \nCouic snif kriss trok couic ! \n \n";
D.q[6707] = "Excellent, ta débrouillardise est exceptionnelle. Va voir Liroye Merline, elle pourra peut-être te faire des copies de cette clef, ça te permettra d\'infiltrer le repaire des bandits avec d\'autres compagnons.";
D.q[4467] = "Hein ? Un simple milicien de Bonta, mais avec un équipement spécial ? \nHmm, c\'est inquiétant. Bonta aurait-elle trouvé un moyen pour mieux équiper ses soldats ? \nQue tu n\'aies pas réussi à le vaincre va encore nous faire passer pour des guignols aux yeux de nos ennemis, tu me déçois vraiment sur ce coup. J\'espère au moins dans ton intérêt que tu n\'as pas pris la fuite sinon ce serait encore pire. \nAu sujet du croc gland, est-il efficace au moins ? Puisqu\'on en parle, j\'ai besoin de le récupérer. Bout d\'chair le boucher m\'en propose un très bon prix.";
D.q[35] = "Bonjour à toi étranger.  \nJe suis une Bijoutière incontournable d\'Amakna, tout le monde s\'arrache mes nouvelles créations. \nEn conséquence, je suis un peu débordée ces derniers temps ; si vous cherchez du travail, je peux vous en donner.";
D.q[7508] = "Je dispose de deux pouvoirs pour transformer tes caractéristiques, veux-tu en savoir plus ?";
D.q[7081] = "Depuis quelques temps, nous ouvrons les portes de notre temple aux représentants des autres divinités.";
D.q[2763] = "Jadis, il n\'était pas rare que les anciens Pandawas offrent de généreuses libations à leur déesse, Pandawa la bien-nommée.  \nAu terme des cérémonies certains Pandawas entraient dans une sorte de transe dûe aux vapeurs capiteuses du bambou fermenté... puis s\'effondraient lourdement. Dans un élan fraternel, les fidèles n\'hésitaient pas à porter les plus titubants d\'entre eux jusqu\'à leurs chaumières. C\'est ici que l\'histoire rejoint la légende : on ne sait pas trop s\'ils étaient assaillis par des hallucinations d\'ivrognes ou par les créatures malfaisantes des environs, mais les Pandawas livraient toujours combat sur le chemin du retour ! Gesticulations et baffes données à l\'aveuglette sont donc à l\'origine des techniques d\'autodéfense des Pandawas.";
D.q[4259] = "Avec ce bâton, je vais pouvoir te sculpter un manche de faux particulièrement efficace. Il ne me restera plus qu\'à démonter la lame de ton épée.";
D.q[1963] = "Très bien ! Alors tu vas retrouver un de mes agents, il doit se trouver quelque part dans l\'ombre de ces Enutrofs. Il devrait avoir pour moi des informations primordiales. Je t\'ai indiqué le chemin. Tu n\'as qu\'à suivre ta boussole.";
D.q[2540] = "Bonjoul ! Soil le bienvenul dans ma demeule, noble étlanger. Tu as l\'oeil scintillant comme l\'astle de la nuit... et l\'amulette de Fleurawa : c\'est notre signe de reconnaissance. Que puis-je poul toi ?";
D.q[1700] = "Voilà votre lot, à bientôt.";
D.q[6306] = "Je puis jeûner pendant trois siècles et ne pas ressentir les affres de la faim.";
D.q[3216] = "Salut l\'aventurier, comment vas-tu ? Tu veux une Greuvette ? \nNe réponds pas, en fait je m\'en fiche. \nBon, je suis certain que tu cherches à rentrer dans ce labyrinthe, mais je sens que tu n\'y connais rien ! Tu dois posséder une clef pour espérer rentrer, et ne compte pas sur moi pour t\'en offrir une, en général, je les vole aux aventuriers comme toi. \n";
D.q[1263] = "Mais tu n\'as même pas 1000 Kamas ! Reviens me voir quand tu seras plus riche. C\'est 1000 ou rien.";
D.q[3545] = "Salut, tu es venu seul, jeune Osamodas ? Etrange, tes semblables se promènent souvent avec quantité de créatures qu\'ils invoquent et contrôlent. Peu importe, ça ira pour ce que je vais te demander. Enfin, pense à invoquer quelques petites bestioles quand même.";
D.q[1310] = "Hey ! Tous les chèques ne sont pas là ! Tu essaies de me rouler ou quoi ?";
D.q[2202] = "De rien... Tu devrais aller voir Enileda, elle te sculptera l\'arc qu\'il te faut.";
D.q[3948] = "Oh, un Wabbit, Soyez le bienvenu dans nos murs, noble pwince!";
D.q[559] = "Enfin, je vous invite à visiter l\'Ouest de l\'île. La jungle féerique vous y attend, sa flore luxuriante et sa faune étrange vous captiveront un long moment. Avec un peu de chance, vous rencontrerez les habitants de l\'île, découvrirez leur folklore très riche, et serez probablement invité à leur table. Si vous avez le temps, tentez de courir au Sud de l\'île où vous aurez sans doute le privilège ultime de rencontrer le Chef de l\'île de Moon.";
D.q[1237] = "Bonjour à vous. Je vous prie de m\'excuser pour les grands mouvements dangereux que je fais. C\'est mon entraînement quotidien vous savez.";
D.q[597] = "Oh comment le savez-vous ? Oui j\'ai déjà volé, j\'ai sauté du haut de ma maison et j\'ai plané sur au moins 5 mètres. Le plus dur était de fabriquer mes ailes en bois...Mon oncle bûcheron et son ami tailleur les ont faites pour moi, je crois qu\'ils ont utilisé 4 planches de frêne et 10 ficelles de lin pour les confectionner.";
D.q[3505] = "Seul, je suis désespérément seul au milieu des brutes et des chasseurs de brutes.";
D.q[1046] = "Tu n\'y vas pas par quatre chemins l\'ami, tu as besoin de quelle quantité de poudre, dis-moi ?";
D.q[1051] = "Naaaa peu pat porlé toa, té tro maichan ! Pi ja la bouk tou seuc dfasson.";
D.q[1042] = "*Cliquetis* *Quetis,Cliquetis* *Cliquetis*-*Cliquecliquetis*, *Clicliquetis*";
D.q[3183] = "Le Maître Corbac se promène dans les différentes salles de cette bibliothèque. Heureusement pour toi, je t\'accompagnerai dans chaque salle, pour t\'indiquer où se situe le Maître Corbac. N\'hésite pas à me le demander dès que tu te sentiras perdu.";
D.q[3400] = "Votre mission est un succès. Bzzztt... Votre nouvelle mi... bzttt krouik ! Frtrtttt";
D.q[3469] = "Bworks veulent nourrir snif snif Trooll avec Raxitik. Moâ pas snif snif vouloir, moâ avoir 19 minigobs à nourrir snif...";
D.q[3146] = "Que Rushu te brûle ce qu\'il te reste de conscience ! Comment as-tu osé t\'attaquer à de si jeunes et frêles Sadidettes ! \nTu as même osé casser mon boomerang, je vais devoir attendre mon prochain anniversaire, pour que notre Maître Skeunk, m\'en offre un nouveau ! \nHors de ma vue, bourreau d\'enfant ! \n";
D.q[3562] = "Cé moâ le chef des Bworks ! Toâ donner kdô, moâ chef !";
D.q[3610] = "Pfff... T\'es encore plus faible que moâ ! Passe ton chemin.";
D.q[3613] = "Gobrose enfermée sous campement Bwork.";
D.q[1902] = "Hé toi jeune Féca ! Arrête de rêvasser !... on dirait que tu viens de tomber du ciel ! J\'aurais bien besoin d\'un coup de main...";
D.q[1560] = "Moo oom foond\'om morocl\'om sqoorrol\'om nord\'om ost\'om oxtorom bontom moo oom.";
D.q[3401] = "Votre mission est un succès. Bzzztt... Votre nouvelle mi... bzttt krouik ! Frtrtttt";
D.q[3200] = "Es-tu certain de vouloir rentrer dans cette bibliothèque labyrinthique ? As-tu une invitation du Maître Corbac ou une clef de sa bibliothèque ? J\'espère qu\'il est disposé à te recevoir, il n\'apprécie guère être dérangé durant ses lectures.";
D.q[6240] = "Ca va j\'ai compris, je ne te pose plus de question. \n... \nT\'aurais pas un Kama ? Aller, juste un Kama, c\'est rien pour toi un Kama.";
D.q[820] = "Ton travail me satisfait pleinement que veux-tu d\'autre ?";
D.q[836] = "Bon #1, je vais te faire passer un petit test sur l\'art de la fourberie, voir si tu mérites d\'être mon disciple.";
D.q[2694] = "Oyahoh ! Les amis de mes amis sont mes amis ! Et comme les Pandawas sont tous mes amis, t\'es forcément un ami !";
D.q[6239] = "C\'est bon, c\'est bon, j\'ai compris, je me tais. Vous autres Brâkmariens vous êtes vraiment spéciaux. Par moment tu me rappelles mon oncle Jack qui a fini désossé par un Croc Gland.";
D.q[3423] = "Pnj(809) et Message(3350)";
D.q[1085] = "Humm, c\'est bien. Mais quelque chose me dit qu\'il en manque. Cherchez mieux !";
D.q[3573] = "Un vaillant guerrier, voilà ce qu\'il me faut. Il faut débarrasser la région des créatures qui l\'infestent. Je l\'aurais bien fait moi-même mais j\'ai tout plein de choses à faire. Tu sais, des trucs quoi, et puis d\'autres ici, plein ...";
D.q[2215] = "A l\'aide ! L\'a bouffé mes Tofus ranifftous ! Il en veut à not\' peau !";
D.q[4034] = "Ah, merci, voilà les ingrédients. Attends un peu, je fais chauffer, je touille dans ce sens, puis dans l\'autre, et voilà ta potion!";
D.q[3588] = "Bonjour, je n\'ai pas vraiment le temps de discuter, si vous voulez quelque chose, allez voir mon contremaître.";
D.q[3053] = "Notre bon roi Allister a besoin de steaks de Dragodinde bien saignants pour sa table. Peux tu m\'en fournir ?";
D.q[2820] = "Hum, tu n\'as pas payé la taxe... je ne peux te parler...";
D.q[843] = "Les Bontariens sont vraiment trop calmes. Cela cache quelque chose. Un de nos espions a infiltré Bonta, il s\'appelle Trojen Tihpor. Il doit être actuellement de garde autour des remparts dans la cité. Va le voir discrètement et rapporte-moi un rapport des activités bontariennes.";
D.q[842] = "Les Bontariens sont bien calmes en ce moment. Il ne se passe plus grand chose à vrai dire. Tu peux en profiter pour te reposer.";
D.q[1707] = "Le temple Eniripsa se trouve à l\'Est du village d\'Amakna, adresse toi à Limine Bryone pour commencer ta formation.";
D.q[2751] = "Le Shaman me semble être quelqu\'un de compétent en matière de certificat. Va le trouver.";
D.q[4236] = "Nourrie tous les jours d\'une haine féroce pour ses geôliers, après avoir obtenu l\'immunité pendant si longtemps, la créature s\'est évadée. D\'elle, il ne reste rien, ou si peu, quelques poils de dos. Qui sait quels dégâts elle commettra demain.";
D.q[5376] = "Je ne serai pas retenu prisonnier longtemps. Mes frères brâkmariens me libèreront !";
D.q[2780] = "Dès que tu as fini ton entrainement, viens me voir, je t\'attends en dehors du Dojo. ";
D.q[1149] = "Bienvenue à la taverne du Alakarte. Si vous voulez une boisson, vous n\'avez qu\'à demander la carte...";
D.q[6408] = "Je n\'y connais rien, je n\'avais jamais cuisiné avant d\'être capturée par Brâkmar. Vous feriez mieux d\'interroger Bout d\'chair, à l\'atelier des bouchers de la cité.";
D.q[2230] = "Merci mon chou, tu es un peu en retard, mon précieux goûter a perdu un peu de sa fraîcheur. Je suis obliiigé de réduire un peu le coût de livraison.";
D.q[3530] = "Voici des Kamas, je vais le fourrer avec le gâtrooll et le cuire dans la gratrooll avant de le dévorer à pleine dents, puis je me nettoierais les babines dans cette cape à cause de tout ce bon gras qui tache.";
D.q[1229] = "Prends cette pince ! Pour retirer une dent à un bouftou, c\'est un jeu d\'enfant, tu mets un pied sur la bête, tu choisis une dent, et tu tires un coup sec avec la pince !";
D.q[4223] = "Les opinions divergent à ce sujet, mais on raconte qu\'un terrible dragon aurait tenté d\'attaquer cette créature. \nCette dernière aurait alors attrapé le dragon avec ses tentacules pour l\'étouffer sous la tourbe, prenant ainsi le dragon au dépourvu. \nLes dragons incarnent la puissance, c\'est pourquoi beaucoup de personnes refusent d\'accepter cette histoire. \nMais les faits sont là, il y a une carcasse de dragon enfouie dans cette tourbière.";
D.q[6576] = "Je suppose qu\'il t\'a déjà résumé la situation donc je n\'irai pas par quatre chemins. Nos miliciens sont nuls, ils ne sont pas capables de coordonner leurs actions ce qui rend toutes nos stratégies inefficaces. Il nous faut trouver un tacticien qui puisse faire le lien entre nos stratégies et nos troupes écervelées. \nLa bibliothèque de Pandala est réputée pour posséder la plus grande collection d\'œuvres traitant de stratégie et d\'histoire militaire, dont l\'incontournable « L\'art de la guerre en getas » ou encore « Guerre et pet », sublime témoignage Pandawa. Sans nul doute pourras-tu trouver quelque tacticien à recruter là-bas.";
D.q[2711] = "Je forge un bouclier pour le Pandasiman... C\'est un maître dans l\'art du combat au bouclier. Il n\'utilise que d\'un bouclier béni par mes soins, et le sien lui à été dérobé par les Pandikazes.";
D.q[2842] = "Souhaitez vous revenir, je vais vous raccompagner jusqu\'au zaap du village, et de là vous rejoindrez le Zaap central";
D.q[6495] = "Ne crois pas que je vais te remercier pour ta générosité. Je suis un Roublard, la politesse ne fait pas partie de mon éducation.";
D.q[1079] = "Oui c\'est vrai, je n\'ai plus le coeur d\'y aller ces temps-ci. Je...Vous savez je.... Ah voilà je suis amoureux c\'est pour ça, désolé je peux pas en dire plus.";
D.q[2413] = "Nous divisons les métiers en deux grandes catégories : les métiers de récolte et les métiers d\'artisanat. La seconde catégorie ne peut rien faire sans les premiers.  \nDans les métiers de récolte on trouve : les paysans, les bûcherons, les pêcheurs, les chasseurs et les mineurs. \nDans les métiers d\'artisanat on trouve : les différents forgeurs, les différents sculpteurs, les bijoutiers, les cordonniers et les tailleurs. \nL\'alchimie possède le statut particulier d\'être à la fois un métier de récolte et d\'artisanat.";
D.q[5639] = "Hier soir j\'ai croisé un bouftou qui s\'était cassé la patte. Je l\'ai soigné comme ça il a pu marcher jusqu\'à chez moi et ensuite j\'ai invité mes amis et nous l\'avons fait rôtir. C\'est quand même pratique les soins, ça évite d\'avoir à porter les blesser.";
D.q[3188] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la première, ou la deuxième, ou la cinquième, ou dans la sixième salle, je ne m\'en souviens plus.";
D.q[3424] = "Oui, avec ça on devrait pouvoir y arriver. Va prévenir mon ami s\'il te plait";
D.q[6131] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[1329] = "Que je suis contente ! Les démons ne sont pas tous des idiots, je le savais. Gardez toujours votre honneur ! Peut-être que cette guerre ressemblerait à quelque chose si tout le monde était comme vous. Bon je vais crier sur tous les toits. Filez maintenant !";
D.q[3640] = "Une forte tête hein ? Ca fait longtemps que j\'en ai pas maté une ! Ecoute p\'tit gars, t\'es un bleu, tu vas faire ce que je te dis ou je vais transformer ta vie en le pire enfer que tu puisses imaginer. Quand tu seras passé entre mes mains, tu ne te souviendras même pas de ton nom, tu ne seras qu\'une masse douloureuse et informe de chair implorant ma pitié ! Pars avant que je ne m\'énerve réellement.";
D.q[701] = "Avant de sortir de ce temple, adresse toi à mon frère Tarazed, il t\'apprendra un moyen pour te guérir par la méditation. \nSi tu n\'es pas assez patient, il faudra te soigner grâce aux pains vendus par les boulangers, ou par les potions fabriquées par les alchimistes.  \nN\'oublie pas d\'économiser quelques kamas pour en acheter.";
D.q[7554] = "C\'est dommage, je suis sûre que nous pourrions faire de grandes choses ensemble. Enfin... \nJe ne vais pas te forcer la main, mais si tu changes d\'avis, tu sais où me trouver.";
D.q[2379] = "Etes vous sûr de vouloir débuter une carrière de sculpteur de Baguette ?";
D.q[3285] = "J\'ai ensuite découvert qu\'il y avait un château de sable assez étrange dans cette calanque, je m\'y suis aventuré, tel un brave homme en quête de rédemption, ou de digestion, je ne me souviens plus exactement. \nJ\'y ai pourfendu les créatures les plus abjectes qui hantent les fonds marins, même elles, n\'auraient pas peur en te voyant. \nC\'est là que j\'ai récupéré mes objets en mousse, en dépeçant une énorme mousse des mers, une éponge marine, l\'illustre Mob l\'Eponge.";
D.q[1058] = "Je t\'avais pourtant prévenu de savoir t\'arrêter ! \nEnfin, je suis de bonne humeur aujourd\'hui. Tu vas donc tout simplement recommencer.";
D.q[1900] = "Comment faire pour qu\'il arrête de penser à ces deux idiotes...J\'ai bien une idée  \nmais il risque d\'être très triste, et en colère s\'il apprend que c\'est  \nmoi... Ahh que c\'est dur *soupir*";
D.q[5546] = "Que me veux-tu fiente de trooll ? Je suis un important marchand bontarien, je n\'ai pas de temps à perdre avec des individus de ton espèce.";
D.q[2409] = "Qu\'as tu fais de la paire que je t\'ai donnée? Même s\'ils sont abimés, ils ont une certaine valeur... Si tu en veux une autre paire, cela te coûtera 50 kamas...";
D.q[5117] = "Je suis un capitaine de la milice de Brâkmar. Pour tout dire, je songe à déserter prochainement. Marre de ne jamais avoir de promotion après toutes ces journées de loyaux services.";
D.q[6298] = "De l\'impatience ? J\'aime ça. Puisque tu y tiens voici mon plan : Xephirès est en mesure de nous donner des informations sur les convois bontariens. Nous allons attaquer ces convois, mais envoyer des Brâkmariens risquerait d\'éveiller les soupçons. En plus de ça, je ne fais pas confiance à mes officiers pour me ramener l\'intégralité du butin, j\'ai donc mis au point un plan génial qui devrait détourner les soupçons de nos ennemis tout en m\'assurant que le butin n\'atterrisse pas comme par enchantement dans les poches de mes hommes.";
D.q[6284] = "Vous ne ressemblez pas à un de ces admirateurs fous, je pense pouvoir faire une exception pour vous. Vous allez voir c\'est très simple. En sortant de la taverne, vous prenez la direction inverse au mouvement inverse du soleil dans le ciel pendant une demie-lieue, puis vous prenez un chemin perpendiculaire à l\'axe Feudala - Akwadala que vous orientez à 90% de sa position initiale pendant un quart de lieue. Si vous n\'y arrivez pas, rendez-vous simplement au sud-ouest de la pointe du port, c\'est là.";
D.q[6567] = "Ah, je préfère ça. Je ne fais pas confiance aux gens qui en font trop, ça cache toujours quelque chose. Là au moins vous ne vous êtes pas laissé faire, ça veut dire que vous ne cherchez pas trop à m\'avoir. Je veux bien réfléchir à votre proposition.";
D.q[1495] = "Je vois..je vois......C\'est bien, tu as su garder le secret qu\'un supérieur hiérarchique t\'a donné. Je suis fier de toi. Bon, il n\'y a pas trop de chose à te donner là...Un petit voyage ou bien...Lors d\'une expédition sur une île lointaine, j\'avais goûté un petit vin délicieux, il se nommait " + "\"" + "Vin de Gloutovore" + "\"" + ", essaye de voir pour m\'en ramener un peu, je te ferais goûter. Promis !";
D.q[1525] = "Une dizaine j\'ai dit, sinon ça ne sert à rien. Retournes-y.";
D.q[5581] = "Hmm... Je vais réfléchir à ta proposition. Peu m\'importe les manières douteuses t\'ayant permises de te procurer cet argent, du moment que tu payes nous pourrons peut-être faire affaire. \nEn fait, je vais te donner un moyen de me convaincre. Je n\'arrive pas à imposer mes marchandises à Astrub car Mawy Ingalsse vend ses céréales moins chères que les miennes. De plus, ses produits ont bien meilleure réputation à cause de sa manière de les cultiver. Je ne peux pas m\'approcher de son atelier sans éveiller les soupçons, mais toi tu dois pouvoir t\'y rendre et convaincre Emia Elliesol de saboter le travail. Peu m\'importent les moyens employés du moment que tu obtiens des résultats satisfaisants.";
D.q[1090] = "Alors ta perm s\'est bien passée ? \nJ\'ai bien l\'impression que tu as oublié de ramener une bière à ton chef... pour la peine va m\'en chercher une à la Tabasse. \nAh j\'allais oublier, cette taverne se trouve à Bonta, je te souhaite donc bonne chance... \nTu n\'as qu\'à capturer un paysan et l\'envoyer la chercher à ta place ! Haha !";
D.q[3454] = "Hey, qu\'est-ce que tu fais encore dans ma mine gamin ?  \nToutes les mines m\'appartiennent ! \nPour 50 kamas je peux t\'aider à partir d\'ici, tu n\'as qu\'à prendre ce petit chariot, je vais le pousser un bon coup, et je t\'accompagnerai jusqu\'à la prochaine mine. \nMais attention, parfois les aiguillages ne fonctionnent pas très bien, et nous pouvons nous retrouver dans une autre mine ! \nParfois, il arrive même que nous nous fassions attaquer par de terribles mineurs sombres. Si tu as des amis, je te conseille de leur demander de t\'accompagner on ne sait jamais ce qui pourrait arriver...";
D.q[5619] = "Hahaha. Tu crois peut-être que nous allons parler ? Nous connaissons toutes les méthodes d\'interrogatoire de Bonta, et nous ne dirons rien. Va pleurer dans les jupes de ta mère.";
D.q[1509] = "Je souhaitais te rencontrer jeune disciple d\'Oto Mustam. Ces derniers temps, tu as accompli pas mal d\'exploits pour Brâkmar. Et il est écrit dans les ténèbres que cela ne s\'arrêtera pas là.  \nMais certaines choses sur Brâkmar te sont ENCORE cachées. Cette vision pourrait changer ta façon de voir Brâkmar. \nSouhaites-tu l\'entendre ?";
D.q[2278] = "Tu sais, ces arches de pierre réparties un peu partout dans le Monde !? Lorsque tu en verras une, approche t\'en. Elle gardera le souvenir de ton passage. Tu pourras ensuite t\'y téléporter à partir d\'un autre Zaap, moyennant quelques kamas.";
D.q[6265] = "J\'attends de voir la couleur de tes Kamas avant de prendre ma décision.";
D.q[4284] = "Comme tu voudras, mais tu ne pourras pas dire que je ne t\'avais pas prévenu.";
D.q[1542] = "Vous voulez des révélations sur votre avenir, très bien cela vous coûtera 50 kamas.";
D.q[403] = "Shhht !";
D.q[3085] = "Génial, il n\'y a plus qu\'à livrer tout ça. Va voir si Monabella est toujours intéressée.";
D.q[2283] = "Une histoire bête... Nous étions avec des mercenaires Sram, et un piège à Meulou s\'est refermé au mauvais moment. Ca m\'a coûté la moitié de mon oreille, mais moi ça va encore. Pour mon frère Kouy ç\'a été plus dur...";
D.q[2147] = "Hé oui ! Bien malin celui qui gagne un pari contre une Xélor, n\'est-ce pas ? On dit qu\'ils lisent l\'avenir, mais je crois savoir qu\'elle est amoureuse, ce qui occupe toutes ses pensées, alors lire l\'avenir, tu parles...";
D.q[3762] = "Iop a laissé son épée sur Incarnam pour nous rappeler sa toute puissance.";
D.q[462] = "Yop matelot ! Tu as fini ce que tu avais à faire ?  \nOn se rentre dans ce cas...";
D.q[2733] = "Vous êtes bien sûr de vous pour m\'aborder de cette façon. De quoi s\'agit-il ?";
D.q[1905] = "Vous tombez bien, à vrai dire mon livreur vient de tomber malade et je ne peux assurer la livraison d\'une commande spéciale. J\'ai besoin de bras forts, et de jambes rapides pour livrer ces gâteaux aux quatre coins de la ville. Je paierai bien, cela vous intéresse-t-il ? ";
D.q[3353] = "Toi, tu veux aller tondre la laine du roi des Bouftous, pas vrai ? Soit tu cherches la clef de son antre dans les entrailles d\'un de ses fidèles, soit tu m\'apportes ce qu\'il y a dans cette liste !";
D.q[1320] = "Ah c\'est votre tour de corvée ? Si vous pouviez m\'éplucher 20 patates, vous seriez un ange. Et si ça ne vous gène pas vous pourriez aussi m\'apporter 6 pattes de corbac et 3 yeux pour le goût ? Je vous en remercie d\'avance. Faites bien attention à ne pas vous couper.";
D.q[2420] = "Ce métier convient bien aux petits jeunes dans le dur monde des métiers. Assez facile et peu couteux, son principal interêt est de faire de la farine pour les boulangers.";
D.q[1357] = "*Pierre* \nPas de chance tu as perdu...";
D.q[4101] = "";
D.q[3359] = "Attention, il te faudra des runes pour pouvoir tester efficacement, ainsi que des objets. Tu peux trouver les deux chez mes collègues de cette zone. \nEs-tu prêt à t\'envoler vers un atelier?";
D.q[2967] = "Bien le bonjour, aventurier, que puis-je pour ton service ?";
D.q[3569] = "Ce qu\'il faut pour construire un symbole bien sûr, et surtout un drapeau mais c\'est pareil, il va falloir que je couse un symbole en drapeau.";
D.q[2117] = "Alors cette livraison ? Ca avance ?";
D.q[4243] = "Maljour à vous !";
D.q[1207] = "Moi ? Vous suivre ? Désolé, je ne peux pas... Tout ceci est trop récent.... \nMais prenez mon badge, cela devrait suffire !";
D.q[2869] = "Bonjour, nous sommes les banquiers. Vous pouvez ouvrir un compte dans ma banque et vous aurez un coffre à disposition pour déposer vos biens. Mais attention, chaque consultation de votre compte vous coûtera #1 Kamas.";
D.q[1210] = "Que fais-tu ici, esclave du bien ? \nPrends garde que le Chaos ne te détruise !";
D.q[6214] = "Puisque tu le prends comme ça voilà ce que je sais : trois clients ont un nom commençant par X. Xélora Busai, Xephirès et Xiron Keuch. Xélora traîne généralement dans le quartier des bricoleurs mais pour les autres aucune idée.";
D.q[2986] = "Je vois que tu es éloquent ! N\'hésite pas à consulter ton étoile, elle t\'indiquera comment tu dois parler à ceux qui t\'entourent. Tu sauras charmer le sexe opposé en montrant tes émotions, et te faire des amis... Et lorsque tu seras plus aguerri, tu sauras former un Groupe d\'aventuriers et leur parler comme un chef. Tu feras partie d\'une Guilde, et ceux qui en sont membres t\'écouteront ! ";
D.q[2984] = "Slurp ! La bière d\'Astrub, c\'est vraiment ma préférée. Cette légère amertume, cette mousse suave... mmhhh.... Reslurp ! Alors, je vois que tu es né sous une bonne étoile. Regarde bien, elle se trouve en bas à gauche, tu saisis ?";
D.q[283] = "Hello ! Je me nomme Simgood, et je suis marin. J\'ai parcouru toutes les mers du globe, mais mon rêve est d\'ouvrir une boutique de souvenirs, qui se vendront par milliers - par millions que dis-je ! - à travers le monde. Les gens se les arracheront, juste pour pouvoir dire qu\'ils possèdent un souvenir de Simgood le marin. Je pense commencer en taillant ou décorant des pinces de crabe.";
D.q[2995] = "Il s\'est vengé en râturant l\'un de mes livres... Je sais que ce livre se nomme " + "\"" + " le temps des dragons " + "\"" + ". On peut trouver des exemplaires de ce livre dans Astrub. Je vois... que tu brûles de me rendre ce service, alors récupères-en un pour moi !";
D.q[3787] = "Mais pour vivre une expérience unique et te préparer pour l\'avenir. Bon, relaxe toi, je vais te lancer un sort qui ne fonctionne que si la personne est consentante.";
D.q[1186] = "Cette tour ? Il s\'agit du point de rencontre des trois plus puissants Ordres de Bonta : l\'Ordre de L\'Oeil Attentif, celui de l\'Esprit Salvateur et celui de l\'ordre du Coeur Vaillant.";
D.q[7564] = "C\'est du jus de ouassingue distillé. Cette boisson est interdite dans toutes les cités du monde civilisé car elle crée chez le buveur un important phénomène de dépendance. \nMaintenant que tu as eu ce que tu voulais, va enquiquiner quelqu\'un d\'autre.";
D.q[1423] = "#1, tu es de nouveau un habitant d\'Amakna.";
D.q[1536] = "Voilà 2000 kamas pour te remercier, les ouvriers seront contents d\'apprendre qu\'ils peuvent continuer les travaux.";
D.q[132] = "Xavier le Boulanger est très célèbre dans le milieu de la Boulangerie. Je pense que ça n\'est pas justifié, il n\'est pas aussi charismatique que moi, ses pains ne sont pas aussi dorés que les miens, et tout ce que l\'on raconte à son sujet n\'est que légendes. Tout le monde pense que je suis jaloux, mais c\'est faux.";
D.q[6472] = "Je vois plusieurs raisons à ça : votre laideur, votre haleine, vos goûts vestimentaires, votre façon de cuisiner, votre équipement moisi et peut-être même votre façon de..., enfin, vous voyez ce que je veux dire. Ou peut-être préfère-t-il simplement les hommes, ou les araknes.";
D.q[5527] = "Merci. A présent j\'ai besoin de ta signature ici pour valider le document officiel. Si tu ne valides pas le document, la procédure sera annulée et les frais ne seront pas remboursés.";
D.q[2657] = "Quoi tu as perdu ton bouclier avant l\'entraînement ?\nSi tu veux que je t\'en fabrique un nouveau apporte-moi 10 bois de bambou";
D.q[5403] = "Allez chante avec moi ce refrain : " + "\"" + "C\'est mon ami, Bibi. Quel beau Bibiblop. Il est super gentil. Comme un bébé Blop. Quand j\'ai besoin de lui. J\'appelle Bibiblop. Si son Biblop fait Blop. Il fonce droit dans la vie..." + "\"" + ". \nTu ne veux vraiment pas chanter avec moi ? \nBon dans quelle salle veux-tu aller ?";
D.q[1302] = "Un nouvel impôt ? Oto Mustam n\'a aucun scrupule ! Il dévalorise notre belle cité ! Jamais je ne paierai cet impôt !";
D.q[30] = "Hé bien, on ne peut pas dire que l\'on chôme en ce moment avec ma petite Shika... Nous sommes débordés ! \nHeureusement que les récoltes s\'annoncent plutôt bonnes. \n \nSi vous avez du temps, j\'ai du travail pour vous.";
D.q[2602] = "Mmh... tu n\'as pas payé de taxe ! Je ne suis pas autorisée à te parler !";
D.q[3174] = "Que viens-tu faire dans mon Tofulailler ? Sais-tu que nous élevons des Tofus depuis plusieurs générations ? Nous élevons même des espèces uniques sur le continent !";
D.q[3833] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[427] = "Les Arcs sont les armes préférées des Crâs, qui aiment attaquer leurs ennemis à distance. \nLes arcs font rarement d\'importants dégâts, mais leurs coups critiques sont en général surprenants. \nIls nécessitent une bonne agilité et de la force pour pouvoir être utilisés. \nLes Sculpteurs d\'arcs utilisent comme outil, une Tailladeuse d\'arcs.";
D.q[6228] = "Je n\'ose pas sortir de ce bosquet car j\'ai entendu des bruits de pas et des rires narquois un peu plus au nord. Si tu peux y jeter un coup d\'oeil et revenir après pour me dire que le chemin du retour est dégagé, je te donnerai les informations dont tu as besoin.";
D.q[258] = "Bonjour, je suis Aria Knofob. Je suis installée depuis peu dans la province d\'Amakna, et pensais avoir été très chanceuse de trouver cette maison à vendre pour quelques kamas.\nIl faut dire que le cadre est agréable, mais le bosquet qui l\'entoure regorge d\'Araknes. La lumière les attire, et je suis envahie. Ils se sont installés dans le grenier.";
D.q[3076] = "Je ne parle pas du requin, le poisson. qui vient du mot requiem (la messe des morts) mais d\'un forban, un truand qui sème la terreur dans le port. Tu peux pas le rater il est couleur carmin (rouge pour les ignares de ton acabit). Dis lui de quitter les lieux !";
D.q[2582] = "...contaminer les coiffes Pandawas avec les germes de la Pandrista était une idée de génie ! Et le vent a porté d\'autres maladies aux quatre coins de l\'île : ces maudits aventuriers risquent d\'être surpris...";
D.q[4401] = "... Magnifique. Bon, il semblerait que ce ne soit pas lui mais je vais le garder à l\'oeil pour en être sûr.";
D.q[840] = "Aaah même pour nous démon cela fait du bien de souffler un peu. \nBon c\'est pas encore ça avec mon fils qui me casse les pieds pour me battre en ce moment mais c\'est toujours mieux que de devoir attendre le retour d\'agents spéciaux en mission importante. \nHmm mais j\'y pense puisque tu n\'as rien à faire, va distraire mon fils. Et perds surtout sinon c\'est moi qui vais devoir te battre.";
D.q[5491] = "Quel rang souhaites-tu avoir au sein de la milice ?";
D.q[1138] = "Certains sont un peu cabossés, t\'aurais pu les tabasser moins fort.\nEnfin bon ça devrait faire l\'affaire. Tu seras bientôt des nôtres #1.";
D.q[284] = "Ma foi pourquoi pas ! Si tu me rapportes des pinces de crabe, je te paierai. Pour chaque lot de trois pinces de crabe que tu me ramèneras, je te donnerai des graines de pavot, qui parfument si bien les pains d\'un bon boulanger.";
D.q[3850] = "Tiens, encore une jeune âme en vadrouille sur Incarnam.";
D.q[3307] = "Quel nouvel ouvrage a été publié depuis ma dernière visite à la bibliothèque ? Comment cuisiner un Bontarien ? Comment piétiner un Piou Piou ? Je devrais peut-être m\'y rendre ?";
D.q[2050] = "Ca y est, tu as le sang du mineur sombre ? Bon je vais l\'analyser. J\'enverrai les résultats de mes recherches à ton maître.";
D.q[2834] = "La nuit dernière, des Brâkmariens ont brûlé plusieurs entrepôts de nourriture destinés à l\'alimentation des dragodindes de la milice. Comme les réserves s\'épuisent rapidement, il faut trouver un moyen de faire pousser les céréales plus vite. Merlan l\'Enchaîneur, à l\'atelier des alchimistes, pourra peut-être l\'aider. \n \nJe compte sur toi !";
D.q[4600] = "Ah, vous êtes de Bonta ? J\'ai récupéré les documents comme prévu, mais par contre je n\'avais pas prévu qu\'ils me poursuivraient ! \nAh, je les entends, ils arrivent !";
D.q[6397] = "Ah oui, on m\'avait prévenu que vous passeriez me donner ces documents. Ne vous en faites pas, tant qu\'ils seront en ma possession les Brâkmariens ne pourront pas mettre la main dessus. \nSaluez Amayiro de ma part.";
D.q[543] = "Bien le bonjour étranger, on me nomme Kib Roche, futur grand pirate. J\'ai échoué sur cette île en suivant mon tout nouvel achat : une carte au trésor parlante. Mais ce damné perroquet s\'est enfui lors de mon arrivée fracassante par la voie des airs. ";
D.q[545] = "Entre nous, c\'est une longue histoire pleine d\'or, de singes, et de personnages peu recommandables. J\'en retiens juste une explosion, un formidable vol plané en bateau, un arrachage de voile pour m\'en servir de parachute et ma tête dans le sable.";
D.q[1012] = "Déjà de retour ? Je vais étudier les informations que tu m\'as apportées sur la porte de Brâkmar au calme. \nSinon, j\'ai un nouveau travail pour toi. Un sanglier agressif piétine les récoltes au Sud de la ville, essaye de le chasser de là, pour calmer les paysans.";
D.q[1522] = "Qu" + "\"" + "il en soit ainsi... \nVa porter cette lettre à Oto. Et continue ton chemin.";
D.q[553] = "Les pirates occupent une partie du Nord de l\'île, ils vous accueilleront les bras ouverts. Ne manquez pas de goûter leur rhum 120 ans d\'âge. Pensez aussi à saluer bien bas leur illustre capitaine. Mais surtout ne vous moquez jamais de son caleçon porte chance. Selon la légende, son caleçon ridicule lui aurait assuré assez de chance pour échapper aux multiples tempêtes lorsqu\'il naviguait dans les terribles mers de Kalmar.";
D.q[4677] = "Avant de répandre tes organes sur les murs j\'ai une petite mission pour toi. D\'habitude ce sont les jeunes recrues qui s\'en occupent mais ton échec récent mérite une sanction. \nSi la corne est aussi puissante qu\'on le dit, Bonta a maintenant un atout de poids ! Nous devons nous préparer à une attaque ! \nDonne une de ces caisses à certains des guerriers de la cité, pour améliorer leur équipement : les guerriers sont Brank Thoof, Kad Maxy, Jack Rottance, et Xale DuGros.";
D.q[3893] = "Reviens plus tard, je réfléchis à mon prochain plan.";
D.q[3772] = "Essaie donc, tu ne peux pas perdre !";
D.q[573] = "Recemment il y a le guide touristique de votre agence qui est arrivé en planant sur la plage ahaha. Un apprenti pirate traîne aussi au sud de l\'île, je crois qu\'il cherche un moyen de partir ahahah.";
D.q[588] = "Ohohoh, vous n\'avez pas l\'air d\'être un Kanniboul, mais vous semblez être un grand guerrier et j\'apprécie ça ! En guise de remerciement pour m\'avoir tant amusé, je vous montre ma technique secrète du lancer de marteau, et je vous autorise à l\'utiliser en mon nom. Je vous demanderai ensuite de partir en vitesse du village...";
D.q[1732] = "Disciple d\'Enutrof, tu dois avoir encore beaucoup de choses à apprendre, que veux-tu savoir ?";
D.q[5523] = "Si servir Bonta t\'intéresse, je peux m\'arranger pour te faire des papiers qui attesteront de ton affiliation à leur milice. Ca me fera gagner du temps et ça ne te coûtera pas un sou. \nPourquoi je fais ça ? Tout simplement parce que Bonta m\'offre certains avantages en nature pour chaque nouvelle recrue enrôlée grâce à moi. Je te suggère cependant d\'aller voir Snori Nairb à Astrub avant d\'entamer la procédure pour rejoindre l\'alignement minoritaire, il donne une récompense à quiconque souhaite s\'engager.";
D.q[3452] = "Filtounga finie, vous mangez !";
D.q[4078] = "Quel sort veux-tu oublier ?";
D.q[5698] = "De l\'argent ? J\'en ai caché des tonnes.";
D.q[5524] = "Si servir Brâkmar t\'intéresse, je peux m\'arranger pour te faire des papiers qui attesteront de ton affiliation à leur milice. Ca me fera gagner du temps et ça ne te coûtera pas un sou. \nPourquoi je fais ça ? Tout simplement parce que Brâkmar me paye grassement pour chaque nouvelle recrue enrôlée grâce à moi. Je te suggère cependant d\'aller voir Snori Nairb, à Astrub, avant d\'entamer la procédure pour rejoindre l\'alignement minoritaire, il donne une récompense à quiconque souhaite s\'engager.";
D.q[610] = "Tu veux me l\'acheter ? bah pourquoi pas, ça me fera gagner du temps. Je te le cède contre 5000 kamas et 5 peaux de larves orange. J\'en ai besoin pour me confectionner une potion d\'invisibilité. À ce prix-là, c\'est un cadeau que je te fais.";
D.q[1152] = "Je me nomme Oshimo Li\'Kross Babine. Je viens de loin pour apporter ma connaissance en matière d\'animaux. Quand j\'ai entendu la nouvelle sur la peste familière j\'ai accouru à dos de tabi. Et j\'ai décidé ensuite de rester.";
D.q[3487] = "La bataille de Bworkdrift fut une chaude affaire, huit jours à patauger dans l\'sang des camarades, plus de 300 morts rien que dans mon régiment, mon meilleur ami, le Kaptain Bluebitt a eu les yeux arrachés par une bille de fronde. Mon adjoint, le Sergent Malbaret, a agonisé trois jours à mes cotés, les deux jambes coupées nettes par une hache trooll...";
D.q[3519] = "Hum hum hum miam miam, moâ dévorer ton coeur !!";
D.q[265] = "Si tu veux affronter un Dopeul, il faudra faire une donation de Ficelle de lin au temple...";
D.q[1814] = "Si tu veux affronter un Dopeul, il faudra faire une donation de fleur de Blop coco au temple...";
D.q[3564] = "Panoplie Prespic et une baguette.";
D.q[3478] = "Moâ pas tigob, moâ grand chef gobelin !";
D.q[390] = "Bonjour, je suis Koussein Trengon, mais je ne suis pas Duc du Koussein. Enfin, pas encore. Je me laisse constamment porter par ma bonne étoile. Elle m\'apporte tout ce dont j\'ai besoin. Par exemple, je parie que vous allez bientôt m\'apporter les ingrédients qu\'il me manque pour préparer une potion.";
D.q[858] = "Combat contre le fils diabolique du maître !";
D.q[6142] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[2764] = "Si tu te sens prêt, viens le Samedi au Dojo. Tu présenteras tes techniques pour obtenir ton grade.";
D.q[7380] = "Je commence à en avoir assez des incompétents. Je te débarrasse de ce désagrément, même si je me doute que la leçon n\'aura pas porté ses fruits.";
D.q[1156] = "La somme d\'argent de départ dépend de la date de son dernier repas. Je demande 10 kamas par heure depuis son dernier repas ainsi qu\'un petit forfait qui dépend de la difficulté à nourrir le familier.\nLa somme d\'argent pour le reprendre dépend du nombre d\'heures pendant lesquelles votre familier est resté dans le chanil. Je demande 10 kamas par heure plus une somme symbolique d\'un kama.";
D.q[3506] = "Toi seul peut sortir trouver ce qui me manque, je suis cloitré du fait de mon peuple et de mon cerveau surdéveloppé. \n";
D.q[1786] = "Si tu veux affronter un Dopeul, il faudra faire une donation de Bave de Bouftou au temple...";
D.q[3486] = "Seulement pour un Bwork, c\'est pour ça que ces deux peuples cohabitent. C\'est la seule espèce que les Bworks n\'aiment pas dévorer. Seul les mages Bworks en mangent au début de leur formation pour apprendre à lire. Je rêve toutes les nuits de cette bataille. Ma mère,Bworkcelhaine, en avait assez de mes cris.";
D.q[3775] = "Veux-tu retourner à ta statue ?";
D.q[1150] = "Mon livreur de fournitures s\'est trompé et m\'a fourni quatre fois trop de poudre soignante pour familier. Ne voulant pas trop perdre de cette erreur, je solde cette poudre exceptionnellement à 1000 Kamas, demandez-moi si vous êtes intéressé.";
D.q[1831] = "Si tu veux affronter un Dopeul, il faudra faire une donation de feuille de tronknyde au temple...";
D.q[1833] = "Si tu veux affronter un Dopeul, il faudra faire une donation de feuille de fourbasse au temple...";
D.q[772] = "62";
D.q[6243] = "Si tu cherches à te procurer quelque chose au marché noir, va voir Rekojel. Il est au courant de toutes les denrées qui circulent illégalement dans la cité, ce qui veut dire qu\'il est au courant de tout ce qui s\'achète et se vend dans la cité. Tu pourras le trouver à proximité des enclos publics, pas loin de l\'atelier des bricoleurs.";
D.q[1576] = "Pitié je veux sortir de cette prison sordide !";
D.q[435] = "Une fois que vous m\'aurez ramené 10 Oeufs de Dragoeufs Blancs, je vous donnerai un Vieil Os de Dragoeuf en échange. \nCet os est magique, Azra Lazarus la Bijoutière est persuadée que l\'on pourrait l\'utiliser pour confectionner de précieux bijoux. \nAllez la voir, elle vous en parlera plus en détail.";
D.q[1810] = "Comme beaucoup d\'Eniripsa veulent s\'entraîner avec mes Dopeuls, je leur demande de faire une donation avant chaque combat pour subvenir aux besoins du temple. \nSi tu veux affronter un Dopeul, apporte moi une fleur de pissenlit.";
D.q[1834] = "Tous mes dopeuls sont fatigués pour le moment, reviens demain si tu veux t\'entraîner davantage...";
D.q[4522] = "Si vous cherchez par vous-même ça va prendre des mois. Vous feriez mieux de demander à Setag l\'Enutrof, ce vieux mineur doit connaître des endroits quasi-inaccessibles où je serai plus en sécurité qu\'ici.";
D.q[688] = "Et voilà la seconde question, \nD\'après vous comment se mesure l\'attention \nAu sein d\'un couple amoureux, \nEn terme de quantité se sera mieux.";
D.q[1015] = "Pauvres bouftous, tu ne fais pas dans la finesse #1, il n\'y en a pas le nombre exact !\nÀ moins que tu ne saches pas compter ?\nPour la peine je prends déjà celles-ci, et tu vas devoir m\'en ramener 32 de plus !";
D.q[3848] = "Les aventuriers viennent souvent se reposer dans les tavernes et les auberges pour récupérer de l\'énergie et descendre une bonne mousse tiède. ";
D.q[675] = "Voilà tu connais l\'invocation du point de croix ! Ah, non ! C\'est l\'invocation du Chaferfu... Chaferfu a dit : Dites " + "\"" + " Bonjour ! " + "\"" + ".";
D.q[3106] = "Merci pour tous tes services, je parais un peu capricieuse comme ça mais si je disais oui à tout le monde, je serais obliger de courir partout comme toi et mon métabolisme ne le supporterait pas.";
D.q[1835] = "Merci beaucoup ! grâce a vous j\'ai réussi à confectionner un joli radeau avec les objets que vous m\'avez apportés. Il me permettra de quitter l\'île très prochainement !";
D.q[1374] = "Merci, commençons.........Mais....Sang de Djaul ! La lave n\'a pas les caractéristiques attendues ! Tout s\'accorde à dire que le courant magmatique est en mouvement. Il faut absolument savoir ce qu\'il se passe la dessous. Il y a une entrée vers une grotte au Sud-Est d\'ici. Au fond de cette grotte une rivière de lave coule. Je pense que c\'est le meilleur endroit pour étudier le phénomène. Hélas la grotte est infestée de monstres. Vous allez donc m\'y emmener et me servir de bouclier.";
D.q[5465] = "Ours entrer Taverne. Ours dire : « Moâ vouloâr Bière d\'Astrub...";
D.q[1246] = "Bon c\'etait la dernière fois, je veux bien être aimable et femer les yeux sur la provenance de cette recette, mais il ne faut pas abuser de ma bonté...";
D.q[1764] = "J\'ai entraîné des Dopeuls pour qu\'ils apprennent les techniques de combat Enutrof. Ainsi ils font d\'excellents adversaires pour s\'entraîner, et ce quel que soit ton niveau.";
D.q[2762] = "Admettons que tu aies un Pandawa de Feu pour ami - ce n\'est qu\'une supposition, nous sommes d\'accord... Tu souhaites lui faire un cadeau digne de ce nom afin qu\'il puisse ravager et détruire en tout quiétude... Quelle cape lui offriras-tu ?";
D.q[845] = " Il parait qu\'il y a eu plusieurs éboulements dans les égouts. Bien que la terre est plutot instable dans le coin certaines rumeurs circulent sur le fait que ces éboulements ne sont pas naturels. Verifie moi ça.";
D.q[5610] = "Ceti po que je commence à avoir des hollucinotions. Co y est, le vieux Terra Cogita il perd lo boule.";
D.q[733] = "Hier, nous avons subi une défaite terrible contre Brâkmar, ils ont utilisé une invocation inconnue jusqu\'alors. \nJ\'aimerais que tu te renseignes sur cette créature auprès de Zeurg le maître de classe des Osamodas, il a toujours de très bons conseils à ce sujet.";
D.q[1795] = "Si tu veux affronter un Dopeul, je te conseille de te préparer. Alors ? prêt ?";
D.q[2430] = "Il se situe à l\'extérieur de la ville, dans la ferme du Nord-Est.";
D.q[242] = "Vous êtes collant, vous ! Bon. J\'en ai marre d\'être seul ici... Et puis j\'ai peur du noir. Amenez-moi 10 plumes de tofu et 2 gelées bleutées, que je puisse me confectionner des ailes pour m\'enfuir d\'ici. Je vous donnerai la clé de ma grotte en échange.";
D.q[394] = "Bonjour, je suis Ali Akelle, peintre illustrateur. Comme mes illustrations sont en noir et blanc, j\'utilise des Pattes d\'Arakne réduites en poudre pour faire ma peinture. D\'ailleurs, j\'en cherche, j\'ai une commande urgente.";
D.q[1577] = "Content de te revoir Houé Dapyus, mais tu n\'es quand même vraiment pas doué pour te faire avoir comme ça !";
D.q[249] = "Je n\'ai pas la tête à ça pour l\'instant, mais tu peux t\'amuser avec nos dopeuls si tu veux. Va voir Brigitebardo Peule, c\'est elle qui les élève.";
D.q[1281] = "Quel gâchis, tu les as coupées au sabre ces patates ma parole ?";
D.q[469] = "Là, à votwe ceintuwe, je vois bien les deux clés de mes fwèwes d\'awmes. Ils ont dû chéwement défendwe leur vie...Vous devez êtwe un twwible guewwiew...Je vous donne ma clé, ça ne sewt à wien que je finisse en civet...";
D.q[241] = "Je vous répète que je ne vous dirai rien ! Jamais je ne vous dirai qu\'il est caché dans une grotte, dont l\'entrée se trouve à l\'ombre d\'un buisson lumineux. Oups... bah, l\'entrée est scellée de toute façon, et je ne sais même plus où se trouve ce buisson...";
D.q[1670] = "Merci #1, les rats d\'Hyoactifs sont une vraie plaie pour la productivité de notre ville, leur Hyoactivité pousse les gens à prendre des congés et aller s\'amuser à la foire du Trool !";
D.q[1478] = "Ahah ! Bien joué, je vais faire transmettre ça à notre équipe de recrutement. Ils seront ravis.";
D.q[2173] = "Merci beaucoup. Cette réunion était d\'une importance capitale. Voila quelques kamas pour te récompenser. Reviens me voir quand tu veux. Je t\'offrirai un peu de mon précieux temps...";
D.q[691] = "Voici l\'ultime interrogation, \nPuis nous évaluerons la situation. \nInteressons nous aux petits calins, \nLe soir, le midi, ou le matin ? \n";
D.q[2222] = "Qu\'attendez vous pour aller porter le remède aux Enutrofs ?";
D.q[408] = "Le cordonnier travaille essentiellement le cuir, pour en faire des ceintures, mais également des bottes. \nIl arrive parfois que les cordonniers utilisent du bois ou des métaux précieux pour décorer leurs créations ou alors les renforcer. Le cordonnier utilise une dague appelée " + "\"" + "Coupe Cuir" + "\"" + " comme outil pour travailler le cuir. \nSi vous cherchez ce genre d\'outil, je peux vous en donner un en échange d\'un peu d\'aide.";
D.q[1631] = "Merci ! Ma mère me disait toujours : " + "\"" + "Si tu manges des Bluegely et des Vertgely, ne mange jamais 2 Rougely en même temps !" + "\"" + "";
D.q[4153] = "Grâce à mon idée de génie, j\'ai pu économiser énormément de temps et de farine de qualité. J\'espère que tu comprends désormais pourquoi je suis une des meilleures boulangères du monde des 12 ?";
D.q[4035] = "Bonjour ! Ravi de te revoir mon ami ! Pourrais-tu m\'aider encore une fois ?";
D.q[4904] = "Pnj(679) et Message(4903)";
D.q[3691] = "Je n\'ai rien remarqué, tout est clair.";
D.q[3496] = "Bworkidais être paxifik.";
D.q[721] = "D\'après tes dernières informations, je pense avoir trouvé un moyen de saboter la porte de Brâkmar. Je vais aller en parler à mes supérieurs. Je te remercie.";
D.q[3499] = "Moâ pas aimer grande gueule.";
D.q[6522] = "C\'est la chance du débutant, à moins que ce soit une veine de cocu. Je pencherai plutôt pour la deuxième solution. Je vais répondre à ta question comme ça tu ne me piqueras pas tous mes Kamas ce soir. \nTu vois l\'hôtel de vente des mineurs ? Oui, de Brâkmar, évidemment ! Trape a une planque à proximité de l\'hôtel de vente, c\'est tout ce que je peux te dire et je n\'ai pas envie de discuter davantage avec toi. \nN\'oublie pas tes gains.";
D.q[6524] = "C\'est la chance du débutant, à moins que ce soit une veine de cocu. Je pencherai plutôt pour la deuxième solution. Je vais répondre à ta question comme ça tu ne me piqueras pas tous mes Kamas ce soir. \nTu vois l\'hôtel de vente des mineurs ? Oui, de Brâkmar, évidemment ! Trape a une planque à proximité de l\'hôtel de vente, c\'est tout ce que je peux te dire et je n\'ai pas envie de discuter davantage avec toi. \nN\'oublie pas tes gains.";
D.q[6235] = "Pendant que tu te promenais dans la forêt des abraknydes, des gobelins m\'ont attaqué par surprise. J\'en ai tué plusieurs mais ils étaient trop nombreux et ils m\'ont capturé. Heureusement je suis un Sram très doué et après plusieurs jours de marche, j\'ai réussi à leur forcer compagnie grâce à un tour dont je te passerai les détails. Comme ils me poursuivaient, j\'ai couru à en perdre haleine et, essouflé, je me suis réfugié sur cette corniche. Malheureusement il m\'est impossible d\'en descendre alors si tu voulais bien me donner un coup de main, je t\'en serai reconnaissant.";
D.q[2008] = "Aïe, mais arrête... tu vises comme un pied. On va se faire gronder s\'il appartient à quelqu\'un. Pauvre Bouftou, il a été tué sur le coup. J\'crois que personne t\'as vu. Bon, va vite donner l\'arc à l\'alchimiste Nibé Lulle, il va améliorer la corde. Enfin... Pas sûre que ça vienne de l\'arc...";
D.q[3912] = "Un noble ? Il y en a beaucoup ici mais digne de la princesse, je n\'en connais pas.";
D.q[6217] = "Je ne vois pas de quoi tu parles. Je ne mets jamais les pieds dans la tour de Bonta. C\'est le tavernier Bagrutte qui t\'a parlé de moi ? Je vais lui apprendre à se mêler de ses affaires.";
D.q[6482] = "C\'est gentil de votre part, mais les ordres sont les ordres et je ne peux pas vous montrer le rapport vous concernant. Par contre pour vous remercier je peux vous dire que le rapport original se trouve dans la Tour des Ordres de Bonta. Je n\'ai pas eu le droit d\'y jeter un coup d\'oeil pour vérifier son authenticité ce qui change de la procédure habituelle car après tout c\'est moi l\'expert. Bien sûr, si quelqu\'un venait à le dérober, je pourrais l\'authentifier. Le problème, c\'est le garde. Une personne aussi habile que vous doit être en mesure de le dérober sous son nez si quelqu\'un détourne son attention. Enfin, ça reste hypothétique n\'est ce pas ?";
D.q[1047] = "Ah ! Un amateur de canon à ce que je vois ? Si tu as des questions à ce sujet, je suis incollable.";
D.q[1471] = "C\'est tout ? Tu es venu à Bonta rien que pour ça ? Oto veut ta mort ou quoi. Je lui aurais envoyé demain par kwak comme d\'habitude. Bon, tiens, que tu ne sois pas venu pour rien. Et file maintenant !";
D.q[4676] = "Les Brâkmariens sont les serviteurs des démons, Jiva soit louée de nous protéger d\'eux. Or l\'expérience a prouvé à maintes reprises qu\'il fallait se méfier des démons, ces êtres vils et perfides qui corrompent tout ce qu\'ils touchent. Malheureusement, le métal et la ruse ne suffisent pas pour gagner contre eux, ainsi ai-je songé à augmenter la puissance magique de nos armées et le nombre de sortilèges à leur disposition. Comme je suis quelqu\'un de généreux, j\'ai pensé partager cette idée avec toi afin que tu puisses profiter de la réussite de cette mission.";
D.q[400] = "Hello, restons simples, appelle-moi l\'Étalon. Hier j\'ai mangé du jambon de Dragon Cochon. On m\'en avait vanté certaines vertus, mais cela s\'est avéré être une bien mauvaise idée, les effets résultants n\'étaient pas ceux que j\'espérais... Bref, j\'aurai besoin de quelques ingrédients pour me soigner.";
D.q[5793] = "Non rien, fausse alerte. Ouf !";
D.q[4885] = "Amayiro a besoin de moi ? Ca me ferait plaisir de l\'aider, bien sûr. Vous pouvez lui dire qu\'il suffira de me prévenir avec au moins un jour d\'avance pour que je puisse fermer la boutique et mettre la clientèle au courant.";
D.q[953] = "La porte de cette tour se trouve au Nord-Ouest de Bonta, elle renferme toutes les fonctions administratives de la ville. \nSi vous cherchez le trésorier, ou le maire de Bonta, vous les trouverez certainement là-bas.";
D.q[1857] = "La création de nouveaux vêtements est assez éprouvante en soit. Utiliser des patrons est déjà un peu plus facile, et encore...Un bon tailleur se doit d\'avoir un réseau de fournisseur important, il ne fera pas grand-chose sinon. Sans compter qu\'il faut beaucoup d\'expérience pour faire des vêtements dignes des plus grands.";
D.q[695] = "Il vous suffira juste de méditer. \nA l\'heure nulle vous reviendrez. \nCette heure secrete qui vaut bien un baiser, \nLa patience sera votre alliée.";
D.q[92] = "Hyooohooo, j\'ai besoin de me confectionner des bretelles en cuir pour que mon pagne ne tombe plus ! Ramenez-moi du cuir de Bouftou, et je vous donnerai en échange ma Tailladeuse de Bâton : elle permet de sculpter des bâtons si vous maîtrisez le métier correspondant.";
D.q[3061] = "Avec tout ce que tu nous as livré, nous allons pouvoir avoir un beau château que le monde entier nous envie déjà.";
D.q[749] = "William Lenglad commence à saouler sérieusement les habitants de la cité, va lui mettre une raclée, à lui et son groupe, pour me faire plaisir. \nIl se trouve à l\'Ouest de Bonta.";
D.q[2851] = "Tu te crois brave ? Va à Pandala et accomplis ce que tu dois !";
D.q[4156] = "Grâce à vous je sais pourquoi mon fils voulait s\'écarter de moi, j\'ai bien compris la leçon, et plus jamais je ne l\'appellerai, mon petit wabbit, je l\'appellerai, mon petit boufton à partir de maintenant, je suis certain qu\'il appréciera ! ";
D.q[3492] = "Moâ être paxifik, si toâ pas d\'accord moâ frapper toâ pour t\'expliquer !";
D.q[3199] = "La dernière fois que j\'ai rencontré le Maître Corbac, il se cachait dans la onzième salle, ou la douzième, ou la quinzième, ou peut-être dans la seizième salle, je ne m\'en souviens plus.";
D.q[4016] = "Une livraie de valet pour un prince Wabbit ? C\'est une commande peu commune, je n\'ai pas les étoffes nécessaires. Il me faut un tissu pourpre, comme celui qu\'on trouve sur les bwork mage. J\'assemblerai le tout avec dix fils de soie. Si vous me trouvez cela, je vous confectionnerai un habit digne d\'un valet de prince.";
D.q[5518] = "Que puis-je pour toi habitante de Brâkmar ?";
D.q[3987] = "Tudieu, une pwincesse à mawier ! Que voilà une nouvelle intéwessante. Je suis ton pwince ! Pawtons céans !";
D.q[2485] = "Ah merci ! Grâce à toi on va pouvoir se remettre à travailler... (il baille).";
D.q[3198] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la onzième salle, ou la douzième, ou la quinzième, ou peut-être dans la seizième salle, je ne m\'en souviens plus.";
D.q[3194] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la onzième salle, ou la douzième, ou la quinzième, ou peut-être dans la seizième salle, je ne m\'en souviens plus.";
D.q[3865] = "Bonjour. Je vois que vous êtes un vaillant guerrier... Souhaiteriez-vous aider à protéger Amakna et le trône d\'Allister ?";
D.q[1189] = "L\'Ordre de l\'Esprit Salvateur est celui qui maîtrise le mieux les arcanes de la magie et de la guérison. \nNous sommes voués au bien des autres, et à la protection de la cité contre les attaques démoniaques des adeptes d\'Hécate de Brâkmar.";
D.q[1731] = "Les disciples Sacrieurs peuvent utiliser n\'importe quelle arme, mais ne sont pas adroits avec les armes en général. Ils sont meilleurs avec leurs sorts.";
D.q[782] = "72";
D.q[1190] = "Les Ordres sont des groupes armés, chargés de faire respecter l\'honneur et l\'équité au sein de notre monde. \nLes trois grands Ordres de Bonta sont l\'Oeil Attentif, l\'Esprit Salvateur et le Coeur Vaillant. \nBien évidemment, chacun d\'entre eux a ses us et coutumes, ses propres méthodes pour arriver à mener sa tâche à bien. \nIl me faudrait des heures pour vous expliquer toutes les subtilités des trois Ordres.";
D.q[4140] = "Alors as-tu réussi à te procurer une potion Bulbique ?";
D.q[6365] = "La Descemer est en mer depuis des lustres et à ma connaissance le navire n\'a pas prévu d\'accoster avant encore au moins deux semaines sur l\'île d\'Otomaï. Il n\'était pas prévu qu\'il aille au port de Madrestam de toute façon. \nEn parlant de Bontariens, il y a par contre un important chargement d\'équipements sortis de nos forges qui est parti pour la cité de Bonta il y a déjà plus d\'une semaine. A l\'heure actuelle le convoi devrait être arrivé à destination et les miliciens sont sûrement en train de tester leur nouvel attirail.";
D.q[6449] = "Le conseil m\'empêche d\'envoyer des troupes pour investir le repaire des bandits. Je suis certain que le repaire des bandits contient des informations pouvant nous révéler l\'identité de leur commanditaire mais le conseil m\'empêche d\'envoyer des troupes pour l\'investir. La mission que je vais donc te demander est risquée mais je n\'ai pas le choix.";
D.q[2702] = "Bonjoul ! Soil le bienvenul dans ma demeule. Tu as l\'oeil scintillant comme l\'astle de la nuit : ton coeul est pul... Que puis-je poul toi ?";
D.q[2105] = "Le " + "\"" + "Coup-Devin" + "\"" + " bien sûr ! Celui grâce auquel je deviendrai riche et célèbre ! Si tu veux en savoir davantage, assieds toi, prend une bière et écoute-moi l\'ami, c\'est une histoire fantastique ! ";
D.q[790] = "80";
D.q[890] = "80";
D.q[2518] = "...Quelle aubaine cette légende à propos des oeufs de dragon ! Nos coffres seront bientôt pleins à craquer ! Mmh... vous désirez un renseignement ?";
D.q[791] = "81";
D.q[6333] = "Mille mercis, ça va être bien pratique pour m\'aider à payer la caution de mes chachas. Il me reste justement un exemplaire de la méthode d\'élevage canin, prends-en soin.";
D.q[965] = "Les pierres des fortifications de Bonta ont été taillées à partir de la dépouille des craqueleurs des plaines. \nUne troupe de Bworks a ébréché celles du nord cette nuit. \nSi tu veux nous donner un coup de main, ramène-moi au moins 4 pierres de craqueleur des plaines pour nous aider à les reconstruire.";
D.q[893] = "83";
D.q[794] = "84";
D.q[479] = "L\'accès à cette pawtie de l\'île est wesewvé au wa. Hows de ma vue !";
D.q[7061] = "Les pierres suivantes... \n";
D.q[3961] = "L\'attentat avec le tofu a échoué... Je crois qu\'on va faire les chose à la mode roublarde et simplement empoisonner ce " + "\"" + "chew pwince" + "\"" + " avec un blopisier empoisonné.";
D.q[3406] = "Le chemin n\'est pas le but, mais c\'est le chemin qui y mène. Pour toi il a été long et il n\'est pas fini. Mais au bout du voyage, auras-tu atteint ta destination ? Car si le but est atteint, obtiendras-tu ce que tu convoites ?";
D.q[7060] = "Les pierres suivantes... \n";
D.q[723] = "Le tavernier de la Tabasse a aussi une dette envers moi, j\'aimerais que tu ailles lui réclamer. N\'hésite pas à user de la force s\'il le faut, car ce coquin a toujours de bonnes excuses pour ne pas payer. \nCes 100000 kamas devraient permettre de refaire la lame de mon katana, ça coûte une petite fortune.";
D.q[2800] = "Ton sang bouillonne à l\'idée de se répandre dans un endroit maudit...Chercherais-tu à entrer dans le labyrinthe ?";
D.q[5789] = "Dès que j\'éternue, le temps autour de moi semble faire d\'étranges choses. Pour couronner le tout, je suis allergique au pollen. Difficile pour moi de ne jamais tousser... Mais je me soigne ! \nPour me faire pardonner, j\'offre régulièrement des bonbons aux habitants d\'Amakna qui subissent les effets secondaires de mes éternuements. \nIls n\'ont pas mal de succès, je suis assez fière de moi. Mais pour le moment tout va bien, heureusement ! \n \n*roule les yeux et renifle bruyamment* \n \nOh non...Oh ";
D.q[7875] = "A la bonne heure ! Voici le classeur.";
D.q[3277] = "Cette somptueuse clef peut t\'amener directement là où se cache le Chêne Mou, ou presque, il te faudra peut-être éliminer quelques indésirables entre temps. Es-tu certain de vouloir y aller ?";
D.q[4417] = "Hâte-toi. Il ne faudrait pas rater leur rendez-vous.";
D.q[2158] = "Tiens je reprends tout";
D.q[6457] = "Ce fauteur de troubles ? Je m\'en rappelle comme si c\'était hier. Il posait problème dans une taverne donc nous l\'avons arrêté et mis en cellule. Malheureusement nous avons reçu l\'ordre de le faire sortir dès le lendemain sous prétexte qu\'il avait des puces et des tiques et qu\'on ne voulait pas d\'alerte sanitaire dans la prison. C\'est bien la première fois que j\'entends parler d\'alerte sanitaire dans notre prison mais les ordres sont les ordres. \nJ\'ai demandé à mes hommes de garder un oeil sur lui et ils m\'ont rapporté qu\'il traînait souvent près de la Tour des Ordres, mais tant qu\'il se tient à carreau je ne peux pas le faire arrêter.";
D.q[1574] = "Mais tu en as déjà un !";
D.q[3462] = "Cette recette est trop dure à réaliser. Moi qui pensais devenir riche en brassant de la bière de Bwork, je crois que je vais me contenter de faire de l\'élevage de Pworks. \n";
D.q[640] = "Ceci est une fontaine de jouvence ! Elle sert à récupérer des points de vie.  \n \nLorsque tu combats des monstres, tu vas sans doute perdre des points de vie.  \nSi tu n\'es pas encore au niveau 6, tu peux te soigner avec cette fontaine.";
D.q[1358] = "*Agite la main*";
D.q[1014] = "Merci, j\'en connais un qui va pouvoir remanger du steak de bouftou, grâce à toi. \nSalue Amayiro de ma part ! ";
