D.q[844] = "Hummm. Après avoir étudié de fond en comble le plan de la cité j\'ai trouvé une faille potentielle : Les égouts de Brakmar. Il va falloir vérifier ça de plus près. Comme je t\'ai sous la main c\'est toi qui va être de corvée. Va d\'abord découvrir les égouts. Profites-en pour en débarasser l\'entrée de quelques rats...Et ramène leurs carcasses, ça fera toujours de la viande de plus pour le diner....On est 10 ce soir alors ramènes-en au moins 10.";
D.q[3074] = "Il y a un requin qui sème le trouble dans le port. Trouve-le moi et reviens m\'indiquer où il navigue. ";
D.q[3427] = "J\'aime... beaucoup... les enfants.";
D.q[4005] = "Pas assez!";
D.q[4475] = "Ah ! Dans une grotte du territoire Porcos. \nUn paranoïaque ? Ca ne va pas être facile de négocier avec lui, surtout s\'il apprend qui nous sommes. Il faut quand même essayer et au pire il y a toujours la solution de secours.";
D.q[3087] = "Une affaire rondement menée. Je vais aller boire un peu de lait de cochon avec ma vieille amie Verumacha. Grâce à elle, j\'ai pu voir que tu étais quelqu\'un de confiance.";
D.q[4539] = "Ah, c\'est vous ! Pouvons-nous commencer l\'attaque ? La patrouille de Brâkmar va arriver d\'un instant à l\'autre.";
D.q[2624] = "Arg ! Comment as-tu deviné que je n\'étais pas un vrai Pandawa?! ";
D.q[3521] = "Moâ premier magobelin !";
D.q[2642] = "Je suis la personne la plus populaire de cette île, la plus jolie, la plus forte et je ne crains rien ni personne mouahahahaha. Hmm oui excusez-moi que voulez-vous ?";
D.q[5564] = "Je viens juste d\'arriver, je n\'ai pas encore jeté le sortilège. Si la potion est contaminée, je préfère vous la confier. Prenez-la.";
D.q[2783] = "J\'pense que je vais rester un peu ici, le temps que tous mes amis soient rétablis. Et puis... j\'ai croisé la route d\'une charmante vendeuse dont le poil était aussi doux que ma barbe ! Ses yeux sont deux rubis et...par la barbe d\'Enutrof...elle picole plus que moi ! Je ne partirai pas sans avoir tenté un coup de pioche dans son p\'tit coeur j\'te l\'dit ! J\'suis même prêt à sortir mon sac de bijoux, c\'est dire ! Ma jeunesse réafflue dans mes veines !";
D.q[4291] = "Je pense que tu as deviné ta prochaine tâche. Rends-toi à la taverne du Pandawa Ivre entre 16h et minuit, rencontre Xephirès et parle-lui de notre proposition : un gros sac de kamas contre son obéissance.";
D.q[4096] = "Hors de ma vue, parjure !";
D.q[1917] = "Pnj(471) et Message(1909)";
D.q[2450] = "Ici sont enfermés les pires chenapans du coin. C\'est à moi que vous devez vous adresser pour enfermer vos prises.";
D.q[7280] = "Je dois partir à l\'hôtel de vente et je ne peux pas laisser des gens utiliser la forge pendant mon absence, alors sors s\'il-te-plaît.";
D.q[4022] = "Laisse-moi réfléchir, veux-tu !";
D.q[3899] = "Alors, finalement, tu viens nous aider ou pas ?";
D.q[4050] = "Bonjour noble sire !";
D.q[937] = "Bienvenu à la taverne de la Tabasse, qu\'est-ce que je peux faire pour toi ?";
D.q[3616] = "Toâ trouver Gobrose.";
D.q[3156] = "Bonjour #1 . Je suis Nikos. Nikos Monote. Je suis le plus grand marin de tous les temps, j\'ai navigué là où personne n\'a navigué, j\'ai trouvé ce qu\'il y avait après les océans, j\'ai percé le mystère du Kralamoure géant. Bref je suis le meilleur.";
D.q[1517] = "Je veux simplement que tu réfléchisses, quel culte vénères-tu ? Veux-tu la mort de Bonta et honorer notre vengeance ? Ou souhaites-tu le pouvoir absolu et la mort de toutes choses ? As-tu de l\'honneur ? Ou es-tu comme Oto, qui ferait tout pour arriver à ses fins ? Ton choix importe beaucoup. Prends cette bague. Lorsque tu connaîtras la réponse, reviens me voir. Rends-la-moi si tu es du mouvement de Djaul.";
D.q[6507] = "huhuhuhéhéhé HIARHIARHIARHAHAHA !  \nDonne-moi 1000 Kamas et je t\'explique pourquoi je rigole. Donne-moi 1500 Kamas et je te dis où trouver des salles de jeux clandestines. \nhuhuhuhéhéhé HIARHIARHIARHAHAHA !";
D.q[6383] = "Oh, je vois que tu t\'es déjà engagé suw cette voie. Tu as fais le bon choix. Lowsque Bonta bwûlewa, tu wéalisewas que tes wêves sont à powtée de main et plus pewsonne ne pouwwa t\'empêchew de les wéalisew.";
D.q[305] = "Kat... Kat... Kat...ékit";
D.q[1389] = "Rien à signaler dans le coin.";
D.q[1690] = "Choisis le montant de jetons";
D.q[1694] = "Choisis ton cadeau";
D.q[3856] = "Les aventurières viennent souvent se prélasser dans les salons pour récupérer de l\'énergie, papoter et déguster un bon petit lailait frais.";
D.q[1040] = "Excellent, tu m\'épates sur ce coup là !";
D.q[1868] = "Alors ?";
D.q[2935] = "Félicitation tu t\'es très bien battu ! Je valide donc ton passage de grade...";
D.q[1232] = "Hmm elle n\'est pas fraîche, elle a dû se réchauffer pendant le voyage. \nTu as de la chance, c\'est comme ça que je les préfère !";
D.q[4566] = "Ton monde m\'a bien amusé, c\'est pourquoi je tiendrai ma promesse de ne pas le détruire... tout de suite. \nSi tu m\'apportes un vieux Trousseau de clefs, je peux te le remplacer par un nouveau, qui te servira pour aller te mesurer aux monstres les plus forts.";
D.q[1946] = "Je..Je...Ah je suis fini *soupir*.";
D.q[6477] = "Vous tirez la tronche parce que vous m\'apportez ma pitance, sympathique comme attitude... Je ne vous remercie pas.";
D.q[3728] = "Tenva Lakruche a lu le livre des vérités mais elle n\'a pu que me conter le récit car ce livre est difficile à trouver même sur Amakna. Si tu veux, va lui parler et elle aussi te parlera de la gloire de Iop.";
D.q[1316] = "Oh, Amayiro a enfin envoyé quelqu\'un à mon secours ? \nLibère-moi vite et aide-moi à m\'échapper !";
D.q[1565] = "Mince, je ne pensais pas que la milice viendrait fouiner dans mes affaires. Tu ne crois pas que vous devriez vous occuper de Brâkmar, plutôt que d\'embêter les gens qui exercent leur métier...";
D.q[6149] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[6148] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[6144] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[6528] = "Ecoute-moi avant de faire une bêtise, j\'ai gagné beaucoup d\'argent récemment et je suis en mesure de rembourser Oto Mustam avec les intérêts. Je sais que j\'aurai dû le rembourser il y a plus de deux mois déjà mais j\'avais des soucis financiers. Tu ne vas quand même pas m\'éliminer alors que j\'ai ce qu\'il faut pour ton chef, si ? A la limite je veux bien... enfin... je peux aussi combler tes désirs si tu me laisses en vie, qu\'en penses-tu ?";
D.q[3476] = "Brises os, répands cervelles, crèves yeux et tues tues tues Bworks !";
D.q[481] = "Je suis trop occupé à chercher le trésor d\'Halouine, pour l\'instant. Tous les ans à cette période, il parait qu\'un passage secret permet de trouver ce trésor. Je m\'y intéresse car il contiendrait un livre expliquant la manière de créer un masque citwouille très puissant.";
D.q[1733] = "Disciple de Crâ, tu dois avoir encore beaucoup de choses à apprendre, que veux-tu savoir ?";
D.q[1712] = "Disciple, tu dois avoir encore beaucoup de choses à apprendre, que veux-tu savoir ?";
D.q[2291] = "Beeeek ?";
D.q[137] = "Mais vous ne pouvez pas jouer, vous n\'avez pas assez de kamas pour miser cette somme. Misez moins ou revenez avec plus de kamas.";
D.q[6467] = "Des documents sur nos convois de marchandises, des documents sur certains prisonniers, divers documents sur des notables de la cité, tout ça ne me dit rien qui vaille. Je te félicite pour ton travail mais fais attention à toi, je ne puis assurer ta protection en dehors des murs de ce bâtiment et il semblerait qu\'un ou plusieurs personnages importants de Bonta soient impliqués dans cette affaire.";
D.q[6789] = "Qu\'est-ce que tu racontes ? Le poil que tu as dans la main, c\'est le tien !";
D.q[1314] = "zzzZZZzzz";
D.q[4427] = "Encore de l\'espionnage ? Que Kaffra hésite à attaquer Bonta m\'aurait étonné si je ne voyais pas où il veut en venir. Il craint sans doute que Jerhyn Gholein ait volontairement envoyé des miliciens sous-équipés à notre encontre afin de nous inciter à foncer tête baissée. Malheureusement pour lui nous sommes plus malins qu\'il ne l\'imagine. Il nous faut impérativement trouver les faiblesses de la milice bontarienne avant de lancer l\'assaut.";
D.q[1089] = "Tu es en perm j\'ai dit !";
D.q[3736] = "Je guide surtout les malotrus vers la sortie !";
D.q[1695] = "Choisis ton cadeau";
D.q[1720] = "Choisis ton cadeau.";
D.q[7108] = "Bien sûr, si tu as suffisamment de doplons, je peux te les échanger contre diverses babioles.";
D.q[3249] = "Il te faudra de toute évidence une clef pour rentrer dans ce sanctuaire. La seule façon d\'en obtenir une, c\'est de faire appel à un Bricoleur expérimenté. Pour fabriquer cette fameuse clef, il lui faudra retrouver des fragments de coquille que seuls quatre gardiens Dragoeufs possèdent. Je ne sais pas où tu peux trouver ces gardiens Dragoeufs, on peut parfois les voir sortir des habitations abandonnées une fois la nuit tombée. Si j\'étais toi, j\'irais explorer les différentes maisons de ce village.";
D.q[6478] = "Bonjour, puis-je vous aider ?";
D.q[811] = "Haha, une âme innocente dans ces lieux, si tu veux faire partie des nôtres, ramène-moi 10 dagues de boisailles, je dois entraîner mes gus demain.";
D.q[1349] = "*Pierre* \nHmm, j\'ai perdu, tu n\'es pas si mauvais, passons à la 2eme manche.";
D.q[872] = "62";
D.q[3677] = "Tu te bouges un peu le popotin ? Si tu ne te débrouilles pas mieux en dehors d\'Incarnam, tu ne trouveras jamais de Dofus ma pauvre fille.";
D.q[2292] = "Pas trop le temps, je suis occupé, là...";
D.q[2952] = "Pnj(163) et Message(2950)";
D.q[3481] = "Cavalerie Gob aider moâ, toâ mourir et moâ vendre ta pô aux Bworks !!";
D.q[3477] = "Gobelins pas vouloir finir en tapisserie à la Manufacture.";
D.q[3712] = "Piou piou";
D.q[6286] = "C\'est bon, vous avez gagné. Je vais remettre votre lettre à Xephirès mais laissez-moi tranquille.";
D.q[3395] = "Oui ! C\'est bien. Pas fini... rien n\'est fini, rien ne se termine jamais. Encore se battre. Toujours. La clef du prochain combat.";
D.q[3555] = "Pô vertes faire belles tapisseries.";
D.q[881] = "71";
D.q[60] = "Ah je souffre, que c\'est délectable, huhu, mes ailes me font mal, j\'ai passé la nuit à les fouetter brrrr...";
D.q[3495] = "Zog Zog à toâ.";
D.q[2991] = "Pour ajouter un joueur à ton carnet, clique sur son personnage, puis sur " + "\"" + " Ajouter à mes amis " + "\"" + ".";
D.q[7467] = "Le second pouvoir est beaucoup moins puissant, il permet d\'oublier partiellement ses caractéristiques, si tu ne veux pas perdre ce que tu as appris déjà avec des parchemins de caractéristiques.";
D.q[6294] = "Hahahahaha. Tu es encore plus moche qu\'un pou de trooll. Donne-moi tes biens et je te laisserai la vie sauve. Refuse et même ta mère sera incapable de te reconnaître lorsque j\'en aurai terminé avec toi.";
D.q[3587] = "Moâ appeler kopain Trool !";
D.q[3834] = "Alors, prêt à te lancer dans la grande aventure ? ";
D.q[3617] = "Mon coeur vibre, vibre, vibre.";
D.q[4290] = "Oh ? Un bijou somptueux ? Mais bien sûr, j\'en ai une dizaine sous la main. Tiens, prends celui qui te plait. Et pas besoin de payer, c\'est la maison qui offre.";
D.q[3042] = "Rargh, je me sens faible ! Je n\'ai plus beaucoup d\'énergie !";
D.q[3448] = "Vous avoir recette ? Ca bien ! Vous allez chercher ingrédients, moi cuisiner.";
D.q[4359] = "Pas vu d\'Ecaflips, mais hier j\'ai entendu des gardes parler d\'une bande d\'Ecaflips qui font des problèmes récemment. Si ça peut aider...";
D.q[4009] = "Ah, pauvre de moi ! mon maître m\'a mis à la rue ! Moi un si bon serviteur !";
D.q[4011] = "Oui, tu m\'as prouvé ta force... C\'est d\'accord, je servirai ton prince.";
D.q[2059] = "Quesce tu veux ? ";
D.q[2643] = "AAAAAAAAAAAAAAH Va-t\'en ! Va-t\'en ! Va-t\'en ! Va-t\'en !";
D.q[486] = "Hahaha, ces missions secrètes sont réservées aux maîtres du clan.";
D.q[2633] = "Bonjour noble aventurier, Sli Dento s\'incline devant vous, puis-je vous renseigner d\'une quelconque manière ?";
D.q[5517] = "Que puis-je pour toi habitant de Brâkmar ?";
D.q[1701] = "Bonjour #1, que puis-je faire pour toi ?";
D.q[3154] = "Bonjour #1. Je suis Fidji Merline, la soeur de Liroye Merline, une des plus célèbres bricoleuses du continent, nous sommes bricoleurs depuis plusieurs générations dans ma famille, et ma soeur et moi avons décidé de nous installer dans des cités rivales afin de faire profiter à tous de notre savoir et de notre expérience. Que veux-tu savoir ?";
D.q[3614] = "Gobrose pas venir. Suis vert ! Tue ses pious préférés, elle viendra !";
D.q[923] = "Salut minus qu\'est-ce que tu me veux ?";
D.q[717] = "Salut petit scarafeuille, j\'espère que tu n\'as pas de trous dans tes bottes, car tu vas devoir t\'en servir : Je prends toujours une bière chez un collègue tavernier vers l\'est de la ville. J\'aime profiter de ce moment de détente pour échanger quelques cartes spéciales avec lui. Il m\'en doit une depuis notre dernière rencontre, tu peux y aller pour moi ?";
D.q[3268] = "Bonjour testeur de l\'extrême ! \nJe suis persuadé que tu aimerais tester les anciens et les nouveaux métiers !";
D.q[1044] = "Le voici éclatant comme au premier jour.";
D.q[3668] = "Plus !";
D.q[3755] = "Parfois j\'ai l\'impression d\'être manipulé par une entité supérieure qui dicte mes actes et mes paroles, pas un des douze dieux, quelque chose d\'autre.";
D.q[786] = "76";
D.q[292] = "C\'est une idée révolutionnaire, mais elle demande beaucoup d\'expérimentations. Je me sers du Fémur du Chafer Archer réduit en poudre pour simuler le goût du curry. Mais le bon dosage est difficile à trouver et je suis en manque de fémurs.";
D.q[1360] = "*Ciseaux* \nHmm, mais comment ? Ce n\'est pas possible ? Tricheur !";
D.q[3711] = "Piiiiiiiiiiou";
D.q[3714] = "Attention devant, je transporte de l\'eau pour les nymphettes. ";
D.q[6327] = "Bonjour, toi aussi tu aimes les bêtes ?";
D.q[6610] = "Bonjour, viens-tu m\'apporter le grimoire du mage bwork ?";
D.q[4510] = "Bonjour, où en es-tu avec ce Nara ? Est-il aussi compétent qu\'on le prétend ?";
D.q[4498] = "Hmm, Bonta a des soucis et vous avez besoin d\'un bon forgeron ? \nJe ne peux pas m\'en charger, mais peut-être que... \nNon, laissez tomber.";
D.q[980] = "Avis de recherche ?";
D.q[2515] = "Bonjour citoyen d\'ailleurs ! Avant toute chose, sachez que la vente de produits fermentés est strictement réglementée sur cette île. Ces produits sont à consommer avec la modération la plus absolue. Mais nos échoppes vous sont grandes ouvertes, à vous et à vos kamas !";
D.q[3779] = "Veux-tu retourner à ta statue ?";
D.q[1438] = "Hmm tu cherches des documents pour mener à bien un interrogatoire ? \nJe te conseille le formulaire d\'enquête nº 36, mais je le vends 500 kamas l\'exemplaire...";
D.q[1153] = "Avant de sortir de ce temple j\'aimerais te faire passer un petit test. \nJe vais te poser quelques questions pour être sur que tu sois aptes à découvrir le monde, si tu le passes avec succès je t\'apprendrai une technique de meditation fortement utile.";
D.q[2069] = "Hey, il me faut une pelle en boisaille, oh oui une pelle... je suis sauvé ! Creuser... toujours plus... \n... Sous-terre, c\'est la protection...";
D.q[1698] = "Oui, oui...Bon allez, piochez un objet dans ce grand sac. Certains objets valent très chers...Si si !";
D.q[6233] = "Hé vous là-bas, sortez-moi de là !";
D.q[2954] = "Pnj(163) et Message(2950)";
D.q[6267] = "Voici le cristal. Maintenant libérez ma nièce comme convenu.";
D.q[889] = "79";
D.q[3139] = "Mais que fait un être aussi abject que vous dans le repaire de notre grand maître, le vénérable Skeunk ? \nVous ne comptez tout de même pas franchir cette porte ? \nSeuls les aventuriers qui reçoivent la permission des quatre soeurs disciples de Skeunk, ont le droit de franchir cette porte.";
D.q[4426] = "Des nouvelles de Kaffra ?";
D.q[1362] = "*Pierre* \nHmm, mais comment ? Ce n\'est pas possible ? Tricheur !";
D.q[1240] = "Bonjour, que désirez vous ?";
D.q[4474] = "As-tu trouvé ce forgeron ?";
D.q[918] = "Bonjour, je me nomme Ture Inge, spécialiste en espionnage et en psychologie. Je sais que vous voulez quelque chose de moi.";
D.q[1739] = "Disciple, tu dois avoir encore beaucoup de choses à apprendre, que veux-tu savoir ?";
D.q[1347] = "Hmm, si tu gagnes une partie, je t\'apprends à y jouer n\'importe où et avec n\'importe qui.";
D.q[6545] = "Toi on peut dire que tu n\'as pas froid aux yeux. Les Ecaflips doivent apprécier de parier avec toi.";
D.q[4043] = "Merci ! Est-ce tout ?";
D.q[1065] = "Hum, laisse-moi, tu vois bien que je fais ma pause !";
D.q[4093] = "Bon j\'ai fini cette potion, prêt à devenir Wabbit ?";
D.q[6269] = "Hum... tout bien réfléchis, ce doit être possible d\'y parvenir sans se donner la mort. Ta mission reste inchangée mais inutile de te baigner dans les douves de Brâkmar pour te donner la mort, tu m\'es plus utile vivant.";
D.q[1935] = "Merci pour le rapport.... Je suis vraiment entouré d\'une bande d\'incapables ! Et puis, de quoi il me parle lui... j\'arrive même pas à le relire... équipe de fouille... une autre découverte... bon sang ! Je veux savoir ce que c\'est ! ";
D.q[5693] = "J\'ai senti une aura maléfique et j\'ai tout de suite pensé à toi. \nQue veux-tu ?";
D.q[1582] = "La loyauté n\'est pas héréditaire, il ne faut donc pas croire que tous les gens de Bonta sont respectables.";
D.q[2169] = "Aurais tu peur des araknées pour revenir si vite ?";
D.q[5579] = "Comment oses-tu m\'insulter ? Je ne fais pas la manche, pas comme ces gueux à la banque d\'Astrub.";
D.q[744] = "Nous avons besoin de main d\'oeuvre pour construire une extension au bâtiment de la milice, il me reste deux boulots à te proposer, choisis-en un et je donnerais l\'autre à Torche. \nTout d\'abord, si tu te sens l\'âme d\'un coupeur de bois, il nous faut une vingtaine de planches de frêne pour fabriquer le plancher. \nSinon, si tu as envie d\'un peu plus d\'action, il me faudrait une dizaine de racines d\'abraknyde pour construire les jonctions entre les poutres.";
D.q[2371] = "Ah pour ça il faut demander à Ahenn, elle se situe au rez-de-chaussée du bâtiment des métiers. Voulez-vous que je vous indique son emplacement ?";
D.q[6212] = "Comment saurai-je qui est X ? Je ne m\'intéresse plus aux autres depuis qu\'il est parti.";
D.q[7525] = "Contre quels doplons souhaites-tu faire l\'échange ?";
D.q[3665] = "Marche jamais ce zaap. J\'use des centaines de marteaux à le réparer ! Vivement que Xelor vienne lui-même le réparer. J\'aimerais bien manger une crêpe ou deux histoire de faire une pause.";
D.q[652] = "Nous avons la recette qu\'aucun Enutrof n\'utilisera jamais, alors je te la donne volontiers : \nOubli de Chance : 3 vieux trèfles à 4 feuilles, 70 trèfles à 5 feuilles, 30 amulettes de krokette \nAmusant non ? \n";
D.q[6573] = "Avec ça je vais pouvoir commencer à installer des pièges afin d\'éviter la visite d\'intrus. Non, je ne suis pas capable de créer des pièges qui font la différence entre de vrais intrus et de simples visiteurs, mais quelle importance ?";
D.q[2473] = "J\'ai tout perdu... plus un seul kama.";
D.q[1086] = "Voici ta lame toute neuve ! Comment ça, j\'ai été rapide ? Je ne suis pas le plus célèbre forgeur de lame de Bonta pour rien....";
D.q[3320] = "Je veux piééééééééééééééétiner ! Ramène-moi vite ces Dragodindes.";
D.q[2561] = "Les Lénalds étaient jadlis les plotecteurs d\'un Dofus. Jalousés par les Pandawas de Feudala, ceux-ci complotèrent avec ces infâmes Wabbits ! Et nous, les Lénalds, fûmes chassés de notle île... Mais la vélité est ailleuls... Lends-toi sur l\'île des Wabbits, et tu saulas !";
D.q[686] = "Répondez à ces 3 questions \nUniquement par des affirmations. \nLa première est la plus facile, \nPour son amour combien dépenser de mille ?";
D.q[3937] = "Ah, ce feignant de Gueudin bosse enfin, il a des sacs de jute à porter au château.";
D.q[1173] = "Oui que voulez-vous ?";
D.q[6459] = "Je vois pas de quoi tu parles, fous-moi la paix.";
D.q[1268] = "Bon on a un problème de taille, le puits de la milice est bouché, je ne vois qu\'un seul homme capable de déboucher le puits rapidement : toi ! \n \nDans le sous-sol de la milice il y a une salle d\'entraînement appelé \'la cave aux scorpions\', le but est simple. \nSurvivre à l\'assaut de 8 scorpions, dans le but de s\'habituer au poison et développer une résistance naturelle à ses effets. \nParle au garde à l\'entrée, il te fera rentrer et aura une surprise pour toi.";
D.q[3643] = "J\'ai toute une théorie concernant l\'impact de la migration des éponges dans la mer d\'Asse, la longueur des égouts d\'Astrub et sur l\'épaisseur des sourcils des Enutrofs.";
D.q[5560] = "N\'as-tu rien de mieux à faire que venir me raconter des sottises ?";
D.q[7064] = "Les pierres suivantes... \n";
D.q[6143] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[1241] = "Bonjour, n\'ayez pas peur surtout, je ne suis pas méchant. Je suis un gentil sorcier vous savez. La plupart des sorciers n\'ont d\'ailleurs pas le coté mauvais que la réputation leur donne je vous assure.";
D.q[6146] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[2472] = "Jouer, jouer et encore jouer... J\'adore le jeu...";
D.q[2565] = "Je sais que tu reviens de loin. Le Dark Vlad est entré dans les brumes de la folie, il y a fort longtemps... Personne ne sort indemne de cette rencontre : ton esprit est plus fort maintenant ! ";
D.q[2957] = "Pnj(163) et Message(2950)";
D.q[176] = "Huummmm...#1, le disciple d\'Oto Mustam, que puis-je faire pour un vil Brâkmarien comme toi ?";
D.q[4061] = "Quel sort veux-tu oublier ?";
D.q[4080] = "Quel sort veux-tu oublier ?";
D.q[309] = "Depuis que j\'ai gagné la confiance de mes consommatrices, j\'arrive à leur faire croire n\'importe quoi. Tenez, en ce moment je leur vends des manteaux en peau et poils de souris, en leur affirmant que c\'est tendance. Et bien, j\'ai tellement de commandes que je ne sais pas si j\'aurai assez de poils pour satisfaire toutes mes clientes...";
D.q[386] = "Bonjour #1, je suis l\'assistant d\'Otomaï. C\'est l\'un des rares enchanteurs d\'Amakna. \nJe l\'aide à créer des enchantements d\'arme, mais aussi des potions ou des parchemins magiques. \nQue puis-je faire pour toi ?";
D.q[444] = "Il est plus vieux que le plus vieux des Enutrofs, plus fourbe que le plus fourbe des Roublards, et plus dangereux qu\'un Bwork Mage saoul.  \nVous ne devriez pas aller le rencontrer seul, il se promène souvent avec une armée d\'Araknes dans les forêts près de la scierie du sud, il est toujours en quête de nouveaux bûcherons à dévorer. \nUne dernière chose... faites attention à sa magie, elle a déjà failli ôter la vie à Brouce Boulgoure le Bûcheron l\'hiver dernier.";
D.q[4453] = "50 000 kamas ? Pour cette somme, je suis prêt à venir parmi vous ! Faites-moi signe quand vous pourrez m\'escorter jusque là-bas.";
D.q[4082] = "Quel sort veux-tu oublier ?";
D.q[202] = "Le bluff ne marche pas avec les Ecaflips, vous devriez le savoir. Vous n\'avez pas ce que je vous ai demandé.";
D.q[1338] = "Vous avez de la chance j\'ai justement une potion de désenvoutement sur moi. \nVoilà colonel, vous avez retrouvé votre apparence normale.";
D.q[2709] = "Une réunion secrète se tient en ce moment même à Aerdala. Nous autres ignorons ce qui se trame là-bas... Mais une chose est sûre : il y sera question des Dofus. Le sage Lenald souhaite t\'envoyer toi, il est difficile de faire confiance à l\'un des nôtres en ce moment, les pandikazes sont partout. Mais Maître Lenald est certain qu\'il peut te faire confiance. Fais attention : Plus d\'un aventurier s\'est fait mal accueillir en allant à Aerdala. On les dit alliés des Pandawas rebels, ceux qui sabotent tous les accès de l\'île. Il faut que tu t\'infiltres et que tu nous rapportes un maximum d\'information. Retourne voir le sage... si tu reviens en vie.";
D.q[3658] = "J\'ai un petit creux.";
D.q[4227] = "Tremblez, mortels ! Ce monstre était là avant l\'île, il EST l\'île. Personne ne peut rivaliser avec sa puissance et ce n\'est pas cet Otomaï et ses tours de sorcier qui feront la différence. J\'ai bien entendu parler de cette terrrrrible création qu\'il aurait accomplie mais croyez moi, c\'est du flan !";
D.q[1774] = "Voilà, ces ciseaux sont à toi à partir de maintenant, fais-en bon usage.";
D.q[1947] = "*Sigh* croyez-moi ou pas, je ne coupe pas la bière par radinerie. Mais je n\'ai pas le choix. Mon stock de bière s\'amenuise et toujours pas de nouvelle livraison. Sans bière, plus de clients, sans client plus de taverne, sans taverne plus de Tek. *soupir*";
D.q[2942] = "Je suis impressionné, rares sont les aventuriers qui arrivent à résister à mes coups de boules. Pour te récompenser, je vais te donner mon familier, cet adorable Chienchien noir.";
D.q[3024] = "Salut à toi, étranger. Tu te trouves en un point du Monde où l\'Infini et le Néant se rejoignent, en tous cas si on en croit les chiffres. On ne dirait pas, hein ? C\'est Nistracolamus qui t\'envoie ?";
D.q[6292] = "Par Djaul ! Je suis presque déçu. Si tu recommences à me faire des entourloupes je risque de te promouvoir officier ou pire, alors méfie-toi.";
D.q[4315] = "Un message d\'Oto ? Des voleurs qui vont s\'introduire chez moi ? Ah ! J\'entends des bruits de pas !";
D.q[4881] = "Hmmm, si, effectivement. Bon, écoute, on va s\'arranger : met une raclée à ce fichu mioche, et fais-moi croire que tu as perdu. Je ferai comme si c\'était vrai.";
D.q[2803] = "Vous êtes à l\'entrée du Village d\'Akwadala, seuls ceux qui ont prouvé leur force peuvent y rentrer.";
D.q[163] = "Fantastique, quelle chance ! Vous avez gagné, et cela faisait longtemps que ça n\'était pas arrivé dans cette taverne. \n \n(Grizmine vous donne les kamas en se grattant les moustaches et en ronronnant)";
D.q[6140] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[659] = "Je peux vous fabriquer une alliance de mariage, mais pour cela il me faudrait 25 pépites d\'or et 1000 kamas.";
D.q[4651] = "Merci pour ton aide ! Ca devrait aller pour moi maintenant.";
D.q[6296] = "Je suis le Gardien du Puits des Âmes Souillées. Puisque vous m\'avez vaincu, vous avez droit à une seule et unique requête. Choisissez sagement.";
D.q[1469] = "Mes humbles excuses, je ne peux vous parler. Je suis en patrouille.";
D.q[1506] = "Plus le temps de toute façon, je distingue une vague d\'ennemis arriver. Prépare-toi ! CHAFER PRÉPAREZ LES ARCS ! VISEZ...";
D.q[1170] = "C\'est parti, je t\'attends.";
D.q[1600] = "Tu as les 3 objets que je t\'ai demandés ? Bien ! \nEquipes les, et tu pourras passer dans la salle suivante.";
D.q[1598] = "Ah, je vois que tu as atteint le deuxième niveau. Félicitations ! \n";
D.q[1615] = "Vous savez désormais accélérer le processus de guérison grâce au sang. Cela vous sera utile dans vos périples !";
D.q[1611] = "Vous savez maintenant écouter le sang sauvage qui coule dans vos veines et le contrôler... plus ou moins !";
D.q[5769] = "J\'ai entendu dire que tu commençais à te la jouer, et c\'est pour ça qu\'il te faudra 16000 Kamas si tu veux redevenir Neutre. \nPar contre, si tu souhaites rejoindre un alignement minoritaire, n\'oublie pas que je peux te faire changer d\'allégeance gratuitement.";
D.q[3004] = "Demandeeez mes parchemins ! Ils sont enluminés et garantis sans fautes d\'orthographe ! Je connais aussi les bons plans pour se procurer des parchemins élémentaux, les meilleurs de toute la région !";
D.q[3544] = "Ah un Sadida, un futur maître de la création de créatures animées capables de grands exploits. J\'ai besoin de quelqu\'un comme toi. Utilise ta magie créatrice pour invoquer de puissantes marionnettes et abattre les créatures qui infestent la région.";
D.q[5671] = "Je n\'ai rien à te dire. Passe ton chemin ou je serai contraint de te violenter.";
D.q[5601] = "J\'espère que tu viens m\'annoncer la réussite de ta mission.";
D.q[5660] = "... \nTu n\'as pas l\'impression de me déranger là ?";
D.q[6139] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[7132] = "Si tu veux affronter un Dopeul, je te conseille de te préparer. Alors ? prêt ?";
D.q[3638] = "Rien à signaler !? C\'est qu\'on va finir par rouiller dans ce trou !";
D.q[1970] = "Tu te prends pour qui ? Je vais te...Hmm..attends, tu dis que la Tavernier mise sa vie sur cette bière...intéressant...Très bien nous ne lui voleront plus sa bière s\'il accepte de nous en fournir à un prix très bas. Convainc le s\'il ne veut pas. Va !";
D.q[4383] = "Est-ce le moment ?";
D.q[6283] = "Je suis désolé mais je ne peux pas vous aider. Depuis qu\'elle a remporté la première saison de la Lascar Amakdémie, Pandalida est constamment harcelée dès qu\'elle sort de chez elle. \nLa dernière fois que des admirateurs trop passionnés ont découvert où elle habitait, ils ont recouvert les murs de pâte à Tra Khben et elle a mis plusieurs semaines à s\'en remettre. C\'est d\'ailleurs suite à ça qu\'elle a déménagé et qu\'elle est devenue une cliente régulière de ma taverne. Les malheurs des uns font le bonheur des autres comme on dit.";
D.q[4345] = "Bonjour, ami Bontarien !";
D.q[3237] = "Le gros trou que tu vois ici, mène dans ce que nous appelons communément le Sanctuaire des Dragoeufs. Nous savons très peu de choses sur cet endroit mystérieux, il est habité depuis des lustres par différentes espèces de Dragoeufs. Beaucoup d\'aventuriers ont tenté d\'y pénétrer et de percer les secret de ce sanctuaire, peu d\'entre eux sont revenus. Ce que nous savons, c\'est que ce sanctuaire a été construit il y a très longtemps par les disciples d\'Osamodas, afin de protéger et de faciliter la reproduction de ses Dragons.";
D.q[4382] = "Merci. Dis-moi quand le convoi pourra partir, tu feras partie de l\'escorte.";
D.q[3523] = "Si gobelin devenir magicien, gobelin plus être esclave des Bworks !";
D.q[4048] = "test 3";
D.q[1775] = "Tu n\'as pas assez de kamas pour acheter ces ciseaux.";
D.q[4244] = "Bonsoir !";
D.q[1452] = "J\'ai dit 10 écorces minimum ! ";
D.q[4106] = "La deuxième potion est beaucoup moins puissante, elle permet d\'oublier partiellement ses caractéristiques, si tu ne veux pas perdre ce que tu as appris déjà avec des parchemins de caractéristiques.";
D.q[4364] = "Si ces bandits viennent jusqu\'ici, il est impératif de prendre des mesures contre eux.";
D.q[2900] = "Je dois m\'occuper du passage de grade de nombreux adeptes, si tu veux retenter un passage, reviens me voir d\'ici cinq heures au minimum !";
D.q[2133] = "Si vous pouviez m\'apporter 5 laines de boufton de chaque couleur, je vous taillerai une petite cape spécialement pour vous !";
D.q[4469] = "Désolé, je ne prends pas de commande pour le moment.";
D.q[248] = "Que pourrais-tu bien connaître à l\'art du fouet ? Reviens quand tu auras une queue fourchue et des cornes !";
D.q[3306] = "Si tu ne sais pas où est la bibliothèque, n\'hésite pas à demander ton chemin.";
D.q[5719] = "J\'ai glissé deux mots à ton sujet aux différents maîtres d\'Ordre et ils sont prêts à tester ta valeur. Afin de les convaincre, tu dois te rendre à la Tour des Ordres de Brâkmar et discuter avec eux pour choisir ta voie. \nEvite de te presser et passe d\'abord boire un coup à la taverne, j\'ai horreur des miliciens qui font trop de zèle, surtout que tu n\'es pas obligé de choisir une spécialité immédiatement.";
D.q[3642] = "Parfait, fais le tour de la ville et va demander aux habitants si tout va bien. J\'attends ton rapport !";
D.q[6578] = "Un instant, je réfléchis.";
D.q[3426] = "J\'ai beaucoup de travail, c\'est ma femme qui s\'occupe des enfants.";
D.q[6780] = "Si je fais disparaître l\'air que tu respires, tu te retrouves comme un poisson hors de l\'eau. Tu ouvres la bouche comme ça, gob gob, et rien ne se passe, tu t\'asphyxies.";
D.q[1813] = "Si tu veux affronter un Dopeul, il faudra faire une donation d\'Edelweiss au temple...";
D.q[385] = "J\'offre un Grand Parchemin de Force à celui qui sera capable de me ramener 70 pics de Prespic, 75 pinces de Crabe et 40 côtes de Rib. Avec autant de trophées, je pourrai aisément faire croire à Pénéloppe - la femme dont je suis épris - que j\'ai vécu de formidables aventures et espérer la séduire ainsi.";
D.q[3234] = "Yiiihhhaaaaa, des kamas, des kamas. \nVous en voulez ?";
D.q[6764] = "Donnez-moi un B. \nDonnez-moi un O. \nDonnez-moi un N. \nDonnez-moi un T. \nDonnez-moi un A.";
D.q[3046] = "Je ne t\'avais pas menti, c\'est un château de toute beauté !";
D.q[2822] = "Désolé je ne peux pas te vendre d\'alcool, tu n\'y survivrais pas !";
D.q[421] = "Il faut beaucoup de pratique pour devenir un bon Forgeron.  \nIl faut également savoir travailler les métaux et les différentes essences de bois pour forger les armes de base. \nLes armes les plus puissantes nécessitent souvent des pierres précieuses ou des métaux rares aux propriétés magiques.";
D.q[7576] = "De quel autre lieu voulez-vous les coordonnées ?";
D.q[7577] = "De quel autre lieu voulez-vous les coordonnées ?";
D.q[5545] = "Si tu veux découvrir la magnifique ville d\'Astrub ainsi que l\'immensité de ce monde, il faudra que tu télécharges la version complète de DOFUS sur le site officiel www.dofus.com";
D.q[7040] = "Quelle caractéristique doit modifier ce parchemin ?";
D.q[6702] = "Rien à signaler !";
D.q[6542] = "Hmmmmff... Mmmmfff !";
D.q[3096] = "Je vois que tu sais où trouver de la bonne bière. J\'aimerais bien en comparer plusieurs.";
D.q[4274] = "Qui ? Ah, ce n\'est pas le dernier champion du concours de ramassage de bave de bouftou ?... Non ? Bon ben, \'connais pas alors.";
D.q[4465] = "Il est sur la route menant à Astrub.";
D.q[7555] = "Parfait, je vois que nous sommes sur la même longueur d\'onde. \nJe n\'ai pas envie que notre conversation s\'ébruite, alors rejoins-moi dans ma maison. Elle se trouve au sud de la statue du dieu Iop, à proximité de l\'hôtel de vente des bricoleurs. \nJe préfère que tu évites de passer par la porte principale. Utilise plutôt la porte de derrière, elle est plus discrète et cachée par un tas de caisses. \nJe t\'en dirai davantage lorsque tu m\'auras rejointe.";
D.q[6584] = "La liste ? Ah oui, la liste. Tenez, la voilà. Au passage, débarrassez-moi de sa caisse d\'outils, elle encombre ma forge depuis trop longtemps.";
D.q[2374] = "Hummm... Le monde des Onze est en train d\'changer, ouais. Ainsi tu convoites les Dofus ? Tu devras d\'abord amadouer leurs gardiens, ou les combattre... Sont puissants, les gardiens... et jaloux... C\'est des aventuriers expérimentés qui pourront s\'y frotter !";
D.q[3281] = "Bonjour, je suis Igloute, le célèbre capitaine ! Je suis persuadé que tu as déjà entendu parler de moi. \nAvant d\'être capitaine de navire sans navire, j\'étais cuisinier. \nOui cuisinier, je préparais le poisson comme personne, je prenais les poissons vivants, oui vivants monsieur ! \nEnsuite, je les écrasais vivants, et je rajoutais du sel, et des herbes magiques, elles aussi encore vivantes ! \nEt mon poisson permettait à ceux qui le mangeaient, de respirer sous l\'eau s\'ils nageaient à l\'envers. Comment ça tu ne me crois-pas ! Mais si je t\'assure, tout ce que je dis est véridique.";
D.q[2238] = "Qu\'attends-tu ? Va donc voir Oli Venders ! Il pourra très certainement te fournir du bois d\'arash.";
D.q[1915] = "Finalement tous les candidats étaient plutôt mous. Je pense que je vais embaucher des gens motivés au jour le jour. Il y a de la demande pour ce genre de petit boulot ! Vous pouvez effectuer la première livraison du jour pour moi ? Exceptionnellement je te paierai le double du tarif. Tu auras le droit de revenir me voir pour refaire une livraison sitôt après - si le coeur t\'en dit évidemment !";
D.q[2471] = "Bon ok. Si tu veux vraiment faire tes preuves, va donc voir Ant Emicheun. Il a de drôles de problèmes dans ses affaires... *soupir*. Si tu peux l\'aider, tu pourras peut-être m\'aider aussi quand tu seras plus fort...";
D.q[4270] = "Qui ? Ah, ce n\'est pas le dernier champion du concours de ramassage de bave de bouftou ?... Non ? Bon ben, \'connais pas alors.";
D.q[2370] = "Je t\'écoute, de quel bâtiment d\'hôtel des ventes cherches-tu l\'emplacement ?";
D.q[2978] = "Si j\'en reprends un à se balader avec des faux Dofus sur lui, ça va barder !";
D.q[4402] = "Mot de passe ?";
D.q[7614] = "Toi, qui ose fouler le sol de ce qui fut jadis un village prospère, aujourd\'hui détruit par la folie des hommes, tu arrives trop tard.";
D.q[1871] = "Les Roublards hein ? Hummm, quels intérêts auraient-ils eu à faire disparaître ma maison ?";
D.q[3324] = "Merci, jeune aventurier !";
D.q[5469] = "Pfff, toâ pas avoir humour !";
D.q[1873] = "Bon, Réfléchissez à tout ça et aller me chercher le coupable, ne revenez pas sans ! Aller parler à l\'alchimiste si vous avez quelque chose à analyser, n\'hésitez pas à faire peur ou à soudoyer les personnes que vous interrogerez, je VEUX savoir où est ma MAISON !";
D.q[358] = "Dans une marmite, faites revenir 80 Glands, 80 Langues de Pissenlit Diabolique, 80 Pétales de Rose, et agrémentez le tout d\'une vingtaine de doses de Sporme de Champ Champ. Vous obtiendrez une délicieuse soupe veloutée.  \nJe m\'en lèche les babines d\'avance.";
D.q[4486] = "J\'ignorais que le bâtiment de la milice de Brâkmar était mitoyen avec le port de Madrestam. Que fais-tu ici ?";
D.q[5670] = "Qu\'est-ce que tu nous veux ?";
D.q[1744] = "Les Ecaflips sont des personnages très forts, ils cherchent donc des équipements augmentant leur force.";
D.q[6538] = "Amayiro m\'a demandé de vous aider. Cependant, avec la recrudescence des attaques de convoi, je ne peux me séparer de mes hommes. Vous avez peut-être des amis qui peuvent vous aider. Sinon, vous êtes seul.";
D.q[6176] = "Qu\'est-ce que ça peut me faire qu\'un idiot m\'envoie un incompétent ? Brâkmar n\'a pas besoin de toi, du moins pour l\'instant.";
D.q[3697] = "Il y a toujours un artisan qui a besoin des ressources des récolteurs, c\'est un excellent moyen de se faire quelques kamas bien mérités.";
D.q[7603] = "C\'est terrible, vraiment terrible...";
D.q[4608] = "Reviens me voir quand tu auras du nouveau.";
D.q[5658] = "Salutations, j\'espère que Terra Tibya ne te martyrise pas trop. Hahaha.";
D.q[3844] = "Tou mé ramène les ingrédients pour la ouache. Tou es amical, tou es oune artiste.";
D.q[3688] = "Mais c\'est pas vrai de voir ça, c\'est quand même pas compliqué de trouver des personnes dans le coin ! Sois méthodique ! Je t\'attends !";
D.q[3292] = "Irrrrk ! \nFneuh Shiii krodocouic doc krik kric ?";
D.q[1215] = "Pour rejoindre notre Ordre, montre nous un minimum ta valeur en rapportant 1 oeil de Corbac.";
D.q[3396] = "Je n\'ai plus rien, allez du vent ! hop ! zou ! du balai !";
D.q[5696] = "Pourquoi fouilles-tu dans ton sac ? Tu as perdu quelque chose ?";
D.q[6428] = "Et les autres ? Et bien tant qu\'ils ne font pas d\'histoire et qu\'ils payent leur consommation tout va bien. Par contre ce sont tous des habitués, rien à voir avec les voyageurs que l\'on trouve à la taverne du Feubuk.";
D.q[3596] = "C\'est mon patron qui vous envoie ? Il est un peu stressé mais sympa. Qu\'est ce que je peux faire pour vous ?";
D.q[5384] = "Est-ce ton dernier mot ?";
D.q[3279] = "J\'ai l\'impression que tu as été mordu par un Abraknyde... Je pense que tu risques de subir la terrible malédiction de cette forêt. J\'ai bien peur que d\'une minute à l\'autre, tu ne commences à te transformer, tu devrais te dépêcher de sortir de ce donjon tant qu\'il en est encore temps, la sortie est devant toi.";
D.q[2494] = "Mmmh ? Demande ça à Manganèze, je suis occupé !";
D.q[1127] = "Cliquotis cliquotecliquote clicliquotis, Cliquolicquotis.";
D.q[1340] = "Rendez moi ce médaillon !";
D.q[6247] = "Garde-les pour l\'instant, tu en auras besoin pour ta prochaine mission.";
D.q[6136] = "Tu me ramènes les âmes que je t\'ai demandées ?";
D.q[6158] = "Je vois que tu ne sais pas comment capturer une âme. Cette technique particulière est indispensable. Je peux t\'aider à l\'apprendre si tu le souhaites.";
D.q[353] = "Bouldiou de bouldiou, j\'suis ben crevaille...Min bien el plu préchieux à dichparu, minche alors.";
D.q[7519] = "Tu ne possèdes pas assez de doplons pour réaliser cet échange.";
D.q[7521] = "Contre quels doplons souhaites-tu faire l\'échange ?";
