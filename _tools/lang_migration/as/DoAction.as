D.q[2155] = "Tiens je te donne tout";
D.q[719] = "Apparemment Torche n\'était pas à son poste la dernière fois que tu l\'as affronté. Pour me rendre service, il faudrait que tu fasses le tour des tavernes pour m\'apporter la liste des miliciens fainéants dans son genre. \nDis-leur que tu fais un recensement, et que tu dois récupérer leurs badges jusqu\'à ce soir.";
D.q[1629] = "Merci ! Ma mère me disait toujours : " + "\"" + "Si tu manges des Rougely et des Vertgely, ne mange jamais 4 Blugely en même temps !" + "\"" + "";
D.q[5460] = "Moâ meurs de faim ! Môa vouloir Pomme !";
D.q[3195] = "La dernière fois que j\'ai croisé le Maître Corbac, il se cachait dans la onzième salle, ou la douzième, ou la quinzième, ou peut-être dans la seizième salle, je ne me souviens plus.";
